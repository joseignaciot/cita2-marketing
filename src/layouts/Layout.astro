---
import '../styles/global.css';
import DarkModeToggle from '../components/DarkModeToggle.astro';
import ExitPopup from '../components/ExitPopup.astro';
import LiveChat from '../components/LiveChat.astro';
import StickyCTA from '../components/StickyCTA.astro';

export interface Props {
  title: string;
  description: string;
  aiDescription?: string;
  ogImage?: string;
  canonicalUrl?: string;
  noindex?: boolean;
  schema?: Record<string, any>;
  ogType?: string;
}

const {
  title,
  description,
  aiDescription,
  ogImage = '/og-image.jpg',
  canonicalUrl,
  noindex = false,
  schema,
  ogType = 'website'
} = Astro.props;

const siteUrl = 'https://agendadereservas.com';
const fullCanonical = canonicalUrl || `${siteUrl}${Astro.url.pathname}`;

// Analytics: GA4 se gestiona desde GTM (GTM-NPTDPRTF)

// Default WebSite schema
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://agendadereservas.com/#website',
  name: 'Agenda de Reservas',
  url: siteUrl,
  description: 'Software de gestión de citas y reservas para peluquerías, estética, restaurantes y turismo. Sin comisiones, setup en 2 minutos.',
};

const finalSchema = schema ? [websiteSchema, schema] : websiteSchema;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />
  
  <!-- Google Search Console Verification -->
  <meta name="google-site-verification" content="__NxzQdcaCeFV3HSgya-Q05UijnFXp_aCMf4woO5egI" />
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <!-- Canonical -->
  <link rel="canonical" href={fullCanonical} />
  
  <!-- Robots -->
  {noindex ? (
    <meta name="robots" content="noindex, nofollow" />
  ) : (
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  )}
  
  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="Agenda de Reservas" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={fullCanonical} />
  <meta property="og:image" content={`${siteUrl}${ogImage}`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={title} />
  <meta property="og:locale" content="es_ES" />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@agendadereservas" />
  <meta name="twitter:creator" content="@agendadereservas" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />
  <meta name="twitter:image:alt" content={title} />
  
  <!-- Title -->
  <title>{title}</title>
  
  <!-- AI / LLM Meta (para ChatGPT, Perplexity, Gemini) -->
  {aiDescription && (
    <meta name="ai-description" content={aiDescription} />
  )}
  
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(finalSchema)} />
  
  <!-- Meta Pixel: configurar en GTM cuando se tenga Pixel ID -->

    <!-- Google tag (gtag.js) - GA4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-47H0N7KECZ"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-47H0N7KECZ');
  </script>

  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-NPTDPRTF');</script>
  <!-- End Google Tag Manager -->

</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NPTDPRTF"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
  <DarkModeToggle />
  <slot />
  <ExitPopup />
  <LiveChat />
  <StickyCTA />
  <!-- Netlify Identity (para Decap CMS) -->
  <!-- is:inline es obligatorio: evita que Astro/Vite procese el script como módulo ES,
       lo que causaba un error CORS al intentar importarlo dinámicamente -->
  <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <script is:inline>
    if (window.netlifyIdentity) {
      // Tras login exitoso (incluyendo tras reset de contraseña), redirigir al admin
      window.netlifyIdentity.on("login", function() {
        document.location.href = "/admin/";
      });

      // Si hay un recovery_token en la URL, el widget lo gestiona automáticamente.
      // NO llamar a open() manualmente aquí — hacerlo después del "init"
      // resetea el modal al estado de login, borrando el formulario de nueva contraseña.
      // El widget v1 abre solo el formulario correcto al detectar #recovery_token en el hash.
    }
  </script>
</body>
</html>
