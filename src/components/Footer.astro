---
const footerLinks = {
  producto: [
    { label: 'Funcionalidades', href: '/funcionalidades' },
    { label: 'Precios', href: '/precios' },
    { label: 'vs AgendaPro', href: '/vs/agendapro' },
    { label: 'vs Reservio', href: '/vs/reservio' },
  ],
  sectores: [
    { label: 'Peluquerías', href: '/peluquerias' },
    { label: 'Estética', href: '/estetica' },
    { label: 'Dentistas', href: '/dentistas' },
    { label: 'Fisioterapia', href: '/fisioterapia' },
    { label: 'Tatuajes', href: '/tatuajes' },
    { label: 'Spas', href: '/spas' },
    { label: 'Restaurantes', href: '/restaurantes' },
    { label: 'Turismo', href: '/turismo' },
  ],
  recursos: [
    { label: 'Blog', href: '/blog' },
    { label: 'Guías', href: '/guias' },
    { label: 'Contacto', href: '/contacto' },
    { label: 'Iniciar sesión', href: 'https://app.agendadereservas.com' },
  ],
};

const socialLinks = [
  { label: 'Twitter / X', href: 'https://twitter.com/agendadereservas', icon: 'twitter' },
  { label: 'Instagram', href: 'https://instagram.com/agendadereservas', icon: 'instagram' },
  { label: 'LinkedIn', href: 'https://linkedin.com/company/agendadereservas', icon: 'linkedin' },
];
---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-7xl mx-auto container-padding py-16">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
      <!-- Brand -->
      <div class="col-span-2">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-lg">A</span>
          </div>
          <span class="text-xl font-bold text-white">Agenda de Reservas</span>
        </a>
        <p class="text-gray-300 text-sm mb-6 max-w-xs">
          Software de gestión de citas y reservas para negocios de servicios. Sin comisiones, setup en 2 minutos.
        </p>
        <div class="flex gap-4">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-8 h-8 bg-gray-800 rounded-full flex items-center justify-center hover:bg-primary-600 transition-colors"
              aria-label={social.label}
            >
              {social.icon === 'twitter' && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              )}
              {social.icon === 'instagram' && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              )}
              {social.icon === 'linkedin' && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>
      
      <!-- Links -->
      <div>
        <h4 class="text-white font-semibold mb-4">Producto</h4>
        <ul class="space-y-2 text-sm">
          {footerLinks.producto.map((link) => (
            <li>
              <a href={link.href} class="hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <div>
        <h4 class="text-white font-semibold mb-4">Sectores</h4>
        <ul class="space-y-2 text-sm">
          {footerLinks.sectores.map((link) => (
            <li>
              <a href={link.href} class="hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <div>
        <h4 class="text-white font-semibold mb-4">Recursos</h4>
        <ul class="space-y-2 text-sm">
          {footerLinks.recursos.map((link) => (
            <li>
              <a href={link.href} class="hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    
    <!-- Bottom -->
    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-gray-400">
        © 2026 Agenda de Reservas. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
