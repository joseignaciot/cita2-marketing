---
// HeroV2 - Apple Style: Product-focused with problem/solution
interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCta?: { text: string; href: string };
}

const { 
  title = "Tu agenda,\nautomatizada",
  subtitle = "Deja que tus clientes reserven 24/7 mientras tú descansas. El software de gestión que reduce las ausencias un 70%.",
  ctaText = "Prueba gratis 14 días",
  ctaHref = "https://app.agendadereservas.com",
  secondaryCta = { text: "Ver cómo funciona", href: "#como-funciona" }
} = Astro.props;

// Problem/Solution data for visual impact
const problems = [
  { icon: "📞", text: "Llamadas constantes a deshoras" },
  { icon: "❌", text: "25% de ausencias que te cuestan dinero" },
  { icon: "📋", text: "Agenda en papel caótica" }
];

const solutions = [
  { icon: "✓", text: "Reservas automáticas 24/7" },
  { icon: "✓", text: "70% menos ausencias con recordatorios" },
  { icon: "✓", text: "Todo digital y organizado" }
];
---

<section class="relative min-h-screen flex items-center overflow-hidden gradient-hero">
  <div class="container-apple w-full py-20 lg:py-32">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Content -->
      <div class="text-center lg:text-left animate-fade-up">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/80 backdrop-blur rounded-full shadow-sm mb-8 animate-fade-in delay-100">
          <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
          <span class="text-sm font-medium text-gray-600">Más de 500 negocios confían en Agenda de Reservas</span>
        </div>
        
        <!-- Headline -->
        <h1 class="text-display text-gray-900 mb-6 whitespace-pre-line">
          {title}
        </h1>
        
        <!-- Subtitle -->
        <p class="text-xl text-gray-700 mb-10 max-w-xl mx-auto lg:mx-0 leading-relaxed">
          {subtitle}
        </p>
        
        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start mb-12 animate-fade-in delay-300">
          <a href={ctaHref} class="btn-apple-primary">
            {ctaText}
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href={secondaryCta.href} class="btn-apple-secondary">
            {secondaryCta.text}
          </a>
        </div>
        
        <!-- Trust indicators -->
        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-6 text-sm text-gray-700 animate-fade-in delay-400">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span>Sin tarjeta</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span>Setup en 2 min</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span>Cancela cuando quieras</span>
          </div>
        </div>
      </div>
      
      <!-- Visual: Problem/Solution Comparison -->
      <div class="relative animate-fade-in delay-200">
        <!-- Product Mockup -->
        <div class="mockup-frame bg-white p-6 relative z-10">
          <!-- App Interface Mockup -->
          <div class="bg-gray-50 rounded-xl p-6">
            <!-- Header -->
            <div class="flex items-center justify-between mb-6 pb-4 border-b border-gray-200">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-blue-600 rounded-lg flex items-center justify-center">
                  <span class="text-white font-bold text-lg">C</span>
                </div>
                <span class="font-semibold text-gray-900">Mi Agenda</span>
              </div>
              <div class="flex gap-2">
                <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center shadow-sm">
                  <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                  </svg>
                </div>
                <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center shadow-sm">
                  <div class="w-6 h-6 bg-gray-300 rounded-full"></div>
                </div>
              </div>
            </div>
            
            <!-- Calendar View -->
            <div class="space-y-3">
              <div class="flex gap-4">
                {['Lun', 'Mar', 'Mié', 'Jue', 'Vie'].map((day, i) => (
                  <div class={`flex-1 text-center py-3 rounded-lg ${i === 1 ? 'bg-blue-600 text-white' : 'bg-white text-gray-600'}`}>
                    <div class="text-xs mb-1">{day}</div>
                    <div class="text-lg font-semibold">{10 + i}</div>
                  </div>
                ))}
              </div>
              
              <!-- Appointment Cards -->
              <div class="space-y-2 mt-4">
                <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="w-2 h-12 bg-blue-500 rounded-full"></div>
                    <div>
                      <p class="font-medium text-gray-900">María García</p>
                      <p class="text-sm text-gray-700">Corte y tinte - 10:00</p>
                    </div>
                  </div>
                  <span class="px-3 py-1 bg-green-100 text-green-700 text-xs font-medium rounded-full">Confirmado</span>
                </div>
                
                <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="w-2 h-12 bg-purple-500 rounded-full"></div>
                    <div>
                      <p class="font-medium text-gray-900">Carlos Ruiz</p>
                      <p class="text-sm text-gray-700">Mechas - 12:30</p>
                    </div>
                  </div>
                  <span class="px-3 py-1 bg-yellow-100 text-yellow-700 text-xs font-medium rounded-full">Pendiente</span>
                </div>
                
                <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 flex items-center justify-between opacity-60">
                  <div class="flex items-center gap-3">
                    <div class="w-2 h-12 bg-gray-300 rounded-full"></div>
                    <div>
                      <p class="font-medium text-gray-400">Slot disponible</p>
                      <p class="text-sm text-gray-400">15:00 - 16:00</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Floating Stats Card -->
          <div class="absolute -bottom-6 -right-6 bg-white rounded-2xl shadow-xl p-4 border border-gray-100 animate-fade-in delay-500">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                </svg>
              </div>
              <div>
                <p class="text-2xl font-bold text-gray-900">+40%</p>
                <p class="text-sm text-gray-700">más reservas</p>
              </div>
            </div>
          </div>
          
          <!-- Floating Notification -->
          <div class="absolute -top-4 -left-4 bg-white rounded-xl shadow-lg p-3 border border-gray-100 animate-fade-in delay-600">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div class="text-sm">
                <p class="font-medium text-gray-900">Nueva reserva</p>
                <p class="text-gray-700">Ana - Mañana 11:00</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Background decoration -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-gradient-to-br from-blue-100/50 to-purple-100/50 rounded-full blur-3xl -z-10"></div>
      </div>
    </div>
  </div>
  
  <!-- Bottom gradient fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#FAFAFA] to-transparent"></div>
</section>
