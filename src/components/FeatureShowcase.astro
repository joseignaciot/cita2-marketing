---
// FeatureShowcase - Apple-style feature storytelling
// Deep dive into 3 main features with visual storytelling

const features = [
  {
    badge: "Reservas",
    title: "Tu agenda se llena sola,\nincluso mientras duermes",
    description: "Los clientes reservan online 24/7 desde cualquier dispositivo. Tú despiertas con la agenda organizada y los recordatorios ya enviados.",
    benefits: [
      "Página de reservas con tu marca y colores",
      "Disponibilidad en tiempo real, sin solapamientos",
      "Confirmación inmediata por email y WhatsApp",
      "Integración en tu web, Google Business y redes"
    ],
    stat: "+40%",
    statLabel: "más reservas online",
    image: "reservations",
    color: "blue"
  },
  {
    badge: "Recordatorios",
    title: "Ausencias reducidas\nhasta un 70%",
    description: "El sistema envía recordatorios automáticos por email 24h antes y WhatsApp 2h antes. Los clientes llegan puntuales o avisan con tiempo si necesitan cambiar.",
    benefits: [
      "Email, SMS y WhatsApp automáticos",
      "Mensajes personalizados con tu tono de marca",
      "Confirmación con un clic desde el móvil",
      "Reagendado fácil sin llamadas"
    ],
    stat: "70%",
    statLabel: "menos citas perdidas",
    image: "reminders",
    color: "green"
  },
  {
    badge: "Gestión",
    title: "Todo tu negocio,\nen una sola pantalla",
    description: "Agenda, clientes, historial, pagos y estadísticas en una plataforma unificada. Accede desde el móvil en la silla o desde el ordenador en recepción.",
    benefits: [
      "CRM completo con historial de cada cliente",
      "Dashboard con ingresos, ocupación y tendencias",
      "Pagos online integrados con Stripe",
      "Exportación de datos para tu contable"
    ],
    stat: "10h",
    statLabel: "ahorro semanal",
    image: "dashboard",
    color: "purple"
  }
];
---

<section class="section-apple gradient-subtle" id="como-funciona">
  <div class="container-apple">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-20">
      <span class="feature-bubble mb-4 inline-block">Cómo funciona</span>
      <h2 class="text-headline text-gray-900 mb-6">
        Todo lo que necesitas,\n<span class="gradient-text">nada que no necesites</span>
      </h2>
      <p class="text-body text-lg">
        Tres pilares que transforman tu gestión diaria. Sin complicaciones, sin funciones que nunca usarás.
      </p>
    </div>

    <!-- Features -->
    <div class="space-y-32">
      {features.map((feature, index) => (
        <div class={`grid lg:grid-cols-2 gap-16 items-center ${index % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
          <!-- Content -->
          <div class={`${index % 2 === 1 ? 'lg:order-2' : ''} scroll-animate`}>
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-full shadow-sm mb-6">
              <span class={`w-2 h-2 rounded-full ${
                feature.color === 'blue' ? 'bg-blue-500' : 
                feature.color === 'green' ? 'bg-green-500' : 'bg-purple-500'
              }`}></span>
              <span class="text-sm font-medium text-gray-600">{feature.badge}</span>
            </div>

            <h3 class="text-title text-gray-900 mb-6 whitespace-pre-line">
              {feature.title}
            </h3>

            <p class="text-body text-lg mb-8">
              {feature.description}
            </p>

            <ul class="space-y-4 mb-8">
              {feature.benefits.map((benefit) => (
                <li class="flex items-start gap-3">
                  <div class={`w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 ${
                    feature.color === 'blue' ? 'bg-blue-100' : 
                    feature.color === 'green' ? 'bg-green-100' : 'bg-purple-100'
                  }`}>
                    <svg class={`w-4 h-4 ${
                      feature.color === 'blue' ? 'text-blue-600' : 
                      feature.color === 'green' ? 'text-green-600' : 'text-purple-600'
                    }`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                  </div>
                  <span class="text-gray-700">{benefit}</span>
                </li>
              ))}
            </ul>

            <!-- Stat highlight -->
            <div class="inline-flex items-center gap-4 bg-white rounded-2xl p-4 shadow-sm">
              <div class={`text-4xl font-bold ${
                feature.color === 'blue' ? 'text-blue-600' : 
                feature.color === 'green' ? 'text-green-600' : 'text-purple-600'
              }`}>
                {feature.stat}
              </div>
              <div class="text-gray-600 text-sm">{feature.statLabel}</div>
            </div>
          </div>

          <!-- Visual Mockup -->
          <div class={`${index % 2 === 1 ? 'lg:order-1' : ''} scroll-animate delay-200`}>
            <div class="mockup-frame bg-white p-8 relative">
              <!-- Abstract representation of the feature -->
              <div class={`rounded-2xl p-8 ${
                feature.color === 'blue' ? 'bg-gradient-to-br from-blue-50 to-blue-100' : 
                feature.color === 'green' ? 'bg-gradient-to-br from-green-50 to-green-100' : 'bg-gradient-to-br from-purple-50 to-purple-100'
              }`}>
                {feature.image === 'reservations' && (
                  <div class="space-y-4">
                    <div class="flex items-center justify-between mb-6">
                      <span class="text-gray-700 text-sm">Reservas de hoy</span>
                      <span class="text-2xl font-bold text-gray-900">8 citas</span>
                    </div>
                    {['María - Corte 10:00', 'Carlos - Tinte 12:00', 'Ana - Peinado 16:00'].map((apt, i) => (
                      <div class="bg-white rounded-xl p-4 shadow-sm flex items-center justify-between">
                        <div class="flex items-center gap-3">
                          <div class={`w-3 h-10 rounded-full ${
                            i === 0 ? 'bg-blue-500' : i === 1 ? 'bg-purple-500' : 'bg-green-500'
                          }`}></div>
                          <span class="font-medium text-gray-900">{apt}</span>
                        </div>
                        <span class="text-xs text-gray-700">Confirmado</span>
                      </div>
                    ))}
                    <div class="mt-4 p-4 bg-green-50 rounded-xl border border-green-200">
                      <div class="flex items-center gap-2">
                        <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span class="text-green-800 font-medium text-sm">Nueva reserva: Luis - Mañana 11:00</span>
                      </div>
                    </div>
                  </div>
                )}

                {feature.image === 'reminders' && (
                  <div class="space-y-4">
                    <div class="bg-white rounded-xl p-4 shadow-sm">
                      <div class="flex items-start gap-3">
                        <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0">
                          <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                          </svg>
                        </div>
                        <div>
                          <p class="font-medium text-gray-900">Recordatorio enviado</p>
                          <p class="text-sm text-gray-700">María García - Mañana 10:00</p>
                          <p class="text-xs text-green-600 mt-1">✓ Email + WhatsApp enviados</p>
                        </div>
                      </div>
                    </div>
                    <div class="bg-white rounded-xl p-4 shadow-sm border-l-4 border-yellow-400">
                      <div class="flex items-start gap-3">
                        <div class="w-10 h-10 bg-yellow-100 rounded-full flex items-center justify-center flex-shrink-0">
                          <svg class="w-5 h-5 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                          </svg>
                        </div>
                        <div>
                          <p class="font-medium text-gray-900">Pendiente de confirmar</p>
                          <p class="text-sm text-gray-700">Carlos Ruiz - Viernes 15:00</p>
                          <p class="text-xs text-yellow-600 mt-1">⏰ WhatsApp en 2 horas</p>
                        </div>
                      </div>
                    </div>
                  </div>
                )}

                {feature.image === 'dashboard' && (
                  <div class="space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                      <div class="bg-white rounded-xl p-4 shadow-sm">
                        <p class="text-gray-700 text-xs mb-1">Este mes</p>
                        <p class="text-2xl font-bold text-gray-900">4.250€</p>
                        <p class="text-green-600 text-xs">↑ 12% vs mes pasado</p>
                      </div>
                      <div class="bg-white rounded-xl p-4 shadow-sm">
                        <p class="text-gray-700 text-xs mb-1">Citas hoy</p>
                        <p class="text-2xl font-bold text-gray-900">8</p>
                        <p class="text-blue-600 text-xs">2 plazas libres</p>
                      </div>
                    </div>
                    <div class="bg-white rounded-xl p-4 shadow-sm">
                      <div class="flex items-center justify-between mb-3">
                        <span class="font-medium text-gray-900">Clientes nuevos</span>
                        <span class="text-2xl font-bold text-blue-600">23</span>
                      </div>
                      <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                        <div class="h-full bg-blue-500 rounded-full" style="width: 65%"></div>
                      </div>
                    </div>
                  </div>
                )}
              </div>

              <!-- Floating elements -->
              <div class="absolute -top-4 -right-4 bg-white rounded-xl shadow-lg p-3 border border-gray-100">
                <div class="flex items-center gap-2">
                  <div class={`w-8 h-8 rounded-full flex items-center justify-center ${
                    feature.color === 'blue' ? 'bg-blue-100' : 
                    feature.color === 'green' ? 'bg-green-100' : 'bg-purple-100'
                  }`}>
                    <svg class={`w-4 h-4 ${
                      feature.color === 'blue' ? 'text-blue-600' : 
                      feature.color === 'green' ? 'text-green-600' : 'text-purple-600'
                    }`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                  </div>
                  <span class="text-sm font-medium text-gray-700">Automático</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
