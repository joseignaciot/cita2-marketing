---
// Calculadora de ahorro interactiva para la página de precios
---

<div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-6 md:p-8" id="calculadora-ahorro">
  <h3 class="text-2xl font-bold text-gray-900 mb-6 text-center">💰 Calcula tu ahorro anual</h3>
  
  <div class="space-y-6">
    <!-- Empleados -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">
        ¿Cuántos empleados tienes?
      </label>
      <input 
        type="range" 
        id="empleados" 
        min="1" 
        max="20" 
        value="3"
        class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-blue-600"
      >
      <div class="flex justify-between text-sm text-gray-500 mt-1">
        <span>1</span>
        <span id="empleados-valor" class="font-semibold text-blue-600 text-lg">3 empleados</span>
        <span>20</span>
      </div>
    </div>

    <!-- Software actual -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">
        ¿Qué software usas actualmente?
      </label>
      <select id="software-actual" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
        <option value="agendapro">AgendaPro</option>
        <option value="reservio">Reservio</option>
        <option value="eltenedor">ElTenedor / TheFork</option>
        <option value="calendly">Calendly / Genérico</option>
        <option value="paper">Agenda en papel</option>
      </select>
    </div>

    <!-- Reservas mensuales (solo para ElTenedor) -->
    <div id="reservas-container" class="hidden">
      <label class="block text-sm font-medium text-gray-700 mb-2">
        ¿Cuántas reservas online al mes?
      </label>
      <input 
        type="range" 
        id="reservas" 
        min="10" 
        max="500" 
        value="100"
        step="10"
        class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-blue-600"
      >
      <div class="flex justify-between text-sm text-gray-500 mt-1">
        <span>10</span>
        <span id="reservas-valor" class="font-semibold text-blue-600 text-lg">100 reservas</span>
        <span>500</span>
      </div>
    </div>

    <!-- Resultado -->
    <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-xl p-6 text-center">
      <p class="text-sm text-gray-600 mb-1">Ahorro anual con Cita2:</p>
      <p id="ahorro-anual" class="text-4xl font-bold text-blue-600">1.536€</p>
      <p id="ahorro-mensual" class="text-sm text-gray-500 mt-1">128€/mes</p>
    </div>

    <!-- CTA -->
    <a 
      href="https://cita2.tecelia.com/register"
      class="btn-primary w-full text-center block"
    >
      Empezar a ahorrar →
    </a>
  </div>
</div>

<script>
  const precios = {
    agendapro: { base: 49, porEmpleado: 49 },
    reservio: { base: 31, porEmpleado: 21 },
    eltenedor: { comision: 0.135 }, // 13.5% comisión promedio
    calendly: { base: 0, porEmpleado: 0 },
    paper: { base: 0, porEmpleado: 0 }
  };

  const empleadosInput = document.getElementById('empleados');
  const empleadosValor = document.getElementById('empleados-valor');
  const softwareInput = document.getElementById('software-actual');
  const reservasInput = document.getElementById('reservas');
  const reservasValor = document.getElementById('reservas-valor');
  const reservasContainer = document.getElementById('reservas-container');
  const ahorroAnual = document.getElementById('ahorro-anual');
  const ahorroMensual = document.getElementById('ahorro-mensual');

  function formatMoney(amount) {
    return amount.toLocaleString('es-ES', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 });
  }

  function calcularAhorro() {
    const empleados = parseInt(empleadosInput.value);
    const software = softwareInput.value;
    const reservas = parseInt(reservasInput.value);
    const ticketMedio = 35; // € promedio

    let costeActual = 0;
    const costeCita2 = 19;

    if (software === 'eltenedor') {
      costeActual = reservas * ticketMedio * precios.eltenedor.comision;
    } else if (software === 'paper' || software === 'calendly') {
      // Calculamos oportunidad: 20% más reservas con sistema online
      const reservasExtra = Math.round(empleados * 10 * 0.2);
      costeActual = -(reservasExtra * ticketMedio); // Negativo = ganancia
    } else {
      costeActual = precios[software].base + (precios[software].porEmpleado * (empleados - 1));
    }

    const ahorro = costeActual - costeCita2;
    const ahorroAnualValor = ahorro * 12;

    ahorroAnual.textContent = formatMoney(ahorroAnualValor);
    ahorroMensual.textContent = formatMoney(ahorro) + '/mes';
  }

  empleadosInput.addEventListener('input', (e) => {
    empleadosValor.textContent = e.target.value + ' empleado' + (e.target.value > 1 ? 's' : '');
    calcularAhorro();
  });

  reservasInput.addEventListener('input', (e) => {
    reservasValor.textContent = e.target.value + ' reservas';
    calcularAhorro();
  });

  softwareInput.addEventListener('change', (e) => {
    if (e.target.value === 'eltenedor') {
      reservasContainer.classList.remove('hidden');
    } else {
      reservasContainer.classList.add('hidden');
    }
    calcularAhorro();
  });

  // Inicializar
  calcularAhorro();
</script>
