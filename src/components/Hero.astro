---
interface Props {
  title: string;
  subtitle: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCta?: { text: string; href: string };
  image?: string;
}

const { 
  title, 
  subtitle, 
  ctaText = 'Empezar prueba gratis',
  ctaHref = 'https://agendadereservas.com/register',
  secondaryCta,
  image = '/hero-illustration.svg'
} = Astro.props;
---

<section class="section-padding bg-gradient-to-br from-primary-50 via-white to-white overflow-hidden">
  <div class="max-w-7xl mx-auto container-padding">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Content -->
      <div class="text-center lg:text-left">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-gray-900 leading-tight text-balance">
          {title}
        </h1>
        <p class="mt-6 text-lg md:text-xl text-gray-600 max-w-2xl mx-auto lg:mx-0">
          {subtitle}
        </p>
        
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href={ctaHref} class="btn-primary text-lg px-8 py-4">
            {ctaText}
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          {secondaryCta && (
            <a href={secondaryCta.href} class="btn-secondary text-lg px-8 py-4">
              {secondaryCta.text}
            </a>
          )}
        </div>
        
        <!-- Trust badges -->
        <div class="mt-8 flex flex-wrap items-center justify-center lg:justify-start gap-6 text-sm text-gray-500">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-success" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span>Setup en 2 minutos</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-success" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span>Sin tarjeta</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-success" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span>Cancela cuando quieras</span>
          </div>
        </div>
      </div>
      
      <!-- Image -->
      <div class="relative">
        <div class="relative bg-white rounded-2xl shadow-2xl p-4 md:p-6 border border-gray-100">
          <div class="aspect-[4/3] bg-gradient-to-br from-primary-100 to-primary-50 rounded-xl flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-24 h-24 mx-auto mb-4 bg-primary-600 rounded-2xl flex items-center justify-center shadow-lg">
                <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
              <p class="text-primary-900 font-semibold">Tu agenda, organizada</p>
              <p class="text-primary-600 text-sm mt-1">Reservas 24/7</p>
            </div>
          </div>
        </div>
        
        <!-- Floating badge -->
        <div class="absolute -bottom-4 -left-4 bg-white rounded-xl shadow-lg p-4 border border-gray-100">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-success/10 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-success" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900">+500 negocios</p>
              <p class="text-sm text-gray-500">ya usan Cita2</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
