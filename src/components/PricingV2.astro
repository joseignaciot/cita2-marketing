---
// PricingV2 - Modular pricing section
// Prices loaded from API at build time, with static fallback

const API_URL = 'https://api.agendadereservas.com';

interface PlanPrice { monthly: number; yearly: number; }
interface PricingConfig {
  service_business:     PlanPrice;
  restaurant:           PlanPrice;
  tourism_activities:   PlanPrice;
  addon_communications: PlanPrice;
  addon_payments:       PlanPrice;
  addon_sms:            PlanPrice;
}

const FALLBACK: PricingConfig = {
  service_business:     { monthly: 19, yearly: 190 },
  restaurant:           { monthly: 24, yearly: 240 },
  tourism_activities:   { monthly: 29, yearly: 290 },
  addon_communications: { monthly: 8,  yearly: 80  },
  addon_payments:       { monthly: 8,  yearly: 80  },
  addon_sms:            { monthly: 5,  yearly: 50  },
};

let pricing: PricingConfig = FALLBACK;
try {
  const res = await fetch(`${API_URL}/pricing`, { signal: AbortSignal.timeout(3000) });
  if (res.ok) {
    const data = await res.json();
    if (data?.pricing) pricing = data.pricing;
  }
} catch {
  // Build-time fetch failed — use fallback values
}

const plans = [
  {
    key: 'service_business' as const,
    name: 'Servicios',
    emoji: '✂️',
    description: 'Peluquerías, clínicas, consultas, talleres y cualquier servicio con cita.',
    color: 'blue',
    popular: false,
  },
  {
    key: 'restaurant' as const,
    name: 'Restaurante',
    emoji: '🍽️',
    description: 'Restaurantes, bares, cafeterías con gestión de mesas y turnos de servicio.',
    color: 'orange',
    popular: true,
  },
  {
    key: 'tourism_activities' as const,
    name: 'Turismo',
    emoji: '🏔️',
    description: 'Actividades, tours, excursiones, deportes y experiencias turísticas.',
    color: 'purple',
    popular: false,
  },
];

const addons = [
  {
    key: 'addon_communications' as const,
    icon: '💬',
    name: 'Comunicaciones',
    features: ['WhatsApp Business API', 'SMTP personalizado', 'Encuestas de satisfacción', 'Informes diarios automáticos'],
  },
  {
    key: 'addon_payments' as const,
    icon: '💳',
    name: 'Pagos Online',
    features: ['Stripe, PayPal, WebPay', 'Depósitos y pagos parciales', 'Seguimiento de cobros por reserva', 'Liquidación automática'],
  },
  {
    key: 'addon_sms' as const,
    icon: '📱',
    name: 'SMS Twilio',
    features: ['Recordatorios por SMS', 'Confirmaciones instantáneas', 'Requiere cuenta Twilio propia'],
  },
];

const baseFeatures = [
  'Reservas online ilimitadas',
  'Clientes y CRM ilimitados',
  'Calendario multivista',
  'Página de reservas personalizable',
  'Equipo ilimitado de usuarios',
  'Estadísticas y dashboard',
  'Soporte en español',
  'App móvil incluida',
];
---

<section class="section-apple bg-gradient-to-b from-white via-gray-50 to-white" id="precios">
  <div class="container-apple">

    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="feature-bubble mb-4 inline-block">Precio transparente</span>
      <h2 class="text-headline text-gray-900 mb-6">
        Elige tu plan base.<br />
        <span class="text-gray-400">Añade solo lo que necesitas.</span>
      </h2>
      <p class="text-body text-lg">
        Sin comisiones por reserva, sin límites de clientes ni usuarios. 
        Paga solo por los módulos que usas.
      </p>
    </div>

    <!-- Base plans grid -->
    <div class="grid md:grid-cols-3 gap-6 mb-16 max-w-5xl mx-auto">
      {plans.map((plan) => {
        const monthly = pricing[plan.key].monthly;
        const yearly  = pricing[plan.key].yearly;
        const saving  = monthly * 12 - yearly;
        const colorMap: Record<string, { border: string; badge: string; price: string; btn: string }> = {
          blue:   { border: 'border-blue-200',   badge: 'bg-blue-100 text-blue-700',   price: 'text-blue-700',   btn: 'bg-blue-600 hover:bg-blue-700' },
          orange: { border: 'border-orange-200', badge: 'bg-orange-100 text-orange-700', price: 'text-orange-700', btn: 'bg-orange-500 hover:bg-orange-600' },
          purple: { border: 'border-purple-200', badge: 'bg-purple-100 text-purple-700', price: 'text-purple-700', btn: 'bg-purple-600 hover:bg-purple-700' },
        };
        const c = colorMap[plan.color];
        return (
          <div class={`relative bg-white rounded-2xl border-2 ${c.border} p-8 shadow-sm flex flex-col`}>
            {plan.popular && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-gray-900 text-white text-xs font-bold rounded-full whitespace-nowrap">
                Más popular
              </div>
            )}
            <div class="mb-6">
              <span class="text-3xl mb-2 block">{plan.emoji}</span>
              <h3 class="text-xl font-bold text-gray-900">{plan.name}</h3>
              <p class="text-sm text-gray-500 mt-1">{plan.description}</p>
            </div>
            <div class="mb-6">
              <div class="flex items-baseline gap-1">
                <span class={`text-4xl font-bold ${c.price}`}>{monthly}€</span>
                <span class="text-gray-400">/mes</span>
              </div>
              <p class="text-sm text-gray-500 mt-1">
                O <strong class="text-gray-700">{yearly}€/año</strong> 
                <span class="text-green-600 ml-1">(ahorras {saving}€)</span>
              </p>
            </div>
            <ul class="space-y-2 mb-8 flex-1">
              {baseFeatures.map(f => (
                <li class="flex items-start gap-2 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <a
              href="https://app.agendadereservas.com"
              class={`block text-center text-white text-sm font-semibold py-3 rounded-xl transition-colors ${c.btn}`}
            >
              Empezar gratis 14 días
            </a>
          </div>
        );
      })}
    </div>

    <!-- Addons section -->
    <div class="max-w-5xl mx-auto mb-16">
      <div class="text-center mb-10">
        <h3 class="text-2xl font-bold text-gray-900 mb-2">Módulos adicionales</h3>
        <p class="text-gray-500">Actívalos solo si los necesitas. Cancélalos en cualquier momento.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {addons.map(addon => {
          const prices = pricing[addon.key];
          return (
            <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-2xl">{addon.icon}</span>
                <div>
                  <h4 class="font-bold text-gray-900">{addon.name}</h4>
                  <p class="text-sm text-gray-500">
                    +{prices.monthly}€/mes · +{prices.yearly}€/año
                  </p>
                </div>
              </div>
              <ul class="space-y-2">
                {addon.features.map(f => (
                  <li class="flex items-center gap-2 text-sm text-gray-600">
                    <svg class="w-3.5 h-3.5 text-blue-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Example total -->
    <div class="max-w-2xl mx-auto bg-gray-900 rounded-2xl p-8 text-white mb-16">
      <h4 class="text-lg font-bold mb-4">Ejemplo: Peluquería completa</h4>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between text-gray-300">
          <span>Plan Servicios</span>
          <span>{pricing.service_business.monthly}€/mes</span>
        </div>
        <div class="flex justify-between text-gray-300">
          <span>+ Comunicaciones (WhatsApp + emails)</span>
          <span>+{pricing.addon_communications.monthly}€/mes</span>
        </div>
        <div class="flex justify-between text-gray-300">
          <span>+ Pagos Online (cobros con Stripe)</span>
          <span>+{pricing.addon_payments.monthly}€/mes</span>
        </div>
        <div class="border-t border-gray-700 pt-2 mt-2 flex justify-between font-bold text-lg">
          <span>Total mensual</span>
          <span class="text-green-400">
            {pricing.service_business.monthly + pricing.addon_communications.monthly + pricing.addon_payments.monthly}€/mes
          </span>
        </div>
        <p class="text-gray-500 text-xs pt-1">vs. más de 147€/mes en la competencia para 3 empleados</p>
      </div>
    </div>

    <!-- Trust badges -->
    <div class="flex flex-wrap items-center justify-center gap-8 text-sm text-gray-600">
      {[
        { icon: '🔒', text: 'Sin tarjeta para probar' },
        { icon: '❌', text: 'Cancela cuando quieras' },
        { icon: '🇪🇸', text: 'Soporte en español' },
        { icon: '♾️', text: 'Sin límite de reservas' },
      ].map(({ icon, text }) => (
        <div class="flex items-center gap-2">
          <span>{icon}</span>
          <span>{text}</span>
        </div>
      ))}
    </div>

  </div>
</section>
