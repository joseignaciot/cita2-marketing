---
// Comprehensive SEO Schema Component
// Includes: Service, LocalBusiness, HowTo, Review, AggregateRating, Offer

interface Props {
  type: 'service' | 'localbusiness' | 'product' | 'howto' | 'article' | 'review';
  data: Record<string, any>;
}

const { type, data } = Astro.props;

// Base Organization Schema
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://cita2.tecelia.com/#organization',
  name: 'Cita2',
  url: 'https://cita2.tecelia.com',
  logo: {
    '@type': 'ImageObject',
    url: 'https://cita2.tecelia.com/favicon.svg',
    width: 512,
    height: 512
  },
  description: 'Software de gestión de citas y reservas para negocios de servicios',
  foundingDate: '2023',
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'ES',
    addressLocality: 'Santiago de Compostela',
    addressRegion: 'Galicia'
  },
  contactPoint: {
    '@type': 'ContactPoint',
    '@id': 'https://cita2.tecelia.com/#contact',
    contactType: 'customer support',
    email: 'soporte@cita2.tecelia.com',
    availableLanguage: ['Spanish', 'English'],
    areaServed: 'ES',
    hoursAvailable: {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '18:00'
    }
  },
  sameAs: [
    'https://twitter.com/cita2app',
    'https://linkedin.com/company/cita2',
    'https://instagram.com/cita2app'
  ]
};

// Service Schema Template
function generateServiceSchema(serviceData: any) {
  return {
    '@context': 'https://schema.org',
    '@graph': [
      organizationSchema,
      {
        '@type': 'Service',
        '@id': `https://cita2.tecelia.com${serviceData.url}/#service`,
        name: serviceData.name,
        description: serviceData.description,
        provider: { '@id': 'https://cita2.tecelia.com/#organization' },
        areaServed: {
          '@type': 'Country',
          name: 'España'
        },
        hasOfferCatalog: {
          '@type': 'OfferCatalog',
          name: 'Planes Cita2',
          itemListElement: {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Plan Profesional Cita2',
              description: 'Software de gestión de citas completo'
            },
            price: '19',
            priceCurrency: 'EUR',
            priceValidUntil: '2026-12-31',
            availability: 'https://schema.org/InStock',
            url: 'https://cita2.tecelia.com/precios'
          }
        },
        aggregateRating: serviceData.rating ? {
          '@type': 'AggregateRating',
          ratingValue: serviceData.rating.value,
          reviewCount: serviceData.rating.count,
          bestRating: 5,
          worstRating: 1
        } : undefined,
        review: serviceData.reviews?.map((review: any) => ({
          '@type': 'Review',
          author: {
            '@type': 'Person',
            name: review.author
          },
          reviewBody: review.text,
          reviewRating: {
            '@type': 'Rating',
            ratingValue: review.rating,
            bestRating: 5
          },
          datePublished: review.date
        }))
      },
      // LocalBusiness for each sector
      serviceData.sector ? {
        '@type': 'LocalBusiness',
        '@id': `https://cita2.tecelia.com${serviceData.url}/#localbusiness`,
        name: `${serviceData.sector.name} - Cita2`,
        description: `Software de gestión para ${serviceData.sector.name.toLowerCase()}`,
        url: `https://cita2.tecelia.com${serviceData.url}`,
        image: serviceData.sector.image,
        priceRange: '€',
        paymentAccepted: ['Credit Card', 'Bank Transfer'],
        currenciesAccepted: 'EUR',
        openingHoursSpecification: {
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
          opens: '00:00',
          closes: '23:59'
        },
        isRelatedTo: { '@id': `https://cita2.tecelia.com${serviceData.url}/#service` }
      } : null
    ].filter(Boolean)
  };
}

// HowTo Schema for guides
function generateHowToSchema(howtoData: any) {
  return {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: howtoData.name,
    description: howtoData.description,
    image: howtoData.image,
    totalTime: howtoData.totalTime,
    supply: howtoData.supplies?.map((s: string) => ({ '@type': 'HowToSupply', name: s })),
    tool: howtoData.tools?.map((t: string) => ({ '@type': 'HowToTool', name: t })),
    step: howtoData.steps.map((step: any, index: number) => ({
      '@type': 'HowToStep',
      position: index + 1,
      name: step.name,
      text: step.text,
      image: step.image,
      url: `${howtoData.url}#step-${index + 1}`
    })),
    estimatedCost: howtoData.cost ? {
      '@type': 'MonetaryAmount',
      currency: 'EUR',
      value: howtoData.cost
    } : undefined
  };
}

// Article Schema for blog
function generateArticleSchema(articleData: any) {
  return {
    '@context': 'https://schema.org',
    '@graph': [
      organizationSchema,
      {
        '@type': 'Article',
        '@id': `https://cita2.tecelia.com/blog/${articleData.slug}/#article`,
        headline: articleData.title,
        description: articleData.description,
        image: articleData.image,
        datePublished: articleData.pubDate,
        dateModified: articleData.updatedDate || articleData.pubDate,
        author: {
          '@type': articleData.authorType || 'Organization',
          name: articleData.author,
          url: articleData.authorUrl || 'https://cita2.tecelia.com'
        },
        publisher: { '@id': 'https://cita2.tecelia.com/#organization' },
        mainEntityOfPage: {
          '@type': 'WebPage',
          '@id': `https://cita2.tecelia.com/blog/${articleData.slug}/`
        },
        wordCount: articleData.wordCount,
        articleSection: articleData.category,
        keywords: articleData.tags?.join(', '),
        about: articleData.sector ? {
          '@type': 'Thing',
          name: articleData.sector
        } : undefined
      }
    ]
  };
}

// FAQPage Schema with AI-optimized structure
function generateFAQSchema(faqs: any[]) {
  return {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
        author: {
          '@type': 'Organization',
          name: 'Cita2',
          '@id': 'https://cita2.tecelia.com/#organization'
        },
        datePublished: faq.date || new Date().toISOString(),
        upvoteCount: faq.upvotes || 0
      }
    }))
  };
}

// Generate schema based on type
let finalSchema;
switch (type) {
  case 'service':
    finalSchema = generateServiceSchema(data);
    break;
  case 'howto':
    finalSchema = generateHowToSchema(data);
    break;
  case 'article':
    finalSchema = generateArticleSchema(data);
    break;
  case 'review':
    finalSchema = generateServiceSchema(data); // Service with reviews
    break;
  default:
    finalSchema = organizationSchema;
}
---

<script type="application/ld+json" set:html={JSON.stringify(finalSchema, null, 0)} />
