---
// ProblemSolution — Sección Antes/Después con datos verificados por vertical
// Datos reales: TheFork 150-200€/mes + 1,5-2€/comensal | Booksy ~35€+20€/empleado | Bókun 49$/mes+1,5%

const verticals = [
  {
    id: "servicios",
    label: "Servicios",
    emoji: "✂️",
    problems: [
      { icon: "📱", title: "Llamadas sin parar", stat: "15+ llamadas/día", desc: "Reservas, cancelaciones y cambios de cita a cualquier hora interrumpen tu trabajo." },
      { icon: "❌", title: "No-shows que duelen", stat: "1 de cada 4 citas", desc: "Sin recordatorio automático, el 25% de tus clientes simplemente no aparecen." },
      { icon: "👥", title: "Precio por empleado", stat: "20€ extra/empleado", desc: "Booksy cobra ~35€ base + 20€ por cada empleado adicional. 3 empleados = 75€/mes." },
      { icon: "🚫", title: "Sin WhatsApp real", stat: "Solo email básico", desc: "Fresha, Booksy y similares no integran WhatsApp Business API. Tus mensajes no llegan." }
    ],
    solutions: [
      { icon: "🌙", benefit: "0 llamadas de reserva", highlight: "Reservas automáticas 24/7 — incluso a las 3am" },
      { icon: "🤖", benefit: "−70% ausencias", highlight: "WhatsApp + email + SMS automáticos antes de cada cita" },
      { icon: "∞", benefit: "Usuarios ilimitados", highlight: "1 precio fijo para todo tu equipo, sin sorpresas" },
      { icon: "💬", benefit: "WhatsApp real", highlight: "API Business oficial, tasa de apertura del 90%" }
    ],
    saving: "vs 75-135€/mes de Booksy para 3 empleados",
    ourPrice: "27€/mes"
  },
  {
    id: "restaurantes",
    label: "Restaurantes",
    emoji: "🍽️",
    problems: [
      { icon: "💸", title: "Cuota fija + comisión", stat: "150-200€/mes", desc: "TheFork Manager cuesta ~175€/mes solo en cuota, antes de añadir la comisión por comensal." },
      { icon: "📊", title: "Comisión por comensal", stat: "1,5-2€ por persona", desc: "Cada comensal captado por TheFork tiene un coste adicional que crece con tu éxito." },
      { icon: "🔒", title: "Clientes son de TheFork", stat: "Sin acceso a datos", desc: "Los comensales que llegan vía TheFork son de TheFork. No puedes contactarlos directamente." },
      { icon: "📈", title: "El éxito te cuesta más", stat: "Coste variable ∞", desc: "Cuanto más llenas el restaurante, más pagas en comisiones. El modelo no tiene límite." }
    ],
    solutions: [
      { icon: "🏷️", benefit: "0€ comisión", highlight: "Sin porcentaje por comensal. Nunca." },
      { icon: "📋", benefit: "24€/mes fijo", highlight: "El mismo precio si tienes 10 o 500 reservas al mes" },
      { icon: "👤", benefit: "Tus clientes", highlight: "CRM completo con todos sus datos, tuyo para siempre" },
      { icon: "💬", benefit: "+WhatsApp", highlight: "Recordatorios automáticos que ningún software de restaurantes ofrece" }
    ],
    saving: "vs 300-500€/mes real en TheFork (cuota + comisiones)",
    ourPrice: "24-32€/mes"
  },
  {
    id: "turismo",
    label: "Turismo",
    emoji: "🏔️",
    problems: [
      { icon: "💵", title: "Precio en dólares", stat: "49-499 USD/mes", desc: "Bókun (TripAdvisor) cobra en USD con fluctuación de tipo de cambio. Sin soporte en español." },
      { icon: "📉", title: "Comisión por reserva", stat: "+1,5% por reserva", desc: "Bókun cobra 1,5% sobre cada reserva online además de la cuota mensual." },
      { icon: "🌙", title: "Pierdes reservas de noche", stat: "60% consultas no atendidas", desc: "Cuando un turista visita tu web a las 11pm y tiene dudas, no hay nadie. Se va con la competencia." },
      { icon: "🌍", title: "Sin WhatsApp", stat: "Solo email", desc: "Ningún competidor de turismo integra WhatsApp para confirmaciones y recordatorios." }
    ],
    solutions: [
      { icon: "🎯", benefit: "29€/mes fijo", highlight: "En euros, sin fluctuación, sin comisión por reserva" },
      { icon: "📊", benefit: "0% comisión", highlight: "100 reservas o 1.000, el precio no cambia" },
      { icon: "🤖", benefit: "IA reserva 24/7", highlight: "El único software de turismo con asistente IA en tu web — reserva mientras duermes" },
      { icon: "💬", benefit: "WhatsApp nativo", highlight: "El único software de turismo en España con WA Business API" }
    ],
    saving: "vs 107€/mes real en Bókun (49$ cuota + 1,5% en 100 reservas de 50€)",
    ourPrice: "29-45€/mes"
  }
];
---

<section class="section-apple bg-white" id="soluciones">
  <div class="container-apple">

    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-12">
      <span class="feature-bubble mb-4 inline-block">El problema que resolvemos</span>
      <h2 class="text-headline text-gray-900 mb-6">
        Lo que pagas hoy <span class="text-gray-400">vs</span> lo que deberías pagar
      </h2>
      <p class="text-body text-lg">
        Hemos verificado los precios reales de los competidores líderes. Los números no engañan.
      </p>
    </div>

    <!-- Vertical Tabs -->
    <div class="flex justify-center gap-2 mb-12 flex-wrap" id="vertical-tabs">
      {verticals.map((v, i) => (
        <button
          id={`tab-${v.id}`}
          data-vertical={v.id}
          class={`vertical-tab px-5 py-2.5 rounded-full text-sm font-semibold transition-all border-2 ${
            i === 0
              ? 'bg-gray-900 text-white border-gray-900'
              : 'bg-white text-gray-600 border-gray-200 hover:border-gray-400'
          }`}
        >
          {v.emoji} {v.label}
        </button>
      ))}
    </div>

    <!-- Panels -->
    {verticals.map((v, vi) => (
      <div
        id={`panel-${v.id}`}
        class={`vertical-panel ${vi !== 0 ? 'hidden' : ''}`}
      >
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-12">

          <!-- BEFORE: Problems -->
          <div class="space-y-4">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center text-xl">😤</div>
              <div>
                <h3 class="font-bold text-gray-900">Sin Agenda de Reservas</h3>
                <p class="text-sm text-gray-500">Lo que está pasando ahora mismo</p>
              </div>
            </div>
            {v.problems.map((p) => (
              <div class="problem-card hover-lift scroll-animate">
                <div class="flex items-start gap-3">
                  <span class="text-2xl flex-shrink-0">{p.icon}</span>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-2 mb-1">
                      <h4 class="font-semibold text-gray-900 text-sm">{p.title}</h4>
                      <span class="text-xs font-bold text-red-600 bg-red-50 px-2 py-0.5 rounded-full whitespace-nowrap flex-shrink-0">{p.stat}</span>
                    </div>
                    <p class="text-gray-500 text-xs leading-relaxed">{p.desc}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <!-- AFTER: Solutions -->
          <div class="space-y-4">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center text-xl">😌</div>
              <div>
                <h3 class="font-bold text-gray-900">Con Agenda de Reservas</h3>
                <p class="text-sm text-gray-500">Desde {v.ourPrice} · Sin comisiones</p>
              </div>
            </div>
            {v.solutions.map((s, i) => (
              <div class="solution-card hover-lift scroll-animate" style={`transition-delay: ${i * 80}ms`}>
                <div class="flex items-center gap-3">
                  <span class="text-2xl flex-shrink-0">{s.icon}</span>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-2 mb-1">
                      <p class="text-xs text-green-700 font-bold">{s.highlight}</p>
                      <span class="text-xs font-bold text-green-700 bg-green-50 px-2 py-0.5 rounded-full whitespace-nowrap flex-shrink-0">{s.benefit}</span>
                    </div>
                  </div>
                </div>
              </div>
            ))}

            <!-- Savings callout -->
            <div class="mt-6 bg-gray-900 rounded-2xl p-5 text-white">
              <p class="text-xs text-gray-400 mb-1">Precio Agenda de Reservas</p>
              <p class="text-2xl font-extrabold text-green-400">{v.ourPrice}</p>
              <p class="text-xs text-gray-400 mt-1">{v.saving}</p>
              <a
                href="https://app.agendadereservas.com"
                class="mt-4 block text-center bg-white text-gray-900 font-semibold text-sm py-2.5 rounded-xl hover:bg-gray-100 transition-colors"
              >
                Empieza gratis 14 días →
              </a>
            </div>
          </div>
        </div>
      </div>
    ))}

    <!-- Stats Row -->
    <div class="mt-20 grid grid-cols-2 lg:grid-cols-4 gap-8">
      <div class="text-center scroll-animate delay-100">
        <p class="stat-number mb-2">500+</p>
        <p class="text-gray-600">negocios en España usando Agenda de Reservas</p>
      </div>
      <div class="text-center scroll-animate delay-200">
        <p class="stat-number mb-2">70%</p>
        <p class="text-gray-600">menos ausencias con recordatorio automático</p>
      </div>
      <div class="text-center scroll-animate delay-300">
        <p class="stat-number mb-2">10h</p>
        <p class="text-gray-600">ahorro semanal en gestión de reservas</p>
      </div>
      <div class="text-center scroll-animate delay-400">
        <p class="stat-number mb-2">0€</p>
        <p class="text-gray-600">comisión por reserva, para siempre</p>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-16">
      <a href="https://app.agendadereservas.com" class="btn-apple-primary text-lg px-10 py-5">
        Empieza gratis — 14 días sin tarjeta →
      </a>
      <p class="text-caption mt-4">Setup en 2 minutos · Cancela cuando quieras · Soporte en español</p>
    </div>
  </div>
</section>

<script>
  // Vertical tab switching
  document.querySelectorAll('.vertical-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.vertical!;
      document.querySelectorAll('.vertical-tab').forEach(t => {
        t.classList.remove('bg-gray-900', 'text-white', 'border-gray-900');
        t.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
      });
      btn.classList.add('bg-gray-900', 'text-white', 'border-gray-900');
      btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-200');
      document.querySelectorAll('.vertical-panel').forEach(p => p.classList.add('hidden'));
      document.getElementById(`panel-${id}`)?.classList.remove('hidden');
    });
  });

  // Scroll animation
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.scroll-animate').forEach(el => observer.observe(el));
</script>
