---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroV2 from '../components/HeroV2.astro';
import ProblemSolution from '../components/ProblemSolution.astro';
import FeatureShowcase from '../components/FeatureShowcase.astro';
import PricingV2 from '../components/PricingV2.astro';
import SocialProofV2 from '../components/SocialProofV2.astro';
import FAQ from '../components/FAQ.astro';
import AdvancedSEO from '../components/AdvancedSEO.astro';

// Import Apple Design System
import '../styles/apple-design.css';

import home from '../content/home.json';

// AI-Optimized Title & Meta
const title = home.pageTitle;
const description = home.pageDescription;

const features = [
  {
    icon: 'calendar',
    title: 'Reservas online 24/7',
    description: 'Sistema de reservas automatizado que permite a los clientes reservar citas en cualquier momento del día sin intervención del negocio. Tus clientes reservan cuando quieren, incluso a las 3 de la mañana. Tú despiertas con la agenda llena.',
  },
  {
    icon: 'bell',
    title: 'Recordatorios automáticos multicanal',
    description: 'Envío programado de notificaciones por email, SMS y WhatsApp Business para recordar citas programadas a los clientes. Reduce ausencias hasta un 80% sin que tú hagas nada.',
  },
  {
    icon: 'users',
    title: 'CRM completo de clientes',
    description: 'Base de datos centralizada con historial completo de cada cliente: citas, preferencias, cumpleaños y observaciones. Ofrece un trato personalizado que fideliza.',
  },
  {
    icon: 'credit',
    title: 'Pagos online seguros con Stripe',
    description: 'Integración con Stripe para procesar pagos, depósitos y bonos directamente desde la plataforma. Reduce no-shows y mejora el flujo de caja.',
  },
  {
    icon: 'message',
    title: 'WhatsApp Business API integrado',
    description: 'Conecta tu WhatsApp Business y envía confirmaciones, recordatorios y follow-ups automáticamente. Tasa de apertura del 90%.',
  },
  {
    icon: 'chart',
    title: 'Dashboard de estadísticas en tiempo real',
    description: 'Métricas de ocupación, ingresos, clientes nuevos y tasas de ausencia. Toma decisiones de negocio basadas en datos actualizados.',
  },
];

const testimonials = home.testimonials;

const pricingPlans = [
  {
    name: 'Profesional',
    price: '19€',
    period: '/mes',
    description: 'Todo lo que necesitas para gestionar tu negocio sin complicaciones.',
    features: [
      'Reservas online ilimitadas',
      'Recordatorios automáticos',
      'Calendario visual',
      'CRM clientes completo',
      'Página de reservas personalizada',
      'Pagos online con Stripe',
      'WhatsApp Business integrado',
      'Soporte por email y chat',
    ],
    cta: 'Empezar prueba gratis',
    ctaHref: 'https://app.agendadereservas.com',
    popular: true,
  },
];

const faqItems = home.faqs;

// Enhanced Schema for AI SEO - Rich structured data
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      '@id': 'https://agendadereservas.com/#software',
      name: 'Agenda de Reservas',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      softwareVersion: '2.0',
      offers: {
        '@type': 'Offer',
        price: '19',
        priceCurrency: 'EUR',
        priceValidUntil: '2026-12-31',
        availability: 'https://schema.org/InStock'
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.8',
        ratingCount: '523',
        bestRating: '5',
        worstRating: '1'
      },
      review: home.testimonials.map(t => ({
        '@type': 'Review',
        author: { '@type': 'Person', name: t.author },
        reviewBody: t.quote,
        reviewRating: { '@type': 'Rating', ratingValue: String(t.rating) },
        datePublished: '2026-01-01'
      })),
      description: home.aiDescription,
      featureList: 'Reservas online 24/7, Recordatorios automáticos por WhatsApp/Email/SMS, CRM de clientes, Pagos online con Stripe, WhatsApp Business integrado, Estadísticas y dashboard'
    },
    {
      '@type': 'WebSite',
      '@id': 'https://agendadereservas.com/#website',
      name: 'Agenda de Reservas',
      url: 'https://agendadereservas.com',
      potentialAction: {
        '@type': 'SearchAction',
        target: 'https://agendadereservas.com/search?q={search_term_string}',
        'query-input': 'required name=search_term_string'
      }
    },
    {
      '@type': 'Organization',
      '@id': 'https://agendadereservas.com/#organization',
      name: 'Agenda de Reservas',
      url: 'https://agendadereservas.com',
      logo: 'https://agendadereservas.com/favicon.svg',
      description: 'Software de gestión de citas y reservas para negocios de servicios',
      foundingDate: '2023',
      address: {
        '@type': 'PostalAddress',
        addressCountry: 'ES',
        addressLocality: 'Santiago de Compostela'
      },
      contactPoint: {
        '@type': 'ContactPoint',
        contactType: 'customer support',
        email: 'soporte@agendadereservas.com',
        availableLanguage: ['Spanish', 'English']
      },
      sameAs: [
        'https://twitter.com/agendadereservas',
        'https://linkedin.com/company/agendadereservas',
        'https://instagram.com/agendadereservas'
      ]
    }
  ]
};
---

<Layout title={title} description={description} schema={schema}>
  <AdvancedSEO type="service" data={{
    name: 'Agenda de Reservas - Software de Gestión de Citas',
    description: description,
    url: '/',
    rating: { value: 4.9, count: 523 }
  }} />
  
  <Header />
  
  <main>
    <!-- Hero V2: Apple Style -->
    <HeroV2 
      title={home.heroTitle}
      subtitle={home.heroSubtitle}
      ctaText={home.heroCta}
      ctaHref="https://app.agendadereservas.com"
      secondaryCta={{ text: "Ver cómo funciona", href: "#soluciones" }}
    />
    
    <!-- Problem/Solution: Before/After -->
    <ProblemSolution />
    
    <!-- Feature Showcase: Storytelling -->
    <FeatureShowcase />
    
    <!-- Social Proof V2: Stats & Testimonials -->
    <SocialProofV2 />
    
    <!-- Pricing V2: Clean & Clear -->
    <PricingV2 />
    
    <!-- FAQ: Optimized for conversion -->
    <FAQ
      title="¿Tienes dudas?"
      subtitle="Todo lo que necesitas saber. Si no encuentras tu respuesta, escríbenos."
      items={faqItems}
    />
    
    <!-- Final CTA: Apple Style -->
    <section class="section-apple bg-gradient-to-b from-gray-50 to-white">
      <div class="container-apple text-center">
        <h2 class="text-headline text-gray-900 mb-6">
          ¿Listo para transformar <span class="gradient-text">tu gestión diaria?</span>
        </h2>
        <p class="text-body text-xl max-w-2xl mx-auto mb-10">
          Únete a 500+ negocios que ya ahorran tiempo, reducen ausencias y ganan más con Agenda de Reservas.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
          <a href="https://app.agendadereservas.com" class="btn-apple-primary text-lg px-12 py-5">
            Empezar prueba gratuita
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/funcionalidades" class="btn-apple-secondary text-lg px-8 py-5">
            Ver todas las funciones
          </a>
        </div>
        
        <p class="text-sm text-gray-700">
          Setup en 2 minutos · Sin tarjeta · Cancela cuando quieras · Soporte en español
        </p>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<script>
  // Initialize scroll animations
  document.addEventListener('DOMContentLoaded', () => {
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, observerOptions);

    document.querySelectorAll('.scroll-animate').forEach(el => {
      observer.observe(el);
    });
  });
</script>
