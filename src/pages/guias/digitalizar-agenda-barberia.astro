---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = 'Cómo digitalizar la agenda de tu barbería en 2026';
const pageDescription = 'Guía paso a paso para gestionar las citas de tu barbería online: software, recordatorios WhatsApp, cobro de anticipo y cero llamadas perdidas.';
const canonicalUrl = 'https://agendadereservas.com/guias/digitalizar-agenda-barberia/';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Inicio',
          item: 'https://agendadereservas.com'
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Guías',
          item: 'https://agendadereservas.com/guias/'
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: 'Digitalizar agenda de barbería',
          item: canonicalUrl
        }
      ]
    },
    {
      '@type': 'HowTo',
      name: 'Cómo digitalizar la agenda de tu barbería paso a paso',
      description: 'Guía práctica para pasar de libreta o teléfono a un sistema de citas online con recordatorios automáticos y cobro de anticipo.',
      totalTime: 'PT30M',
      estimatedCost: {
        '@type': 'MonetaryAmount',
        currency: 'EUR',
        value: '19'
      },
      step: [
        {
          '@type': 'HowToStep',
          position: 1,
          name: 'Elige qué servicios y barberos incluir en tu agenda online',
          text: 'Define el catálogo de servicios (corte, barba, degradado, tratamientos) y asigna a cada barbero los servicios que ofrece con su duración y precio. Esto es la base de tu agenda digital.'
        },
        {
          '@type': 'HowToStep',
          position: 2,
          name: 'Activa los recordatorios automáticos para eliminar ausencias',
          text: 'Configura al menos dos recordatorios: uno por WhatsApp 24 horas antes y otro por SMS/email 2 horas antes. Las barberías que usan recordatorios automáticos reducen las ausencias entre un 60% y un 80%.'
        },
        {
          '@type': 'HowToStep',
          position: 3,
          name: 'Configura el cobro de anticipo para servicios largos',
          text: 'Activa la opción de anticipo (10-20% del precio) para degradados, tratamientos de barba y servicios de más de 45 minutos. Reduce drásticamente los no-shows en las franjas de mayor demanda.'
        },
        {
          '@type': 'HowToStep',
          position: 4,
          name: 'Conecta tu agenda con WhatsApp para que los clientes reserven sin llamar',
          text: 'Integra WhatsApp Business API para que los clientes puedan ver disponibilidad y confirmar su cita directamente desde el chat, sin necesidad de llamar ni instalar una app.'
        }
      ]
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: '¿Puede usar el software un barbero autónomo sin empleados?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Sí. El plan Profesional de 19€/mes está pensado para autónomos y pequeños negocios. Un único barbero puede gestionar toda su agenda, recordatorios y pagos sin necesidad de añadir empleados ni pagar más.'
          }
        },
        {
          '@type': 'Question',
          name: '¿Funciona en el móvil sin instalar una app?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Sí. Agenda de Reservas es una aplicación web que funciona desde cualquier navegador móvil, tanto para el barbero (gestión) como para el cliente (reserva). No hace falta descargar nada.'
          }
        },
        {
          '@type': 'Question',
          name: '¿Qué pasa si un cliente llama en lugar de reservar online?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Puedes introducir la reserva manualmente desde el panel en segundos. La agenda digital y las reservas telefónicas conviven sin problema: todo queda registrado en el mismo sistema.'
          }
        },
        {
          '@type': 'Question',
          name: '¿Cuánto tiempo tarda la configuración inicial?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'La configuración básica (servicios, horarios y primer barbero) se completa en menos de 30 minutos. Con la ayuda del equipo de soporte en español de Agenda de Reservas, la mayoría de barberías están operativas el mismo día.'
          }
        }
      ]
    }
  ]
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  schema={schema}
  aiDescription="Guía paso a paso para que barberías y barberos autónomos en España digitalicen su agenda de citas: elección de servicios, recordatorios automáticos por WhatsApp, cobro de anticipo y configuración en menos de 30 minutos con Agenda de Reservas (19€/mes, sin comisiones)."
>
  <Header />

  <main class="pt-24">

    <!-- Hero -->
    <section class="py-16 bg-gradient-to-br from-gray-900 to-gray-800 text-white">
      <div class="container mx-auto px-4 max-w-4xl">
        <!-- Breadcrumb -->
        <nav class="text-sm text-gray-400 mb-8" aria-label="Ruta de navegación">
          <ol class="flex flex-wrap items-center gap-1">
            <li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
            <li class="mx-1 text-gray-600">/</li>
            <li><a href="/guias" class="hover:text-white transition-colors">Guías</a></li>
            <li class="mx-1 text-gray-600">/</li>
            <li class="text-gray-300">Digitalizar agenda de barbería</li>
          </ol>
        </nav>

        <div class="flex flex-wrap items-center gap-3 mb-6">
          <span class="inline-block px-3 py-1 bg-blue-600/30 border border-blue-500/40 rounded-full text-xs text-blue-300 font-medium">
            Guía práctica
          </span>
          <span class="text-sm text-gray-400">Actualizado: junio 2026</span>
          <span class="text-sm text-gray-400">Lectura: 8 min</span>
        </div>

        <h1 class="text-3xl md:text-5xl font-bold mb-6 leading-tight">
          Cómo digitalizar la agenda<br class="hidden md:block" /> de tu barbería en 2026
        </h1>
        <p class="text-xl text-gray-300 mb-8 max-w-2xl leading-relaxed">
          De la libreta al software de citas en menos de 30 minutos. Sin complicaciones, sin llamadas perdidas y sin pagar comisión por cada reserva.
        </p>

        <div class="flex flex-wrap gap-6 text-sm text-gray-300">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            4 pasos concretos
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Tabla comparativa incluida
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Válido para autónomos y equipos
          </span>
        </div>
      </div>
    </section>

    <!-- Contenido principal -->
    <div class="container mx-auto px-4 max-w-4xl py-16">

      <!-- Sección 1: Por qué -->
      <section class="mb-16">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
          ¿Por qué las barberías necesitan agenda digital en 2026?
        </h2>
        <p class="text-lg text-gray-700 mb-4 leading-relaxed">
          Gestionar citas por teléfono o libreta cuesta tiempo que podrías dedicar a cortar. Cada llamada perdida es un cliente que reserva en otra barbería —o que directamente no reserva. Un sistema de citas online trabaja por ti las 24 horas, incluso cuando tienes las tijeras en la mano.
        </p>
        <p class="text-gray-700 mb-6 leading-relaxed">
          Los datos son claros: según estudios del sector de la belleza en Europa, entre el 15% y el 25% de las citas en barberías sin sistema de recordatorios acaban en ausencia (no-show). Con recordatorios automáticos, esa cifra cae por debajo del 5%. En una barbería que factura 3.000€ al mes, recuperar ese 15-20% de huecos vacíos equivale a entre 450€ y 600€ mensuales adicionales.
        </p>

        <div class="bg-blue-50 border-l-4 border-blue-600 rounded-r-xl p-5 mb-6">
          <p class="text-blue-900 font-medium">
            "Antes perdía entre 4 y 6 citas a la semana porque no podía coger el teléfono mientras estaba con un cliente. Ahora el 80% de mis reservas llegan solas por WhatsApp."
          </p>
          <p class="text-blue-700 text-sm mt-2">— Alejandro M., barbero autónomo, Sevilla (cliente de Agenda de Reservas)</p>
        </div>

        <p class="text-gray-700 leading-relaxed">
          La digitalización de la agenda no es una tendencia; es la forma en que trabajan ya la mayoría de barberías competitivas en España. El <a href="/peluquerias" class="text-blue-600 hover:underline font-medium">software para peluquerías y barberías</a> ha madurado lo suficiente para que la curva de aprendizaje sea mínima y el retorno, inmediato.
        </p>
      </section>

      <!-- Tabla comparativa -->
      <section class="mb-16">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
          Gestión manual vs software de citas para barbería
        </h2>
        <p class="text-gray-700 mb-6">
          La diferencia no es solo comodidad: es dinero, tiempo y datos sobre tu negocio que ahora mismo no tienes.
        </p>

        <div class="overflow-x-auto rounded-2xl border border-gray-200 shadow-sm">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="bg-gray-50 border-b border-gray-200">
                <th class="py-4 px-5 font-semibold text-gray-900 w-1/3">Aspecto</th>
                <th class="py-4 px-5 font-semibold text-gray-600 w-1/3">Teléfono / libreta</th>
                <th class="py-4 px-5 font-semibold text-blue-700 w-1/3">Agenda de Reservas</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-4 px-5 font-medium text-gray-900">Gestión de citas</td>
                <td class="py-4 px-5 text-gray-600">Manual, solo cuando contestas</td>
                <td class="py-4 px-5 text-blue-700 font-medium">Automática 24/7, sin intervención</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-4 px-5 font-medium text-gray-900">Recordatorios</td>
                <td class="py-4 px-5 text-gray-600">No existen o son manuales</td>
                <td class="py-4 px-5 text-blue-700 font-medium">Automáticos por WhatsApp y email</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-4 px-5 font-medium text-gray-900">Cobro de anticipo</td>
                <td class="py-4 px-5 text-gray-600">Imposible de gestionar online</td>
                <td class="py-4 px-5 text-blue-700 font-medium">Integrado en el flujo de reserva</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-4 px-5 font-medium text-gray-900">Historial del cliente</td>
                <td class="py-4 px-5 text-gray-600">En papel o en la memoria del barbero</td>
                <td class="py-4 px-5 text-blue-700 font-medium">Digital, buscable, con notas por servicio</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-4 px-5 font-medium text-gray-900">Estadísticas</td>
                <td class="py-4 px-5 text-gray-600">Ninguna</td>
                <td class="py-4 px-5 text-blue-700 font-medium">Servicios más populares, horas pico, ingresos</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-4 px-5 font-medium text-gray-900">Tasa de no-shows *</td>
                <td class="py-4 px-5 text-gray-600">15-25% (estimación sector)</td>
                <td class="py-4 px-5 text-blue-700 font-medium">&lt; 5% con recordatorios activos</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-4 px-5 font-medium text-gray-900">Coste mensual</td>
                <td class="py-4 px-5 text-gray-600">0€ + tiempo perdido</td>
                <td class="py-4 px-5 text-blue-700 font-medium">Desde 19€/mes, sin comisiones</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-xs text-gray-500 mt-3">
          * Estimación basada en datos del sector de belleza en Europa. Los resultados individuales varían según tipo de clientela y configuración del negocio.
        </p>
      </section>

      <!-- Checklist -->
      <section class="mb-16">
        <div class="bg-gray-900 rounded-2xl p-8 text-white">
          <h2 class="text-xl font-bold mb-6">8 pasos para digitalizar tu barbería</h2>
          <ul class="space-y-3">
            {[
              'Registrarte en Agenda de Reservas (prueba gratis 14 días, sin tarjeta)',
              'Crear tu catálogo de servicios con precio y duración',
              'Añadir a cada barbero con su disponibilidad horaria',
              'Activar recordatorios automáticos por WhatsApp y email',
              'Configurar el anticipo para servicios de más de 45 minutos',
              'Publicar el enlace de reserva en tu Instagram y Google Business',
              'Conectar WhatsApp Business para reservas desde el chat',
              'Revisar las estadísticas cada semana y ajustar horarios o servicios'
            ].map((step, i) => (
              <li class="flex items-start gap-3">
                <span class="flex-shrink-0 w-6 h-6 border-2 border-blue-400 rounded mt-0.5" aria-hidden="true"></span>
                <span class="text-gray-200 leading-snug">
                  <span class="text-blue-400 font-semibold mr-1">{i + 1}.</span>
                  {step}
                </span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Pasos how-to -->
      <section class="mb-16 space-y-14">

        <!-- Paso 1 -->
        <div>
          <div class="flex items-center gap-4 mb-5">
            <span class="flex-shrink-0 w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold text-lg">1</span>
            <h2 class="text-2xl font-bold text-gray-900">
              Elige qué servicios y barberos incluir en tu agenda online
            </h2>
          </div>
          <p class="text-gray-700 mb-4 leading-relaxed">
            El primer paso es trasladar tu catálogo al sistema. Define cada servicio con nombre, duración y precio. Después asigna a cada barbero los servicios que realiza: así el cliente solo puede reservar lo que ese barbero ofrece, en el hueco que tiene libre.
          </p>
          <p class="text-gray-700 mb-4 leading-relaxed">
            Algunos ejemplos de servicios habituales en barberías españolas:
          </p>
          <ul class="space-y-2 mb-4 ml-4">
            {[
              'Corte de cabello — 30 min',
              'Corte + barba — 45 min',
              'Degradado (fade) — 45-60 min',
              'Arreglo de barba — 20 min',
              'Tratamiento hidratante de barba — 30 min',
              'Coloración / mechas — 60-90 min'
            ].map(s => (
              <li class="flex items-center gap-2 text-gray-700">
                <svg class="w-4 h-4 text-blue-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                {s}
              </li>
            ))}
          </ul>
          <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm text-amber-900">
            <strong>Consejo:</strong> Si tienes varios barberos con especialidades distintas, configura un perfil por barbero. El cliente elegira quien le atiende y el sistema mostrara solo los huecos disponibles de esa persona.
          </div>
        </div>

        <!-- Paso 2 -->
        <div>
          <div class="flex items-center gap-4 mb-5">
            <span class="flex-shrink-0 w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold text-lg">2</span>
            <h2 class="text-2xl font-bold text-gray-900">
              Activa los recordatorios automáticos para eliminar ausencias
            </h2>
          </div>
          <p class="text-gray-700 mb-4 leading-relaxed">
            Los recordatorios son la funcionalidad con mayor impacto económico inmediato. Un mensaje automático por WhatsApp 24 horas antes de la cita reduce los no-shows entre un 60% y un 80%, según datos del sector. Combina dos momentos de envío: 24 horas antes y 2 horas antes.
          </p>
          <p class="text-gray-700 mb-4 leading-relaxed">
            El canal importa: WhatsApp tiene una tasa de apertura superior al 90% frente al 20-25% del email. Si el cliente tiene activo el <a href="/guias/reducir-ausencias" class="text-blue-600 hover:underline">sistema de recordatorios que describimos en nuestra guía completa para reducir ausencias en tu negocio</a>, el efecto se multiplica porque el cliente puede confirmar o cancelar con un solo mensaje, dando tiempo a rellenar el hueco.
          </p>
          <div class="grid sm:grid-cols-2 gap-4 mt-4">
            <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm">
              <h3 class="font-semibold text-gray-900 mb-2">Recordatorio 24 h antes</h3>
              <p class="text-sm text-gray-600">Permite al cliente confirmar o cancelar con antelación suficiente para que puedas ofrecer el hueco a otro.</p>
            </div>
            <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm">
              <h3 class="font-semibold text-gray-900 mb-2">Recordatorio 2 h antes</h3>
              <p class="text-sm text-gray-600">Captura los olvidos del dia. Un recordatorio a primera hora de la tarde tiene tasa de lectura muy alta en dispositivos moviles.</p>
            </div>
          </div>
        </div>

        <!-- Paso 3 -->
        <div>
          <div class="flex items-center gap-4 mb-5">
            <span class="flex-shrink-0 w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold text-lg">3</span>
            <h2 class="text-2xl font-bold text-gray-900">
              Configura el cobro de anticipo para servicios largos (degradados, tratamientos de barba)
            </h2>
          </div>
          <p class="text-gray-700 mb-4 leading-relaxed">
            Para servicios de más de 45 minutos —degradados, tratamientos, coloraciones— el anticipo es la herramienta mas efectiva contra los no-shows. Un cliente que ha pagado 5€ o 10€ por adelantado tiene un compromiso real con su cita.
          </p>
          <p class="text-gray-700 mb-4 leading-relaxed">
            La clave esta en la comunicacion: presentalo como una "reserva garantizada" en lugar de un "deposito". El cliente entiende que esta asegurando su hueco, especialmente en las horas de mayor demanda (tardes de jueves y viernes, sábados por la mañana).
          </p>
          <div class="bg-blue-50 border border-blue-200 rounded-xl p-5 text-sm">
            <h3 class="font-semibold text-blue-900 mb-2">Como configurarlo en Agenda de Reservas</h3>
            <ol class="space-y-2 text-blue-800 list-decimal ml-4">
              <li>Ve a Servicios y selecciona el servicio que quieres proteger con anticipo.</li>
              <li>Activa la opcion "Cobrar anticipo al reservar".</li>
              <li>Fija el importe: recomendamos entre el 20% y el 30% del precio del servicio.</li>
              <li>El cliente abona el anticipo al confirmar la reserva online con tarjeta.</li>
            </ol>
          </div>
        </div>

        <!-- Paso 4 -->
        <div>
          <div class="flex items-center gap-4 mb-5">
            <span class="flex-shrink-0 w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold text-lg">4</span>
            <h2 class="text-2xl font-bold text-gray-900">
              Conecta tu agenda con WhatsApp para que los clientes reserven sin llamar
            </h2>
          </div>
          <p class="text-gray-700 mb-4 leading-relaxed">
            WhatsApp es el canal de comunicacion dominante en España: el 85% de los adultos lo usa a diario (Statista, 2025). Conectar tu agenda a WhatsApp Business API permite que los clientes consulten disponibilidad y reserven sin salir del chat, sin instalar nada y sin que tu tengas que contestar manualmente.
          </p>
          <p class="text-gray-700 mb-4 leading-relaxed">
            El flujo es sencillo: el cliente escribe a tu numero de WhatsApp, el sistema le muestra los servicios disponibles, elige fecha y hora, y recibe la confirmacion automatica. Tu ves la nueva reserva en el panel en tiempo real.
          </p>
          <div class="bg-gray-50 rounded-xl border border-gray-200 p-5">
            <h3 class="font-semibold text-gray-900 mb-3">¿Que necesitas para activar WhatsApp Business API?</h3>
            <ul class="space-y-2 text-gray-700 text-sm">
              {[
                'Un numero de telefono dedicado a tu barberia (puede ser el mismo que ya usas)',
                'Verificar tu cuenta de empresa en Meta Business Manager',
                'Activar el add-on de WhatsApp Business API en Agenda de Reservas (+8€/mes)',
                'Configurar los mensajes automaticos de confirmacion y recordatorio'
              ].map(item => (
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-blue-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <!-- Seccion precio -->
      <section class="mb-16">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
          ¿Cuanto cuesta digitalizar la agenda de una barberia?
        </h2>
        <p class="text-gray-700 mb-6 leading-relaxed">
          El coste depende de las funcionalidades que necesites. Para la mayoria de barberías, el plan base es suficiente. Aqui tienes el desglose real, sin letra pequeña.
        </p>

        <div class="grid sm:grid-cols-3 gap-4 mb-6">
          <div class="bg-white border-2 border-blue-600 rounded-2xl p-6 shadow-sm">
            <p class="text-sm font-medium text-blue-600 mb-1">Plan Profesional</p>
            <p class="text-3xl font-bold text-gray-900 mb-1">19€<span class="text-base font-normal text-gray-500">/mes</span></p>
            <p class="text-xs text-gray-500 mb-4">Precio unico, sin comisiones</p>
            <ul class="space-y-2 text-sm text-gray-700">
              {[
                'Agenda online 24/7',
                'Multiples barberos',
                'Recordatorios email/SMS',
                'Historial de clientes',
                'Estadisticas basicas',
                'Soporte en español'
