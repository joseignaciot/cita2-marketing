---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = "Guías y Recursos";
const description = "Guías prácticas, comparativas y estrategias para gestionar mejor tu peluquería, restaurante o negocio de servicios. Recursos gratuitos de Agenda de Reservas.";

const guides = [
  {
    category: "Gestión de citas",
    items: [
      {
        href: "/guias/reducir-ausencias",
        title: "Cómo reducir ausencias hasta un 70%",
        description: "7 estrategias probadas para eliminar las citas perdidas: recordatorios automáticos, depósitos, listas de espera y más.",
        badge: "Descarga gratuita",
        badgeColor: "bg-green-100 text-green-700",
        icon: "📥",
      },
    ],
  },
  {
    category: "Comparativas de software",
    items: [
      {
        href: "/blog/mejores-software-gestion-citas-2026",
        title: "Mejores software de gestión de citas 2026",
        description: "Análisis completo de las principales plataformas del mercado: funciones, precios y para qué tipo de negocio encaja cada una.",
        badge: "Comparativa",
        badgeColor: "bg-blue-100 text-blue-700",
        icon: "📊",
      },
      {
        href: "/blog/software-agenda-estetica-comparativa",
        title: "Software de agenda para estética: comparativa 2026",
        description: "Comparamos Agenda de Reservas, AgendaPro, Treatwell y más para centros de estética y belleza.",
        badge: "Estética",
        badgeColor: "bg-purple-100 text-purple-700",
        icon: "💅",
      },
      {
        href: "/blog/mejor-software-peluquerias-2026",
        title: "Mejor software para peluquerías 2026",
        description: "Guía de compra con las funciones esenciales y precios reales para peluquerías y barberías.",
        badge: "Peluquerías",
        badgeColor: "bg-orange-100 text-orange-700",
        icon: "✂️",
      },
    ],
  },
  {
    category: "Restaurantes",
    items: [
      {
        href: "/blog/alternativa-eltenedor-sin-comisiones",
        title: "Alternativa a TheFork sin comisiones por reserva",
        description: "Por qué pagar comisión en cada cubierto cuando puedes tener tu propio sistema de reservas por una cuota fija.",
        badge: "Restaurantes",
        badgeColor: "bg-red-100 text-red-700",
        icon: "🍽️",
      },
      {
        href: "/blog/como-aumentar-reservas-restaurante",
        title: "Cómo aumentar las reservas de tu restaurante",
        description: "Estrategias probadas para atraer más comensales: reservas online 24/7, recordatorios y gestión de listas de espera.",
        badge: "Restaurantes",
        badgeColor: "bg-red-100 text-red-700",
        icon: "📈",
      },
    ],
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Guías y Recursos - Agenda de Reservas",
  "description": description,
  "itemListElement": guides.flatMap(g => g.items).map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.title,
    "url": `https://agendadereservas.com${item.href}`,
    "description": item.description,
  })),
};
---

<Layout title={`${title} - Agenda de Reservas`} description={description} schema={schema}>
  <Header />
  <main class="pt-24 pb-20">
    <div class="container mx-auto px-4 max-w-4xl">

      <nav class="mb-8 text-sm text-gray-500" aria-label="Breadcrumb">
        <a href="/" class="hover:text-blue-600">Inicio</a>
        <span class="mx-2">›</span>
        <span class="text-gray-700">{title}</span>
      </nav>

      <header class="mb-12 pb-8 border-b border-gray-200">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{title}</h1>
        <p class="text-lg text-gray-600 max-w-2xl">Recursos prácticos para reducir ausencias, elegir el mejor software y hacer crecer tu negocio de servicios.</p>
      </header>

      <div class="space-y-12">
        {guides.map(section => (
          <section>
            <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-5">{section.category}</h2>
            <div class="grid gap-4 sm:grid-cols-2">
              {section.items.map(item => (
                <a
                  href={item.href}
                  class="group flex flex-col gap-3 p-6 rounded-2xl border border-gray-200 hover:border-blue-300 hover:shadow-md transition-all bg-white"
                >
                  <div class="flex items-start justify-between gap-2">
                    <span class="text-2xl">{item.icon}</span>
                    <span class={`shrink-0 text-xs font-medium px-2.5 py-0.5 rounded-full ${item.badgeColor}`}>
                      {item.badge}
                    </span>
                  </div>
                  <h3 class="text-base font-semibold text-gray-900 group-hover:text-blue-600 transition-colors leading-snug">
                    {item.title}
                  </h3>
                  <p class="text-sm text-gray-500 leading-relaxed">{item.description}</p>
                  <span class="mt-auto text-sm font-medium text-blue-600 group-hover:underline">
                    Leer guía →
                  </span>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>

      <div class="mt-16 p-8 rounded-2xl bg-blue-50 border border-blue-100 text-center">
        <h2 class="text-xl font-bold text-gray-900 mb-2">¿Quieres ver el software en acción?</h2>
        <p class="text-gray-600 mb-6">Empieza gratis durante 14 días, sin tarjeta de crédito.</p>
        <a href="/#precios" class="inline-block px-6 py-3 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-700 transition-colors">
          Probar gratis 14 días
        </a>
      </div>

    </div>
  </main>
  <Footer />
</Layout>
