---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = 'Guía Gratis: Cómo Reducir Ausencias en tu Negocio';
const pageDescription = 'Descarga gratis nuestra guía con 7 estrategias probadas para reducir las citas perdidas hasta un 70%. PDF gratuito, sin spam.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'DigitalDocument',
  name: 'Guía: Cómo Reducir Ausencias en tu Negocio',
  description: '7 estrategias probadas para reducir citas perdidas hasta un 70%'
};
---

<Layout title={pageTitle} description={pageDescription} schema={schema}>
  <Header />
  
  <main class="pt-24">
    <!-- Hero -->
    <section class="py-16 bg-gradient-to-br from-blue-600 to-blue-800 text-white">
      <div class="container mx-auto px-4 max-w-4xl text-center">
        <span class="inline-block px-4 py-1 bg-white/20 rounded-full text-sm mb-4">
          📥 Descarga Gratuita
        </span>
        <h1 class="text-3xl md:text-5xl font-bold mb-6">
          7 estrategias para reducir ausencias hasta un 70%
        </h1>
        <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
          Guía práctica con tácticas que usan los negocios más exitosos para minimizar citas perdidas y maximizar ingresos.
        </p>
        
        <div class="flex flex-wrap justify-center gap-6 text-sm">
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            PDF de 15 páginas
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Sin spam, garantizado
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            500+ descargas
          </span>
        </div>
      </div>
    </section>

    <!-- Form Section -->
    <section class="py-16">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <!-- What's inside -->
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6">¿Qué incluye la guía?</h2>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <span class="w-8 h-8 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0">1</span>
                <div>
                  <h3 class="font-semibold text-gray-900">El problema real de las ausencias</h3>
                  <p class="text-sm text-gray-600">Por qué los clientes no vienen y cómo identificarlo</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-8 h-8 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0">2</span>
                <div>
                  <h3 class="font-semibold text-gray-900">Recordatorios que funcionan</h3>
                  <p class="text-sm text-gray-600">Qué decir, cuándo enviarlo, por qué canal</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-8 h-8 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0">3</span>
                <div>
                  <h3 class="font-semibold text-gray-900">Depósitos sin perder clientes</h3>
                  <p class="text-sm text-gray-600">Cómo pedir señal sin que el cliente se vaya</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-8 h-8 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0">4</span>
                <div>
                  <h3 class="font-semibold text-gray-900">Lista de espera inteligente</h3>
                  <p class="text-sm text-gray-600">Convierte cancelaciones en ingresos</p>
                </div>
              </li>
            </ul>
          </div>
          
          <!-- Form -->
          <div class="bg-white rounded-2xl shadow-xl p-8 border border-gray-100">
            <h3 class="text-xl font-bold text-gray-900 mb-2">Descarga tu guía gratis</h3>
            <p class="text-gray-600 text-sm mb-6">Te enviamos el PDF inmediatamente por email.</p>
            
            <form class="space-y-4" action="https://agendadereservas.com/api/lead-magnet" method="POST">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Nombre</label>
                <input 
                  type="text" 
                  name="name" 
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                  placeholder="Tu nombre"
                />
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input 
                  type="email" 
                  name="email" 
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                  placeholder="tu@email.com"
                />
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de negocio</label>
                <select name="business_type" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                  <option value="">Selecciona...</option>
                  <option value="peluqueria">Peluquería</option>
                  <option value="estetica">Estética / Spa</option>
                  <option value="dentista">Dentista</option>
                  <option value="fisioterapia">Fisioterapia</option>
                  <option value="restaurante">Restaurante</option>
                  <option value="turismo">Turismo / Actividades</option>
                  <option value="otro">Otro</option>
                </select>
              </div>
              
              <button type="submit" class="btn-primary w-full">
                Descargar guía gratis →
              </button>
            </form>
            
            <p class="text-xs text-gray-400 mt-4 text-center">
              Respetamos tu privacidad. Sin spam, solo contenido útil.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4 max-w-2xl text-center">
        <blockquote class="text-xl text-gray-700 italic mb-6">
          "Apliqué solo 2 de las estrategias de esta guía y reduje las ausencias de un 25% a un 8%. Mi peluquería factura 400€ más al mes."
        </blockquote>
        <div class="flex items-center justify-center gap-3">
          <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 font-bold">
            M
          </div>
          <div class="text-left">
            <p class="font-semibold text-gray-900">María G.</p>
            <p class="text-sm text-gray-700">Peluquería María, Madrid</p>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
