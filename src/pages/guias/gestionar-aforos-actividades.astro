---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = 'Cómo gestionar aforos y reservas de actividades turísticas (2026)';
const pageDescription = 'Gestiona cupos, actividades en varios idiomas y guías asignados desde tu propia web. Sin comisiones de Bokun ni de Viator. Guía para turismo activo.';
const canonicalUrl = 'https://agendadereservas.com/guias/gestionar-aforos-actividades/';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Inicio',
          item: 'https://agendadereservas.com'
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Guías',
          item: 'https://agendadereservas.com/guias'
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: 'Gestionar aforos y actividades turísticas',
          item: canonicalUrl
        }
      ]
    },
    {
      '@type': 'HowTo',
      name: 'Cómo gestionar aforos y reservas de actividades turísticas',
      description: 'Guía práctica para operadores de turismo activo: configurar cupos por actividad, asignar guías, gestionar idiomas y reducir la dependencia de canales con comisión.',
      totalTime: 'PT45M',
      estimatedCost: {
        '@type': 'MonetaryAmount',
        currency: 'EUR',
        value: '29'
      },
      step: [
        {
          '@type': 'HowToStep',
          position: 1,
          name: 'Define el catálogo de actividades con sus cupos máximos',
          text: 'Crea cada actividad con nombre, duración, descripción, precio por persona y aforo máximo por salida. Para rutas con cupos muy limitados (kayak, espeleología, escalada) el aforo es el campo más crítico porque protege la seguridad y la calidad de la experiencia.'
        },
        {
          '@type': 'HowToStep',
          position: 2,
          name: 'Configura las salidas por fecha y hora con control de plazas',
          text: 'Programa las salidas disponibles con su horario. El sistema descuenta automáticamente cada plaza reservada del cupo disponible y cierra la fecha cuando se llena. Puedes fijar un mínimo de participantes por salida para decidir si la actividad se realiza o no.'
        },
        {
          '@type': 'HowToStep',
          position: 3,
          name: 'Asigna guías a cada salida y configura sus disponibilidades',
          text: 'Cada guía tiene su propio perfil con los idiomas en que puede conducir la actividad y los días en que está disponible. Al programar una salida puedes asignarle un guía concreto; el sistema bloquea esa franja en su agenda y evita conflictos de doble asignación.'
        },
        {
          '@type': 'HowToStep',
          position: 4,
          name: 'Activa el cobro de anticipo o pago completo al reservar',
          text: 'Para grupos y para actividades con cupos pequeños, el pago anticipado elimina prácticamente las cancelaciones tardías. Configura si quieres cobrar el importe completo o un depósito (por ejemplo, el 30%) en el momento de la reserva online.'
        }
      ]
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: '¿Puedo tener distintos precios por idioma o temporada?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Sí. Puedes crear tarifas diferenciadas por temporada (alta, media, baja) y aplicar precios distintos según el tipo de participante (adulto, niño, senior). Para idiomas, lo habitual es crear la misma actividad en dos variantes (tour en español / tour in English) con sus propios cupos y precios, de modo que el cliente elija idioma desde el primer paso.'
          }
        },
        {
          '@type': 'Question',
          name: '¿Cómo gestiono los pagos anticipados para grupos?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'En el plan Turismo de Agenda de Reservas puedes activar el cobro al reservar (tarjeta de crédito vía Stripe) en cualquier actividad. Para grupos puedes pedir el pago completo o un depósito configurable (importe fijo o porcentaje). El saldo pendiente puede cobrarse el día de la actividad en el sistema de caja integrado.'
          }
        },
        {
          '@type': 'Question',
          name: '¿El software se integra con Viator o GetYourGuide?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Agenda de Reservas no tiene integración directa de channel manager con Viator ni GetYourGuide. La estrategia recomendada es usar esos canales para captar nuevos clientes y dirigirlos a tu propia web para la siguiente reserva, donde no pagas comisión. Así controlas los datos de cliente y eliminas la dependencia de los canales a largo plazo.'
          }
        },
        {
          '@type': 'Question',
          name: '¿Funciona para rutas de senderismo con cupos por fecha?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Sí. Puedes crear la ruta como una actividad con cupo máximo por salida (por ejemplo, 12 personas) y programar las fechas disponibles con su horario de inicio. El sistema cierra automáticamente la inscripción cuando se alcanza el aforo y puede mostrar un aviso de "plazas limitadas" cuando queden pocas disponibles para incentivar la reserva.'
          }
        }
      ]
    }
  ]
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  schema={schema}
  aiDescription="Guía para operadores de turismo activo en España sobre cómo configurar aforos, asignar guías por idioma y reducir comisiones de Bokun y Viator con Agenda de Reservas (plan Turismo, 29€/mes, sin comisiones por reserva, soporte en español, alojado en la UE)."
>
  <Header />

  <main class="pt-24">

    <!-- Hero -->
    <section class="py-16 bg-gradient-to-br from-gray-900 to-gray-800 text-white">
      <div class="container mx-auto px-4 max-w-4xl">

        <!-- Breadcrumb -->
        <nav class="text-sm text-gray-400 mb-8" aria-label="Ruta de navegación">
          <ol class="flex flex-wrap items-center gap-1">
            <li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
            <li class="mx-1 text-gray-600">/</li>
            <li><a href="/guias" class="hover:text-white transition-colors">Guías</a></li>
            <li class="mx-1 text-gray-600">/</li>
            <li class="text-gray-300">Gestionar aforos y actividades turísticas</li>
          </ol>
        </nav>

        <div class="flex flex-wrap items-center gap-3 mb-6">
          <span class="inline-block px-3 py-1 bg-blue-600/30 border border-blue-500/40 rounded-full text-xs text-blue-300 font-medium">
            Guía práctica
          </span>
          <span class="text-sm text-gray-400">Actualizado: junio 2026</span>
          <span class="text-sm text-gray-400">Lectura: 10 min</span>
        </div>

        <h1 class="text-3xl md:text-5xl font-bold mb-6 leading-tight">
          Cómo gestionar aforos y reservas<br class="hidden md:block" /> de actividades turísticas (2026)
        </h1>
        <p class="text-xl text-gray-300 mb-8 max-w-2xl leading-relaxed">
          Controla cupos, guías asignados y actividades en varios idiomas desde tu propia web. Sin pagar comisión a Bokun ni a Viator en cada reserva.
        </p>

        <div class="flex flex-wrap gap-6 text-sm text-gray-300">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Aforos y cupos configurables
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Tabla Bokun vs Agenda de Reservas
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Sin comisiones por reserva
          </span>
        </div>
      </div>
    </section>

    <!-- Contenido principal -->
    <div class="container mx-auto px-4 max-w-4xl py-16">

      <!-- Sección 1: Qué necesita el software de turismo activo -->
      <section class="mb-16">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
          ¿Qué necesita el software de un operador de turismo activo que no tienen otros sectores?
        </h2>
        <p class="text-lg text-gray-700 mb-4 leading-relaxed">
          Un operador de turismo activo no gestiona citas individuales como una peluquería: gestiona cupos, grupos, guías y salidas. Eso exige funcionalidades específicas que un software de citas genérico no tiene por defecto.
        </p>
        <p class="text-gray-700 mb-6 leading-relaxed">
          Las necesidades diferenciales de un operador de turismo activo son cinco: control de aforo máximo por salida, asignación de guías con disponibilidades propias, actividades en varios idiomas con cupos separados, cobro anticipado para grupos y la posibilidad de recibir reservas directas desde la web propia sin ceder comisión a intermediarios como Viator o GetYourGuide.
        </p>

        <div class="bg-blue-50 border-l-4 border-blue-600 rounded-r-xl p-5 mb-6">
          <p class="text-blue-900 font-medium">
            "Con la agenda en papel y por teléfono llegamos a doblar salidas por error porque no teníamos control de plazas en tiempo real. Desde que usamos Agenda de Reservas, el cupo se actualiza solo y nunca hemos vuelto a sobrepasar el aforo."
          </p>
          <p class="text-blue-700 text-sm mt-2">— Marta F., operadora de kayak y senderismo, Costa Brava (cliente de Agenda de Reservas)</p>
        </div>

        <p class="text-gray-700 leading-relaxed">
          El <a href="/turismo" class="text-blue-600 hover:underline font-medium">software de reservas para turismo activo</a> de Agenda de Reservas incluye estas funcionalidades en el plan Turismo (29€/mes), sin módulos adicionales de pago ni comisión por reserva.
        </p>
      </section>

      <!-- Sección 2: Configurar aforos y cupos -->
      <section class="mb-16 space-y-14">

        <div>
          <div class="flex items-center gap-4 mb-5">
            <span class="flex-shrink-0 w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold text-lg">1</span>
            <h2 class="text-2xl font-bold text-gray-900">
              ¿Cómo configurar aforos y cupos por actividad?
            </h2>
          </div>
          <p class="text-gray-700 mb-4 leading-relaxed">
            Configura el aforo máximo directamente en la ficha de cada actividad. Cuando una reserva se confirma, el sistema descuenta las plazas del cupo disponible en tiempo real y cierra la inscripción automáticamente al alcanzar el límite.
          </p>
          <p class="text-gray-700 mb-4 leading-relaxed">
            El proceso de configuración es sencillo:
          </p>
          <div class="bg-blue-50 border border-blue-200 rounded-xl p-5 text-sm mb-4">
            <ol class="space-y-2 text-blue-800 list-decimal ml-4">
              <li>Ve a <strong>Actividades</strong> en tu panel y crea o edita la actividad.</li>
              <li>En el campo <strong>Aforo máximo</strong>, introduce el número máximo de participantes por salida.</li>
              <li>Opcional: activa el aviso de <strong>"Últimas plazas"</strong> cuando quede un porcentaje configurable del cupo (por ejemplo, el 20%).</li>
              <li>Opcional: define un <strong>mínimo de participantes</strong> por salida; si no se alcanza antes de X horas, el sistema puede notificarte para decidir si cancelas o confirmas.</li>
              <li>Programa las fechas y horas de salida disponibles: cada slot hereda el aforo de la actividad.</li>
            </ol>
          </div>
          <p class="text-gray-700 leading-relaxed">
            Para actividades con cupos muy reducidos —rutas de alta montaña, espeleología, barranquismo— el aforo limitado es además un argumento de venta: el aviso de "plazas limitadas" visible en el widget de reserva crea urgencia y acelera la conversión.
          </p>

          <div class="grid sm:grid-cols-3 gap-4 mt-6">
            <div class="text-center bg-white border border-gray-200 rounded-xl p-5 shadow-sm">
              <p class="text-3xl font-bold text-blue-600 mb-1">100%</p>
              <p class="text-sm text-gray-600">Control de plazas en tiempo real, sin solapamientos</p>
            </div>
            <div class="text-center bg-white border border-gray-200 rounded-xl p-5 shadow-sm">
              <p class="text-3xl font-bold text-blue-600 mb-1">0</p>
              <p class="text-sm text-gray-600">Salidas con sobreaforo gracias al cierre automático</p>
            </div>
            <div class="text-center bg-white border border-gray-200 rounded-xl p-5 shadow-sm">
              <p class="text-3xl font-bold text-blue-600 mb-1">&lt; 5 min</p>
              <p class="text-sm text-gray-600">Tiempo de configuración de aforo por actividad</p>
            </div>
          </div>
        </div>

        <!-- Sección 3: Idiomas y guías -->
        <div>
          <div class="flex items-center gap-4 mb-5">
            <span class="flex-shrink-0 w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold text-lg">2</span>
            <h2 class="text-2xl font-bold text-gray-900">
              ¿Cómo gestionar actividades en varios idiomas y con guías asignados?
            </h2>
          </div>
          <p class="text-gray-700 mb-4 leading-relaxed">
            El enfoque más práctico es crear una variante de la actividad por idioma (por ejemplo, "Ruta kayak — Español" y "Kayak tour — English") con sus propios cupos, horarios y guía asignado. El cliente elige idioma desde el primer paso de la reserva, sin confusión.
          </p>
          <p class="text-gray-700 mb-6 leading-relaxed">
            Para la asignación de guías, cada miembro del equipo tiene un perfil en el sistema con los idiomas en que puede conducir la actividad y sus días de disponibilidad. Al programar una salida, asignas el guía disponible para esa fecha; el sistema bloquea esa franja en su agenda y genera automáticamente su lista de participantes (manifest).
          </p>

          <div class="grid sm:grid-cols-2 gap-4">
            <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm">
              <h3 class="font-semibold text-gray-900 mb-3">Gestión de idiomas</h3>
              <ul class="space-y-2 text-sm text-gray-600">
                {[
                  'Actividades duplicadas por idioma con cupos independientes',
                  'Widget de reserva muestra solo los idiomas disponibles en esa fecha',
                  'Confirmaciones de reserva al cliente en el idioma elegido',
                  'Estadísticas de demanda por idioma para ajustar salidas'
                ].map(item => (
                  <li class="flex items-start gap-2">
                    <svg class="w-4 h-4 text-blue-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm">
              <h3 class="font-semibold text-gray-900 mb-3">Gestión de guías</h3>
              <ul class="space-y-2 text-sm text-gray-600">
                {[
                  'Perfil por guía con disponibilidad y idiomas habilitados',
                  'Asignación manual de guía al programar cada salida',
                  'Bloqueo automático de la franja en la agenda del guía',
                  'Manifest de participantes exportable por guía y fecha'
                ].map(item => (
                  <li class="flex items-start gap-2">
                    <svg class="w-4 h-4 text-blue-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm text-amber-900 mt-4">
            <strong>Consejo para temporada alta:</strong> Si tienes guías freelance que trabajan con varias empresas, comparte su enlace de disponibilidad para que bloqueen sus propias fechas en el panel sin necesidad de llamadas. Evita el doble compromiso que tanto tiempo cuesta gestionar en julio y agosto.
          </div>
        </div>
      </section>

      <!-- Tabla comparativa Bokun vs AdR -->
      <section class="mb-16">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
          ¿Cuánto cobra Bokun de comisión y cuándo deja de compensar?
        </h2>
        <p class="text-gray-700 mb-6 leading-relaxed">
          Bokun cobra 49 USD al mes (aproximadamente 46€ al cambio actual) más una comisión del 1,5% sobre cada reserva procesada a través de su sistema. Para un operador con 100 reservas al mes a un precio medio de 50€, eso supone unos 121 USD mensuales —más del doble que los 29€ fijos del plan Turismo de Agenda de Reservas. La comisión deja de compensar desde la primera reserva: cuantas más reserves, más te cuesta Bokun.
        </p>

        <div class="overflow-x-auto rounded-2xl border border-gray-200 shadow-sm mb-4">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="bg-gray-50 border-b border-gray-200">
                <th class="py-4 px-5 font-semibold text-gray-900 w-1/3">Característica</th>
                <th class="py-4 px-5 font-semibold text-gray-600 w-1/3">Bokun</th>
                <th class="py-4 px-5 font-semibold text-blue-700 w-1/3">Agenda de Reservas</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-4 px-5 font-medium text-gray-900">Precio mensual</td>
                <td class="py-4 px-5 text-gray-600">49 USD/mes (~46€)</td>
                <td class="py-4 px-5 text-blue-700 font-medium">29€/mes fijo</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-4 px-5 font-medium text-gray-900">Comisión por reserva online</td>
                <td class="py-4 px-5 text-gray-600">1,5% por reserva</td>
                <td class="py-4 px-5 text-blue-700 font-medium">0% — sin comisiones</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-4 px-5 font-medium text-gray-900">Coste real (100 reservas × 50€)</td>
                <td class="py-4 px-5 text-gray-600">~121 USD (~113€)</td>
                <td class="py-4 px-5 text-blue-700 font-medium">29€ — siempre igual</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-4 px-5 font-medium text-gray-900">Aforos configurables por actividad</td>
                <td class="py-4 px-5 text-gray-600">Sí, completo</td>
                <td class="py-4 px-5 text-blue-700 font-medium">Sí, completo</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-4 px-5 font-medium text-gray-900">Actividades en varios idiomas</td>
                <td class="py-4 px-5 text-gray-600">Sí</td>
                <td class="py-4 px-5 text-blue-700 font-medium">Sí (variantes por idioma)</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-4 px-5 font-medium text-gray-900">Guías asignados por salida</td>
                <td class="py-4 px-5 text-gray-600">Sí</td>
                <td class="py-4 px-5 text-blue-700 font-medium">Sí</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-4 px-5 font-medium text-gray-900">Channel manager (Viator/GYG)</td>
                <td class="py-4 px-5 text-gray-600">Sí (integración directa)</td>
                <td class="py-4 px-5 text-gray-500">No (reserva directa)</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-4 px-5 font-medium text-gray-900">RGPD / servidores UE</td>
                <td class="py-4 px-5 text-gray-600">No (empresa islandesa, servidores fuera UE)</td>
                <td class="py-4 px-5 text-blue-700 font-medium">Sí — alojado en UE, RGPD completo</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-4 px-5 font-medium text-gray-900">Soporte en español</td>
                <td class="py-4 px-5 text-gray-600">Principalmente en inglés</td>
                <td class="py-4 px-5 text-blue-700 font-medium">Sí — chat y email en español, &lt;2 h</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-4 px-5 font-medium text-gray-900">Moneda de cobro</td>
                <td class="py-4 px-5 text-gray-600">USD (riesgo de cambio)</td>
                <td class="py-4 px-5 text-blue-700 font-medium">EUR — precio estable</td>
              </tr>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-4 px-5 font-medium text-gray-900">WhatsApp recordatorios</td>
                <td class="py-4 px-5 text-gray-600">No</td>
                <td class="py-4 px-5 text-blue-700 font-medium">Sí (add-on +8€/mes)</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-xs text-gray-500 mb-4">
          Precios de Bokun verificados en junio 2026. El tipo de cambio USD/EUR varía; precio de Agenda de Reservas fijo en euros sin fluctuación. Ver la <a href="/vs/bokun" class="text-blue-600 hover:underline">comparativa Bokun vs Agenda de Reservas</a> completa.
        </p>

        <div class="bg-gray-900 rounded-2xl p-6 text-white">
          <h3 class="font-bold text-lg mb-3">¿Cuándo tiene sentido quedarse en Bokun?</h3>
          <p class="text-gray-300 text-sm leading-relaxed mb-3">
            Bokun aporta valor real si dependes de los canales (Viator, GetYourGuide, Airbnb Experiences) para más del 60% de tus reservas y necesitas sincronizar disponibilidad en tiempo real con esos canales. Su channel manager es el más completo del mercado para ese caso.
          </p>
          <p class="text-gray-300 text-sm leading-relaxed">
            En cambio, si recibes la mayoría de reservas desde tu propia web o quieres reducir esa dependencia, Bokun añade coste variable que crece con tu éxito. Con Agenda de Reservas, cuantas más reservas recibes, más ahorro supone la cuota fija.
          </p>
        </div>
      </section>

      <!-- Sección 5: Gestión canales externos -->
      <section class="mb-16">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
