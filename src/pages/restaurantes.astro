---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroV2 from '../components/HeroV2.astro';
import Features from '../components/Features.astro';
import Testimonials from '../components/Testimonials.astro';
import PricingV2 from '../components/PricingV2.astro';
import DynamicPricing from '../components/DynamicPricing.astro';
import FAQ from '../components/FAQ.astro';
import '../styles/apple-design.css';

// Contenido editable desde el CMS → public/admin → Páginas de Sector → Restaurantes
import content from '../content/sectors/restaurantes.json';
const { pageTitle, pageDescription, heroTitle, heroSubtitle, features: restaurantFeatures, testimonials: restaurantTestimonials, faqs: restaurantFAQs } = content;

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: 'Agenda de Reservas - Software para Restaurantes',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      offers: {
        '@type': 'Offer',
        price: '24',
        priceCurrency: 'EUR',
        priceValidUntil: '2026-12-31'
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.9',
        reviewCount: '220'
      }
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: '¿Realmente ahorro dinero vs ElTenedor?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Sí. ElTenedor cobra 12-15% por reserva. Si facturas 10.000€/mes en reservas online, pagas 1.200-1.500€ de comisión. Con Agenda de Reservas pagas 24€ fijos. Ahorro mensual: hasta 1.476€.'
          }
        },
        {
          '@type': 'Question',
          name: '¿Puedo gestionar turnos de comida y cena?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Sí, configuras horarios específicos para cada turno con duración y cubiertos máximos independientes.'
          }
        },
        {
          '@type': 'Question',
          name: '¿Cómo funciona la lista de espera?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Cuando estás lleno, el cliente se apunta a lista de espera. Si hay cancelación, el sistema notifica automáticamente por email/WhatsApp al primero de la lista.'
          }
        },
        {
          '@type': 'Question',
          name: '¿Se pueden pedir depósitos al reservar?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Sí, es opcional y configurable por tamaño de grupo o día de la semana. El pago se procesa mediante Stripe de forma segura.'
          }
        }
      ]
    }
  ]
};
---

<Layout 
  title={pageTitle}
  description={pageDescription}
  schema={schema}
>
  <Header />
  
  <main>
    <HeroV2
      title={heroTitle}
      subtitle={heroSubtitle}
      ctaText="Prueba gratis 14 días"
      ctaHref="https://app.agendadereservas.com"
      secondaryCta={{ text: 'Ver comparativa real', href: '#comparativa' }}
    />

    <Features 
      title="¿Qué conseguirás con Agenda de Reservas?"
      subtitle="Funcionalidades diseñadas específicamente para restaurantes."
      features={restaurantFeatures}
    />

    <!-- Comparativa real verificada -->
    <section id="comparativa" class="section-apple bg-gray-50">
      <div class="container-apple">
        <div class="text-center mb-12">
          <span class="feature-bubble mb-4 inline-block">Comparativa verificada</span>
          <h2 class="text-headline text-gray-900 mb-4">El coste real de gestionar reservas en tu restaurante</h2>
          <p class="text-body">Datos contrastados en webs oficiales. Actualizado abril 2026.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">

          <!-- TheFork -->
          <div class="bg-white rounded-2xl border-2 border-red-200 p-6">
            <div class="flex items-center gap-2 mb-4">
              <span class="text-2xl">🍴</span>
              <div>
                <h3 class="font-bold text-red-600">TheFork Manager</h3>
                <p class="text-xs text-gray-400">ElTenedor en España</p>
              </div>
            </div>
            <div class="space-y-3 text-sm mb-4">
              <div class="flex justify-between">
                <span class="text-gray-500">Cuota mensual</span>
                <span class="font-semibold text-red-600">~<span data-competitor-key="thefork.monthly_fee">175</span>€/mes</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Comisión por comensal</span>
                <span class="font-semibold text-red-600"><span data-competitor-key="thefork.commission_value">1,75</span>€/persona</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500"><span data-competitor-key="thefork.example_covers">200</span> comensales captados</span>
                <span class="font-semibold text-red-600">+<span data-competitor-total="thefork">350</span>€ extra (estimado)</span>
              </div>
              <div class="border-t pt-3 flex justify-between">
                <span class="font-bold">Total estimado/mes</span>
                <span class="font-extrabold text-red-600 text-lg">~<span data-competitor-total="thefork">475</span>€</span>
              </div>
            </div>
            <ul class="text-xs text-gray-400 space-y-1">
              <li>❌ Sin WhatsApp</li>
              <li>❌ Datos de clientes son de TheFork</li>
              <li>❌ Cuota crece con éxito del negocio</li>
            </ul>
            <p class="text-xs text-gray-300 mt-3">
              Fuente: <a data-competitor-source-url="thefork" href="https://www.thefork.es" target="_blank" class="underline hover:text-white"><span data-competitor-source="thefork">thefork.es · verificado</span></a>
              · <span data-competitor-date="thefork">2026-04</span>
            </p>
          </div>

          <!-- Restoo -->
          <div class="bg-white rounded-2xl border-2 border-orange-200 p-6">
            <div class="flex items-center gap-2 mb-4">
              <span class="text-2xl">📋</span>
              <div>
                <h3 class="font-bold text-orange-600">Restoo</h3>
                <p class="text-xs text-gray-400">Competidor español directo</p>
              </div>
            </div>
            <div class="space-y-3 text-sm mb-4">
              <div class="flex justify-between">
                <span class="text-gray-500">Plan Mini</span>
                <span class="font-semibold"><span data-competitor-key="restoo.monthly_fee">39</span>€/mes</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Comisión por reserva</span>
                <span class="font-semibold text-green-600">0%</span>
              </div>
              <div class="border-t pt-3 flex justify-between">
                <span class="font-bold">Desde</span>
                <span class="font-extrabold text-orange-600 text-lg"><span data-competitor-key="restoo.monthly_fee">39</span>€/mes</span>
              </div>
            </div>
            <ul class="text-xs text-gray-400 space-y-1">
              <li>❌ Sin WhatsApp</li>
              <li>❌ Sin turismo ni servicios</li>
              <li>✓ Empresa española</li>
            </ul>
            <p class="text-xs text-gray-300 mt-3">
              Fuente: <a data-competitor-source-url="restoo" href="https://www.restoo.es/precios" target="_blank" class="underline hover:text-white"><span data-competitor-source="restoo">restoo.es · verificado</span></a>
              · <span data-competitor-date="restoo">2026-04</span>
            </p>
          </div>

          <!-- Agenda de Reservas -->
          <div class="bg-white rounded-2xl border-2 border-green-400 p-6 shadow-lg relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-green-500 text-white text-xs font-bold px-3 py-1 rounded-full">
              Mejor precio ✓
            </div>
            <div class="flex items-center gap-2 mb-4">
              <span class="text-2xl">🗓️</span>
              <div>
                <h3 class="font-bold text-green-600">Agenda de Reservas</h3>
                <p class="text-xs text-gray-400">Plan Restaurante</p>
              </div>
            </div>
            <div class="space-y-3 text-sm mb-4">
              <div class="flex justify-between">
                <span class="text-gray-500">Cuota mensual</span>
                <span class="font-semibold text-green-600"><span data-price-key="restaurant.monthly">24</span>€/mes</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Comisión por comensal</span>
                <span class="font-semibold text-green-600">0€ — nunca</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">WhatsApp Business</span>
                <span class="font-semibold">+<span data-price-key="addon_communications.monthly">8</span>€/mes</span>
              </div>
              <div class="border-t pt-3 flex justify-between">
                <span class="font-bold">Total completo</span>
                <span class="font-extrabold text-green-600 text-lg"><span data-price-calc="restaurant.monthly+addon_communications.monthly">32</span>€/mes</span>
              </div>
            </div>
            <ul class="text-xs text-gray-600 space-y-1">
              <li>✅ WhatsApp Business API nativo</li>
              <li>✅ CRM — tus datos, siempre</li>
              <li>✅ Turismo y servicios en un plan</li>
            </ul>
          </div>
        </div>

        <div class="text-center mt-10">
          <p class="text-xl font-bold text-gray-900">
            Ahorro vs TheFork: <span class="text-green-600">hasta <span data-price-saving-annual="restaurant.monthly+addon_communications.monthly:475">5.316</span>€/año</span>
          </p>
          <p class="text-sm text-gray-500 mt-1">(475€ TheFork - <span data-price-calc="restaurant.monthly+addon_communications.monthly">32</span>€) × 12 meses</p>
        </div>
      </div>
    </section>

    <Testimonials 
      title="Lo que dicen los restaurantes"
      subtitle="Más de 200 restaurantes ya gestionan sus reservas con Agenda de Reservas."
      testimonials={restaurantTestimonials}
    />

    <PricingV2 />

    <FAQ 
      title="Preguntas frecuentes para restaurantes"
      subtitle="Respuestas a las dudas más comunes del sector restauración."
      faqs={restaurantFAQs}
    />

    <section class="section-apple bg-gray-900">
      <div class="container-apple text-center">
        <h2 class="text-headline text-white mb-4">Deja de pagar comisiones.<br/><span class="text-green-400">Empieza hoy por <span data-price-key="restaurant.monthly">24</span>€/mes.</span></h2>
        <p class="text-gray-400 mb-8">Únete a 200+ restaurantes que ya gestionan sus reservas sin TheFork.</p>
        <a href="https://app.agendadereservas.com" class="inline-block bg-white text-gray-900 font-bold px-10 py-4 rounded-2xl hover:bg-gray-100 transition-colors">
          Prueba gratis 14 días — sin tarjeta
        </a>
      </div>
    </section>
  </main>
  
  <Footer />
  <DynamicPricing />
</Layout>

