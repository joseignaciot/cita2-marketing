---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection('posts');
const relatedPosts = allPosts
  .filter(p => p.id !== post.id && p.data.category === post.data.category)
  .slice(0, 2);
---

<Layout 
  title={`${post.data.title} - Cita2 Blog`}
  description={post.data.description}
  ogImage={post.data.image || "/og-blog.jpg"}
>
  <Header />
  
  <main class="pt-24">
    <!-- Article Header -->
    <article class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="py-12">
        <!-- Breadcrumbs -->
        <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6">
          <a href="/blog" class="hover:text-blue-600">Blog</a>
          <span>/</span>
          <span class="text-gray-900">{post.data.category}</span>
        </nav>

        <!-- Meta -->
        <div class="flex items-center gap-4 mb-6">
          <span class="px-3 py-1 bg-blue-50 text-blue-600 rounded-full text-sm font-medium">
            {post.data.category.charAt(0).toUpperCase() + post.data.category.slice(1)}
          </span>
          <span class="text-gray-500 text-sm">
            {post.data.readingTime} min de lectura
          </span>
        </div>

        <!-- Title -->
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-6 leading-tight">
          {post.data.title}
        </h1>

        <!-- Author & Date -->
        <div class="flex items-center gap-4 mb-8 pb-8 border-b border-gray-200">
          <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 font-bold">
            {post.data.author.charAt(0)}
          </div>
          <div>
            <p class="font-medium text-gray-900">{post.data.author}</p>
            <p class="text-sm text-gray-500">
              Publicado el {post.data.pubDate.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}
              {post.data.updatedDate && (
                <span> · Actualizado el {post.data.updatedDate.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
              )}
            </p>
          </div>
        </div>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2 mb-8">
          {post.data.tags.map(tag => (
            <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-sm">
              #{tag}
            </span>
          ))}
        </div>

        <!-- Content -->
        <div class="prose prose-lg max-w-none prose-headings:text-gray-900 prose-p:text-gray-600 prose-a:text-blue-600 prose-strong:text-gray-900 prose-li:text-gray-600">
          <Content />
        </div>

        <!-- Share -->
        <div class="mt-12 pt-8 border-t border-gray-200">
          <p class="text-sm font-medium text-gray-900 mb-4">Compartir artículo:</p>
          <div class="flex gap-3">
            <a 
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(`https://cita2.tecelia.com/blog/${post.id}`)}`}
              target="_blank"
              rel="noopener"
              class="px-4 py-2 bg-gray-100 rounded-lg text-sm hover:bg-gray-200 transition-colors"
            >
              Twitter
            </a>
            <a 
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://cita2.tecelia.com/blog/${post.id}`)}`}
              target="_blank"
              rel="noopener"
              class="px-4 py-2 bg-gray-100 rounded-lg text-sm hover:bg-gray-200 transition-colors"
            >
              LinkedIn
            </a>
            <a 
              href={`https://wa.me/?text=${encodeURIComponent(post.data.title + ' ' + `https://cita2.tecelia.com/blog/${post.id}`)}`}
              target="_blank"
              rel="noopener"
              class="px-4 py-2 bg-gray-100 rounded-lg text-sm hover:bg-gray-200 transition-colors"
            >
              WhatsApp
            </a>
          </div>
        </div>
      </div>
    </article>

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <section class="py-12 bg-gray-50">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Artículos relacionados</h2>
          <div class="grid md:grid-cols-2 gap-6">
            {relatedPosts.map(related => (
              <a 
                href={`/blog/${related.id}`}
                class="block bg-white p-6 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow"
              >
                <span class="text-xs text-blue-600 font-medium">{related.data.category}</span>
                <h3 class="font-semibold text-gray-900 mt-2 mb-2">{related.data.title}</h3>
                <p class="text-sm text-gray-600 line-clamp-2">{related.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="py-16 bg-blue-600">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
          ¿Listo para implementar lo que has aprendido?
        </h2>
        <p class="text-blue-100 mb-8 max-w-xl mx-auto">
          Prueba Cita2 gratis durante 14 días. Setup en 2 minutos, sin tarjeta de crédito.
        </p>
        <a 
          href="https://cita2.tecelia.com/register"
          class="inline-block px-8 py-4 bg-white text-blue-600 rounded-lg font-semibold hover:bg-gray-100 transition-colors"
        >
          Empezar prueba gratuita
        </a>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
