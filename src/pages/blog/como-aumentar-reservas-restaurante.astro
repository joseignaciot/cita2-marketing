---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdvancedSEO from '../../components/AdvancedSEO.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const pageTitle = 'Cómo Aumentar Reservas en Restaurante: 8 Estrategias Comprobadas';
const pageDescription = 'Guía práctica para aumentar reservas en tu restaurante sin depender de ElTenedor. Estrategias de marketing digital, fidelización y optimización que funcionan en 2026.';

const breadcrumbItems = [
  { name: 'Inicio', url: 'https://agendadereservas.com/' },
  { name: 'Blog', url: 'https://agendadereservas.com/blog' },
  { name: 'Aumentar Reservas', url: 'https://agendadereservas.com/blog/como-aumentar-reservas-restaurante' }
];

const articleData = {
  title: pageTitle,
  description: pageDescription,
  slug: 'como-aumentar-reservas-restaurante',
  pubDate: '2026-03-24',
  updatedDate: '2026-03-24',
  author: 'Carlos Martínez',
  authorType: 'Person',
  category: 'Restaurantes',
  tags: ['aumentar reservas', 'restaurante', 'marketing', 'fidelización', 'ElTenedor'],
  wordCount: 3500,
  sector: 'Restauración'
};

const strategies = [
  {
    number: '01',
    title: 'Sistema de reservas directas en tu web',
    description: 'El 70% de los clientes visitan tu web antes de reservar. Si no tienen botón de reserva ahí, se van a ElTenedor o a la competencia.',
    action: 'Implementa un widget de reservas visible en tu homepage, móvil-optimizado, que confirme al instante.',
    impact: '+35% reservas directas',
    time: '1 día'
  },
  {
    number: '02',
    title: 'Google Business: tu escaparate digital',
    description: 'El 46% de búsquedas de restaurantes son "restaurantes cerca de mí". Aparecer en Google Maps con botón de reserva directa es crítico.',
    action: 'Optimiza tu perfil con fotos profesionales, menú actualizado, y enlace de reservas destacado.',
    impact: '+28% visibilidad',
    time: '2 horas'
  },
  {
    number: '03',
    title: 'Fidelización con datos propios',
    description: 'ElTenedor nunca te da los emails de tus clientes. Con reservas directas, construyes tu base de datos para marketing.',
    action: 'Pide email al reservar, segmenta por frecuencia de visita, y envía ofertas personalizadas.',
    impact: '+40% clientes recurrentes',
    time: 'Ongoing'
  },
  {
    number: '04',
    title: 'Incentivo por reserva directa',
    description: 'Dale a los clientes una razón para reservar contigo directamente en vez de por intermediarios.',
    action: 'Ofrece 10% descuento, postre gratis, o copa de bienvenida solo para reservas web/directa.',
    impact: '+25% migración a directas',
    time: 'Inmediato'
  },
  {
    number: '05',
    title: 'Redes sociales con conversión',
    description: 'Instagram y Facebook son escaparates, pero deben convertir en reservas, no solo likes.',
    action: 'Añade botón "Reservar" en Instagram Bio, Stories con link directo, y posts que inciten a la acción.',
    impact: '+20% reservas desde social',
    time: '1 semana'
  },
  {
    number: '06',
    title: 'Gestión de mesas inteligente',
    description: 'Optimiza tu aforo. Una mesa de 4 no debe estar ocupada por 2 personas cuando hay espera.',
    action: 'Usa software que sugiera reubicaciones, gestione turnos, y minimice tiempos vacíos entre reservas.',
    impact: '+15% cobertura',
    time: '1 día'
  },
  {
    number: '07',
    title: 'Recordatorios que reducen no-shows',
    description: 'El 15-20% de reservas online son no-shows. WhatsApp 2h antes reduce esto drásticamente.',
    action: 'Automatiza recordatorios por WhatsApp con confirmación de un clic.',
    impact: '-70% no-shows',
    time: '1 día'
  },
  {
    number: '08',
    title: 'Email marketing para ocasiones especiales',
    description: 'Cumpleaños, aniversarios, San Valentín... momentos donde el cliente planea con antelación.',
    action: 'Envía promos especiales 2 semanas antes de fechas clave. Ofrece menú especial o experiencia única.',
    impact: '+30% reservas en fechas clave',
    time: 'Automático'
  }
];

const metrics = [
  { before: '35%', after: '70%', metric: 'Reservas directas', period: '3 meses' },
  { before: '25%', after: '8%', metric: 'Tasa de no-shows', period: '1 mes' },
  { before: '150', after: '380', metric: 'Reservas mensuales', period: '6 meses' }
];

const faqs = [
  {
    question: '¿Cómo reducir dependencia de ElTenedor?',
    answer: 'Implementa reservas directas en tu web y Google Business, ofrece incentivos por reservar directo (10% descuento), y comunica a clientes habituales el cambio. En 3 meses puedes pasar de 100% dependencia a 70% reservas directas.'
  },
  {
    question: '¿Qué hacer con mesas vacías por no-shows?',
    answer: 'Implementa recordatorios WhatsApp 2h antes (reduce 70% no-shows), mantén lista de espera para cubrir cancelaciones de última hora, y para clientes problemáticos, requiere tarjeta de crédito para reservar.'
  },
  {
    question: '¿Cuánto cuesta marketing digital para restaurantes?',
    answer: 'Con Agenda de Reservas (19€/mes) tienes sistema de reservas + herramientas de fidelización. Google Business es gratis. Email marketing con tu base de datos es gratuito. Vs ElTenedor (~500€/mes), ahorras 5.700€/año que puedes invertir en SEO local y ads específicos.'
  },
  {
    question: '¿Cómo fidelizar clientes de restaurante?',
    answer: 'Con reservas directas obtienes sus emails. Segmenta por frecuencia (primerizos vs habituales), envía ofertas de cumpleaños, crea programa de puntos, y personaliza la experiencia recordando preferencias (mesa favorita, alergias, celebraciones pasadas).'
  }
];
---

<Layout title={pageTitle} description={pageDescription}>
  <AdvancedSEO type="article" data={articleData} />
  <Header />
  
  <main class="pt-24">
    <div class="container-apple">
      <Breadcrumb items={breadcrumbItems} />
      
      <article class="max-w-4xl mx-auto">
        <header class="text-center mb-16">
          <span class="feature-bubble mb-4 inline-block">Restaurantes</span>
          <h1 class="text-headline text-gray-900 mb-6">
            Cómo Aumentar Reservas en Restaurante
          </h1>
          <p class="text-body text-xl max-w-3xl mx-auto">
            8 estrategias comprobadas para aumentar reservas directas y reducir dependencia de ElTenedor. Guía práctica basada en casos reales de restaurantes que han duplicado sus reservas.
          </p>
        </header>

        {/* Impact Box */}
        <div class="bg-green-50 rounded-2xl p-8 mb-16">
          <h2 class="text-xl font-bold text-green-900 mb-6 text-center">Resultados reales en 6 meses</h2>
          <div class="grid md:grid-cols-3 gap-6">
            {metrics.map((m) => (
              <div class="text-center">
                <p class="text-sm text-gray-700 mb-1">{m.metric}</p>
                <div class="flex items-center justify-center gap-2 mb-2">
                  <span class="text-2xl font-bold text-red-500">{m.before}</span>
                  <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                  </svg>
                  <span class="text-3xl font-bold text-green-600">{m.after}</span>
                </div>
                <p class="text-xs text-green-700">En {m.period}</p>
              </div>
            ))}
          </div>
        </div>

        {/* Strategies */}
        <div class="space-y-12 mb-16">
          <h2 class="text-title text-gray-900 text-center">8 estrategias para más reservas</h2>
          
          {strategies.map((strategy, index) => (
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
              <div class="p-8">
                <div class="flex items-start gap-6">
                  <div class="flex-shrink-0">
                    <span class="text-5xl font-bold text-gray-200">{strategy.number}</span>
                  </div>
                  <div class="flex-1">
                    <h3 class="text-xl font-bold text-gray-900 mb-3">{strategy.title}</h3>
                    <p class="text-gray-600 mb-4">{strategy.description}</p>
                    
                    <div class="bg-blue-50 rounded-xl p-4 mb-4">
                      <p class="text-blue-900 font-medium mb-1">✓ Acción concreta:</p>
                      <p class="text-blue-800 text-sm">{strategy.action}</p>
                    </div>
                    
                    <div class="flex items-center gap-4 text-sm">
                      <span class="inline-flex items-center gap-1 text-green-700 bg-green-100 px-3 py-1 rounded-full">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                        </svg>
                        {strategy.impact}
                      </span>
                      <span class="text-gray-700">⏱️ {strategy.time}</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>

        {/* Quick Wins Section */}
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl p-8 mb-16">
          <h2 class="text-title text-gray-900 mb-8 text-center">Quick Wins: Acciones de hoy para resultados mañana</h2>
          <div class="grid md:grid-cols-2 gap-6">
            <div class="bg-white rounded-xl p-6 shadow-sm">
              <h3 class="font-semibold text-gray-900 mb-3 flex items-center gap-2">
                <span class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-sm font-bold">1</span>
                Activa botón de reserva en Google Business
              </h3>
              <p class="text-gray-600 text-sm mb-3">Ve a tu perfil de Google Business → Reservas → Configura enlace directo. Es gratis y toma 5 minutos.</p>
              <span class="text-xs text-green-600 font-medium">Impacto inmediato</span>
            </div>
            <div class="bg-white rounded-xl p-6 shadow-sm">
              <h3 class="font-semibold text-gray-900 mb-3 flex items-center gap-2">
                <span class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-sm font-bold">2</span>
                Añade botón "Reservar" en Instagram
              </h3>
              <p class="text-gray-600 text-sm mb-3">Instagram → Editar perfil → Botones de acción → Reservar. Vincula tu sistema de reservas.</p>
              <span class="text-xs text-green-600 font-medium">+20% reservas desde IG</span>
            </div>
            <div class="bg-white rounded-xl p-6 shadow-sm">
              <h3 class="font-semibold text-gray-900 mb-3 flex items-center gap-2">
                <span class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-sm font-bold">3</span>
                Ofrece 10% descuento por reserva web
              </h3>
              <p class="text-gray-600 text-sm mb-3">Cartel en mesas: "Reserva directa en nuestra web y obtén 10% descuento". Aún así ganas vs comisión ElTenedor.</p>
              <span class="text-xs text-green-600 font-medium">Migra clientes habituales</span>
            </div>
            <div class="bg-white rounded-xl p-6 shadow-sm">
              <h3 class="font-semibold text-gray-900 mb-3 flex items-center gap-2">
                <span class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-sm font-bold">4</span>
                Configura recordatorios automáticos
              </h3>
              <p class="text-gray-600 text-sm mb-3">WhatsApp 2h antes: "Hola [nombre], te recordamos tu reserva hoy a las [hora]. Confirma aquí: [link]"</p>
              <span class="text-xs text-green-600 font-medium">-70% no-shows</span>
            </div>
          </div>
        </div>

        {/* ROI Calculator hint */}
        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 mb-16">
          <h2 class="text-xl font-bold text-gray-900 mb-4">Calcula tu ahorro potencial</h2>
          <div class="grid md:grid-cols-3 gap-6 text-center">
            <div>
              <p class="text-sm text-gray-700 mb-1">Si usas ElTenedor</p>
              <p class="text-3xl font-bold text-red-600">~500€/mes</p>
              <p class="text-xs text-gray-400">100 reservas × 35€ × 15%</p>
            </div>
            <div>
              <p class="text-sm text-gray-700 mb-1">Con sistema propio</p>
              <p class="text-3xl font-bold text-green-600">19€/mes</p>
              <p class="text-xs text-gray-400">Agenda de Reservas plan único</p>
            </div>
            <div class="bg-green-50 rounded-xl p-4">
              <p class="text-sm text-green-700 mb-1">Ahorro anual</p>
              <p class="text-4xl font-bold text-green-700">5.772€</p>
              <p class="text-xs text-green-600">Para invertir en marketing</p>
            </div>
          </div>
        </div>

        {/* FAQs */}
        <div class="mb-16">
          <h2 class="text-title text-gray-900 mb-8 text-center">Preguntas frecuentes</h2>
          <div class="space-y-4">
            {faqs.map((faq) => (
              <details class="bg-white rounded-xl shadow-sm border border-gray-100 group">
                <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-gray-50 transition-colors">
                  <h3 class="font-semibold text-gray-900 pr-4">{faq.question}</h3>
                  <span class="flex-shrink-0">
                    <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </span>
                </summary>
                <div class="px-6 pb-6 text-gray-600">
                  <p>{faq.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </div>

        {/* Final CTA */}
        <div class="bg-gradient-to-br from-blue-600 to-indigo-700 rounded-2xl p-12 text-center text-white">
          <h2 class="text-2xl font-bold mb-4">Empieza a aumentar tus reservas hoy</h2>
          <p class="text-blue-100 mb-8 max-w-2xl mx-auto">
            Sistema de reservas directas con todas las herramientas de marketing integradas. 14 días gratis para probar.
          </p>
          <a href="https://app.agendadereservas.com" class="inline-flex items-center gap-2 px-8 py-4 bg-white text-blue-600 rounded-full font-semibold hover:bg-blue-50 transition-colors text-lg">
            Crear cuenta gratuita
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <p class="text-sm text-blue-200 mt-4">Setup en 2 minutos · Sin tarjeta · Sin comisiones</p>
        </div>
      </article>
    </div>
  </main>
  
  <Footer />
</Layout>
