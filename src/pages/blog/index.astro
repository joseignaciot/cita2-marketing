---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const publishedPosts = posts.filter(p => !p.data.draft).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPost = publishedPosts.find(p => p.data.featured);
const regularPosts = publishedPosts.filter(p => p !== featuredPost);

const categories = [...new Set(posts.map(p => p.data.category))];
---

<Layout 
  title="Blog - Agenda de Reservas | Recursos para Negocios de Servicios"
  description="Artículos, guías y recursos para gestionar tu peluquería, restaurante o negocio de servicios más eficientemente."
  ogImage="/og-blog.jpg"
>
  <Header />
  
  <main>
    <!-- Hero Blog -->
    <section class="pt-32 pb-16 bg-gradient-to-br from-blue-50 to-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto">
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
            Blog de Agenda de Reservas
          </h1>
          <p class="text-xl text-gray-600">
            Recursos, guías y estrategias para que tu negocio de servicios crezca.
          </p>
        </div>
      </div>
    </section>

    <!-- Categories -->
    <section class="py-8 border-b border-gray-200">
      <div class="container mx-auto px-4">
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="#todos" class="px-4 py-2 bg-blue-600 text-white rounded-full text-sm font-medium hover:bg-blue-700 transition-colors">
            Todos
          </a>
          {categories.map(category => (
            <a 
              href={`#${category}`} 
              class="px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition-colors"
            >
              {category.charAt(0).toUpperCase() + category.slice(1)}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Featured Post -->
    {featuredPost && (
      <section class="py-12">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-100">
            <div class="grid md:grid-cols-2 gap-0">
              <div class="bg-gradient-to-br from-blue-500 to-blue-600 p-8 md:p-12 flex items-center">
                <div>
                  <span class="inline-block px-3 py-1 bg-white/20 text-white rounded-full text-sm font-medium mb-4">
                    Destacado
                  </span>
                  <span class="inline-block px-3 py-1 bg-white/10 text-white rounded-full text-sm ml-2">
                    {featuredPost.data.category}
                  </span>
                  <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
                    {featuredPost.data.title}
                  </h2>
                  <p class="text-blue-100 mb-6">
                    {featuredPost.data.description}
                  </p>
                  <a 
                    href={`/blog/${featuredPost.id}`}
                    class="inline-flex items-center text-white font-medium hover:underline"
                  >
                    Leer artículo
                    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                  </a>
                </div>
              </div>
              <div class="p-8 md:p-12 flex flex-col justify-center">
                <div class="flex items-center gap-4 mb-4 text-sm text-gray-700">
                  <span>{featuredPost.data.author}</span>
                  <span>•</span>
                  <span>{featuredPost.data.pubDate.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
                  <span>•</span>
                  <span>{featuredPost.data.readingTime} min lectura</span>
                </div>
                <div class="flex flex-wrap gap-2">
                  {featuredPost.data.tags.map(tag => (
                    <span class="px-2 py-1 bg-gray-100 text-gray-600 rounded text-xs">
                      #{tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- All Posts -->
    <section class="py-12">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-8">Todos los artículos</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {regularPosts.map(post => (
            <article class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
              <div class="p-6">
                <div class="flex items-center gap-2 mb-3">
                  <span class="px-2 py-1 bg-blue-50 text-blue-600 rounded text-xs font-medium">
                    {post.data.category}
                  </span>
                  <span class="text-xs text-gray-700">{post.data.readingTime} min</span>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2 line-clamp-2">
                  <a href={`/blog/${post.id}`} class="hover:text-blue-600 transition-colors">
                    {post.data.title}
                  </a>
                </h3>
                <p class="text-gray-600 text-sm mb-4 line-clamp-3">
                  {post.data.description}
                </p>
                <div class="flex items-center justify-between">
                  <span class="text-xs text-gray-700">
                    {post.data.pubDate.toLocaleDateString('es-ES', { day: 'numeric', month: 'short' })}
                  </span>
                  <span class="text-xs text-gray-400">{post.data.author}</span>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Newsletter CTA -->
    <section class="py-16 bg-blue-600">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
          Recibe los mejores artículos en tu email
        </h2>
        <p class="text-blue-100 mb-8 max-w-xl mx-auto">
          Una vez a la semana, consejos prácticos para hacer crecer tu negocio de servicios.
        </p>
        <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input 
            type="email" 
            placeholder="tu@email.com"
            class="flex-1 px-4 py-3 rounded-lg text-gray-900 focus:outline-none focus:ring-2 focus:ring-white"
          />
          <button 
            type="submit"
            class="px-6 py-3 bg-gray-900 text-white rounded-lg font-medium hover:bg-gray-800 transition-colors"
          >
            Suscribirme
          </button>
        </form>
        <p class="text-blue-200 text-sm mt-4">
          Sin spam. Puedes darte de baja cuando quieras.
        </p>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
