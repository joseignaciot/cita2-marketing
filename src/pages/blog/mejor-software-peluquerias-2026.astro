---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdvancedSEO from '../../components/AdvancedSEO.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const pageTitle = 'Mejor Software para Peluquerías 2026: Gestión de Citas + Comparativa';
const pageDescription = 'Análisis completo del mejor software de gestión para peluquerías. Comparamos precios, funciones y valoraciones de Agenda de Reservas, AgendaPro, Phorest y más. Guía definitiva 2026.';

const breadcrumbItems = [
  { name: 'Inicio', url: 'https://agendadereservas.com/' },
  { name: 'Blog', url: 'https://agendadereservas.com/blog' },
  { name: 'Software Peluquería', url: 'https://agendadereservas.com/blog/mejor-software-peluquerias-2026' }
];

const articleData = {
  title: pageTitle,
  description: pageDescription,
  slug: 'mejor-software-peluquerias-2026',
  pubDate: '2026-03-25',
  updatedDate: '2026-03-25',
  author: 'María García',
  authorType: 'Person',
  category: 'Peluquerías',
  tags: ['software peluquería', 'agenda peluquería', 'gestión citas', 'comparativa', 'peluqueros'],
  wordCount: 3100,
  sector: 'Peluquería'
};

const comparison = [
  {
    feature: 'Precio (3 peluqueros)',
    cita2: { value: '19€/mes', highlight: true },
    agendapro: { value: '147€/mes', highlight: false },
    phorest: { value: '120€/mes', highlight: false },
    reservio: { value: '63€/mes', highlight: false }
  },
  {
    feature: 'Reservas online',
    cita2: { value: '✓', highlight: true },
    agendapro: { value: '✓', highlight: false },
    phorest: { value: '✓', highlight: false },
    reservio: { value: '✓', highlight: false }
  },
  {
    feature: 'Recordatorios WhatsApp',
    cita2: { value: '✓ Incluido', highlight: true },
    agendapro: { value: '+15€/mes', highlight: false },
    phorest: { value: '+10€/mes', highlight: false },
    reservio: { value: '✗', highlight: false }
  },
  {
    feature: 'Gestión técnicos',
    cita2: { value: '✓', highlight: true },
    agendapro: { value: '✓', highlight: false },
    phorest: { value: '✓', highlight: false },
    reservio: { value: '✓', highlight: false }
  },
  {
    feature: 'Historial coloración',
    cita2: { value: '✓', highlight: true },
    agendapro: { value: '✓', highlight: false },
    phorest: { value: '✓', highlight: false },
    reservio: { value: '△', highlight: false }
  },
  {
    feature: 'Comisiones automáticas',
    cita2: { value: '✓', highlight: true },
    agendapro: { value: '✓', highlight: false },
    phorest: { value: '✓', highlight: false },
    reservio: { value: '✗', highlight: false }
  },
  {
    feature: 'App móvil',
    cita2: { value: 'Web responsive', highlight: false },
    agendapro: { value: '✓ Nativa', highlight: true },
    phorest: { value: '✓ Nativa', highlight: true },
    reservio: { value: 'Web responsive', highlight: false }
  }
];

const testimonial = {
  quote: "Desde que uso Cita2 he dejado de recibir llamadas a deshoras. Mis clientes reservan online y yo solo llego y trabajo. Las ausencias bajaron del 25% al 8%.",
  author: "María García",
  role: "Dueña",
  salon: "Peluquería María, Madrid",
  improvement: "-70% ausencias"
};

const faqs = [
  {
    question: '¿Cuál es el mejor software para peluquería pequeña?',
    answer: 'Para peluquerías con 1-3 peluqueros, Cita2 es la mejor opción porque cuesta 19€/mes plan único (no por peluquero) e incluye WhatsApp Business. AgendaPro cuesta 49€ por cada peluquero, así que para 3 son 147€/mes. Cita2 incluye todas las funciones esenciales: reservas online, recordatorios, historial de coloraciones y gestión de técnicos.'
  },
  {
    question: '¿Cómo reducir ausencias en peluquería?',
    answer: 'Implementa recordatorios automáticos por WhatsApp (90% tasa de apertura) 24h antes de la cita. Pide depósito del 20% para coloraciones complejas. Usa lista de espera para rellenar cancelaciones de última hora. Con estas 3 tácticas reduces ausencias un 70%.'
  },
  {
    question: '¿Vale la pena pagar por software de peluquería?',
    answer: 'Absolutamente. Un software de 19€/mes que te ahorra 10h semanales de gestión (vale 180€ a 18€/hora) tiene ROI positivo inmediato. Además, reducir ausencias un 70% en una peluquería con 100 citas semanales significa recuperar ~700€/semana en ingresos.'
  },
  {
    question: '¿Qué funciones necesita una peluquería?',
    answer: 'Las imprescindibles son: reservas online 24/7, recordatorios automáticos (WhatsApp/email), historial de coloraciones y tratamientos por cliente, gestión de técnicos/peluqueros, comisiones automáticas, y estadísticas de ocupación e ingresos. Todo esto lo incluye Cita2 en su plan único de 19€/mes.'
  },
  {
    question: '¿Cita2 o AgendaPro para peluquería?',
    answer: 'Para la mayoría de peluquerías, Cita2 ofrece mejor relación calidad-precio: 19€/mes vs 147€/mes de AgendaPro (3 peluqueros). Cita2 incluye WhatsApp Business (AgendaPro cobra extra), tiene setup más rápido (2 min vs horas), y soporte igual de bueno. AgendaPro solo tiene sentido para grandes franquicias con presupuesto alto.'
  }
];
---

<Layout title={pageTitle} description={pageDescription}>
  <AdvancedSEO type="article" data={articleData} />
  <Header />
  
  <main class="pt-24">
    <div class="container-apple">
      <Breadcrumb items={breadcrumbItems} />
      
      <article class="max-w-4xl mx-auto">
        <header class="text-center mb-16">
          <span class="feature-bubble mb-4 inline-block">Peluquerías</span>
          <h1 class="text-headline text-gray-900 mb-6">
            Mejor Software para Peluquerías 2026
          </h1>
          <p class="text-body text-xl max-w-3xl mx-auto">
            Análisis completo de los mejores programas de gestión para peluquerías. Comparamos Cita2, AgendaPro, Phorest y más. Precios reales, funciones y valoraciones.
          </p>
          <div class="mt-8 p-6 bg-green-50 rounded-2xl inline-block">
            <p class="text-4xl font-bold text-green-700">Ahorra 1.536€/año</p>
            <p class="text-green-600">Cita2 vs AgendaPro (3 peluqueros)</p>
          </div>
        </header>

        {/* Quick Answer */}
        <div class="bg-blue-50 rounded-2xl p-8 mb-16">
          <h2 class="text-xl font-bold text-blue-900 mb-4">Respuesta rápida</h2>
          <p class="text-blue-800 mb-4">
            Para la mayoría de peluquerías con 1-5 peluqueros, <strong>Cita2</strong> ofrece la mejor relación calidad-precio.
          </p>
          <div class="grid md:grid-cols-2 gap-4">
            <ul class="space-y-2 text-blue-700 text-sm">
              <li>✓ 19€/mes plan único (no por peluquero)</li>
              <li>✓ WhatsApp Business incluido</li>
              <li>✓ Setup en 2 minutos</li>
              <li>✓ Historial de coloraciones</li>
            </ul>
            <div class="bg-white rounded-xl p-4 text-center">
              <p class="text-sm text-gray-500 mb-2">Coste mensual (3 peluqueros)</p>
              <div class="flex items-center justify-center gap-4">
                <div>
                  <p class="text-2xl font-bold text-blue-600">19€</p>
                  <p class="text-xs text-blue-600">Cita2</p>
                </div>
                <span class="text-gray-400">vs</span>
                <div>
                  <p class="text-2xl font-bold text-gray-500">147€</p>
                  <p class="text-xs text-gray-500">AgendaPro</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Comparison Table */}
        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden mb-16">
          <div class="p-6 bg-gradient-to-r from-pink-50 to-purple-50 border-b border-pink-200">
            <h2 class="text-xl font-semibold text-gray-900">Comparativa software peluquería</h2>
            <p class="text-sm text-gray-600 mt-1">Precios para peluquería con 3 peluqueros</p>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-4 py-4 text-left text-sm font-semibold text-gray-900">Función</th>
                  <th class="px-4 py-4 text-center text-sm font-bold text-blue-600 bg-blue-50/50">Cita2</th>
                  <th class="px-4 py-4 text-center text-sm font-semibold text-gray-700">AgendaPro</th>
                  <th class="px-4 py-4 text-center text-sm font-semibold text-gray-700">Phorest</th>
                  <th class="px-4 py-4 text-center text-sm font-semibold text-gray-700">Reservio</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {comparison.map((row, index) => (
                  <tr class={index % 2 === 1 ? 'bg-gray-50/30' : ''}>
                    <td class="px-4 py-4 font-medium text-gray-900">{row.feature}</td>
                    <td class="px-4 py-4 text-center bg-blue-50/30">
                      <span class={row.cita2.highlight ? 'font-semibold text-blue-700' : 'text-gray-700'}>
                        {row.cita2.value}
                      </span>
                    </td>
                    <td class="px-4 py-4 text-center text-gray-600">{row.agendapro.value}</td>
                    <td class="px-4 py-4 text-center text-gray-600">{row.phorest.value}</td>
                    <td class="px-4 py-4 text-center text-gray-600">{row.reservio.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        {/* Why Cita2 for hair salons */}
        <div class="mb-16">
          <h2 class="text-title text-gray-900 mb-8 text-center">¿Por qué Cita2 lidera para peluquerías?</h2>
          <div class="grid md:grid-cols-3 gap-6">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
              <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mb-4">
                <span class="text-2xl">💬</span>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">WhatsApp Business incluido</h3>
              <p class="text-gray-600 text-sm">Las peluqueras viven en WhatsApp. Tus clientes también. Recordatorios automáticos con 90% tasa de apertura, sin coste extra.</p>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
              <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mb-4">
                <span class="text-2xl">💰</span>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">Precio por peluquería, no por peluquero</h3>
              <p class="text-gray-600 text-sm">19€/mes ya sea que tengas 1 o 5 peluqueros. AgendaPro cobra 49€ por cada uno. Con 3 peluqueros ahorras 1.536€/año.</p>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
              <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mb-4">
                <span class="text-2xl">🎨</span>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">Historial de coloraciones</h3>
              <p class="text-gray-600 text-sm">Registra fórmulas de color, tratamientos aplicados, y fotos antes/después. Nunca más "¿qué tinte le puse la última vez?"</p>
            </div>
          </div>
        </div>

        {/* Testimonial */}
        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 mb-16">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 bg-pink-600 rounded-full flex items-center justify-center text-white text-xl font-bold">
              M
            </div>
            <div>
              <p class="font-semibold text-gray-900">{testimonial.author}</p>
              <p class="text-sm text-gray-500">{testimonial.role}, {testimonial.salon}</p>
            </div>
            <div class="ml-auto">
              <span class="inline-block px-3 py-1 bg-green-100 text-green-700 text-sm font-medium rounded-full">
                {testimonial.improvement}
              </span>
            </div>
          </div>
          <blockquote class="text-lg text-gray-700 italic border-l-4 border-pink-200 pl-4">
            "{testimonial.quote}"
          </blockquote>
        </div>

        {/* Essential Features */}
        <div class="bg-gradient-to-br from-pink-50 to-purple-50 rounded-2xl p-8 mb-16">
          <h2 class="text-title text-gray-900 mb-8 text-center">5 funciones imprescindibles para tu peluquería</h2>
          <div class="grid md:grid-cols-2 gap-6">
            <div class="bg-white rounded-xl p-6 shadow-sm">
              <h3 class="font-semibold text-gray-900 mb-2 flex items-center gap-2">
                <span class="w-8 h-8 bg-pink-100 rounded-full flex items-center justify-center text-pink-600 text-sm">1</span>
                Reservas online 24/7
              </h3>
              <p class="text-gray-600 text-sm">Tus clientes reservan cuando quieran, incluso a las 3am. Tú despiertas con la agenda organizada.</p>
            </div>
            <div class="bg-white rounded-xl p-6 shadow-sm">
              <h3 class="font-semibold text-gray-900 mb-2 flex items-center gap-2">
                <span class="w-8 h-8 bg-pink-100 rounded-full flex items-center justify-center text-pink-600 text-sm">2</span>
                Recordatorios automáticos
              </h3>
              <p class="text-gray-600 text-sm">WhatsApp 24h antes reduce ausencias un 70%. Confirmación con un clic, sin llamadas.</p>
            </div>
            <div class="bg-white rounded-xl p-6 shadow-sm">
              <h3 class="font-semibold text-gray-900 mb-2 flex items-center gap-2">
                <span class="w-8 h-8 bg-pink-100 rounded-full flex items-center justify-center text-pink-600 text-sm">3</span>
                Historial técnico completo
              </h3>
              <p class="text-gray-600 text-sm">Coloraciones, tratamientos, productos usados, fotos. Ficha digital completa de cada cliente.</p>
            </div>
            <div class="bg-white rounded-xl p-6 shadow-sm">
              <h3 class="font-semibold text-gray-900 mb-2 flex items-center gap-2">
                <span class="w-8 h-8 bg-pink-100 rounded-full flex items-center justify-center text-pink-600 text-sm">4</span>
                Gestión de técnicos
              </h3>
              <p class="text-gray-600 text-sm">Cada peluquero ve su agenda, comisiones automáticas, y horarios personalizados.</p>
            </div>
            <div class="bg-white rounded-xl p-6 shadow-sm md:col-span-2">
              <h3 class="font-semibold text-gray-900 mb-2 flex items-center gap-2">
                <span class="w-8 h-8 bg-pink-100 rounded-full flex items-center justify-center text-pink-600 text-sm">5</span>
                Depósitos online
              </h3>
              <p class="text-gray-600 text-sm">Para coloraciones complejas, cobra señal al reservar. Reduce no-shows y asegura compromiso del cliente.</p>
            </div>
          </div>
        </div>

        {/* ROI Calculator */}
        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 mb-16">
          <h2 class="text-xl font-bold text-gray-900 mb-6 text-center">ROI del software de peluquería</h2>
          <div class="grid md:grid-cols-2 gap-8">
            <div>
              <h3 class="font-semibold text-gray-900 mb-4">Costes vs Beneficios (ejemplo real)</h3>
              <ul class="space-y-3 text-sm">
                <li class="flex justify-between">
                  <span class="text-gray-600">Coste software Cita2</span>
                  <span class="font-medium">228€/año</span>
                </li>
                <li class="flex justify-between">
                  <span class="text-gray-600">Ahorro gestión (10h/semana × 18€)</span>
                  <span class="font-medium text-green-600">+9.360€/año</span>
                </li>
                <li class="flex justify-between">
                  <span class="text-gray-600">Recuperar ausencias (70% de 100 citas/semana)</span>
                  <span class="font-medium text-green-600">+25.480€/año</span>
                </li>
                <li class="flex justify-between">
                  <span class="text-gray-600">Ahorro vs AgendaPro</span>
                  <span class="font-medium text-green-600">+1.536€/año</span>
                </li>
                <li class="border-t pt-2 flex justify-between font-bold">
                  <span class="text-gray-900">Beneficio neto anual</span>
                  <span class="text-green-700 text-lg">+36.148€</span>
                </li>
              </ul>
            </div>
            <div class="bg-blue-50 rounded-xl p-6 flex flex-col justify-center">
              <p class="text-sm text-blue-600 mb-2">Tiempo de recuperación</p>
              <p class="text-4xl font-bold text-blue-700">2 días</p>
              <p class="text-blue-600 text-sm mt-2">El ahorro de una sola cita recuperada ya paga el mes de software.</p>
            </div>
          </div>
        </div>

        {/* FAQs */}
        <div class="mb-16">
          <h2 class="text-title text-gray-900 mb-8 text-center">Preguntas sobre software de peluquería</h2>
          <div class="space-y-4">
            {faqs.map((faq) => (
              <details class="bg-white rounded-xl shadow-sm border border-gray-100 group">
                <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-gray-50 transition-colors">
                  <h3 class="font-semibold text-gray-900 pr-4">{faq.question}</h3>
                  <span class="flex-shrink-0">
                    <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </span>
                </summary>
                <div class="px-6 pb-6 text-gray-600">
                  <p>{faq.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </div>

        {/* Final CTA */}
        <div class="bg-gradient-to-br from-pink-600 to-purple-600 rounded-2xl p-12 text-center text-white">
          <h2 class="text-2xl font-bold mb-4">Prueba el mejor software para peluquerías</h2>
          <p class="text-pink-100 mb-8 max-w-2xl mx-auto">
            Gestión de técnicos, historial de coloraciones, WhatsApp Business y todo lo que tu peluquería necesita. 14 días gratis.
          </p>
          <a href="https://agendadereservas.com/register" class="inline-flex items-center gap-2 px-8 py-4 bg-white text-pink-600 rounded-full font-semibold hover:bg-pink-50 transition-colors text-lg">
            Crear cuenta gratuita
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <p class="text-sm text-pink-200 mt-4">Sin tarjeta · Setup en 2 minutos · Precio fijo 19€/mes</p>
        </div>
      </article>
    </div>
  </main>
  
  <Footer />
</Layout>
