---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Testimonials from '../components/Testimonials.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import DashboardMockup from '../components/DashboardMockup.astro';

import content from '../content/sectors/fisioterapia.json';

const { pageTitle, pageDescription, aiDescription, heroTitle, heroSubtitle, features, testimonials, faqs } = content;

const canonicalUrl = 'https://agendadereservas.com/fisioterapia/';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: 'Agenda de Reservas - Software para Fisioterapia',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      offers: {
        '@type': 'Offer',
        price: '19',
        priceCurrency: 'EUR',
        priceValidUntil: '2026-12-31'
      },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((faq: { question: string; answer: string }) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer }
      }))
    }
  ]
};

---

<Layout title={pageTitle} description={pageDescription} aiDescription={aiDescription} canonicalUrl={canonicalUrl} schema={schema}>
  <Header />
  
  <main>
    <Hero 
      title={heroTitle}
      subtitle={heroSubtitle}
      primaryCta="Prueba gratis 14 días"
      primaryCtaHref="https://app.agendadereservas.com"
      secondaryCta="Ver funcionalidades"
      secondaryCtaHref="#producto"
    />

    <!-- Vista previa del panel real (datos de ejemplo) -->
    <section class="section-padding bg-white border-b border-gray-100">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto mb-10">
          <h2 class="text-3xl font-bold text-gray-900 mb-3">Así gestionas tu centro de fisioterapia</h2>
          <p class="text-gray-600">Boxes, sesiones e historial de pacientes en un panel claro. Datos de ejemplo.</p>
        </div>
        <div class="max-w-3xl mx-auto">
          <DashboardMockup sector="fisioterapia" />
        </div>
      </div>
    </section>

    <Features
      title="¿Qué conseguirás con Agenda de Reservas?"
      subtitle="Funcionalidades específicas para fisioterapeutas."
      features={features}
    />

    <Testimonials 
      title="Lo que dicen los fisioterapeutas"
      subtitle="Más de 95 clínicas de fisioterapia confían en Agenda de Reservas."
      testimonials={testimonials}
    />

    <Pricing />

    <FAQ 
      title="Preguntas frecuentes para fisioterapia"
      subtitle="Respuestas a las dudas más comunes del sector."
      faqs={faqs}
    />

    <CTA 
      title="Mejora la gestión de tu clínica de fisioterapia"
      subtitle="Únete a 95+ clínicas que ya ahorran tiempo y mejoran resultados con Agenda de Reservas."
    />
  </main>
  
  <Footer />
</Layout>
