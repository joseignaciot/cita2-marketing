---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroV2 from '../components/HeroV2.astro';
import Features from '../components/Features.astro';
import Testimonials from '../components/Testimonials.astro';
import PricingV2 from '../components/PricingV2.astro';
import DynamicPricing from '../components/DynamicPricing.astro';
import FAQ from '../components/FAQ.astro';
import '../styles/apple-design.css';

// Contenido editable desde el CMS → public/admin → Páginas de Sector → Turismo
import content from '../content/sectors/turismo.json';
const { pageTitle, pageDescription, aiDescription, heroTitle, heroSubtitle, features: tourismFeatures, testimonials: tourismTestimonials, faqs: tourismFAQs } = content;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Agenda de Reservas - Software para Turismo',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '29',
    priceCurrency: 'EUR',
    priceValidUntil: '2026-12-31'
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '85'
  }
};

---

<Layout 
  title={pageTitle}
  description={pageDescription}
  aiDescription={aiDescription}
  schema={schema}
>
  <Header />
  
  <main>
    <HeroV2
      title="Software de turismo activo. En español. Sin comisiones."
      subtitle="Bókun cobra 49-499 USD/mes más 1,5% por cada reserva online. Nosotros: 29€/mes fijo en euros. Con WhatsApp, manifest de participantes e idiomas incluidos."
      ctaText="Prueba gratis 14 días"
      ctaHref="https://app.agendadereservas.com"
      secondaryCta={{ text: 'Ver comparativa vs Bókun', href: '#comparativa-turismo' }}
    />

    <Features 
      title="¿Qué conseguirás con Agenda de Reservas?"
      subtitle="Funcionalidades diseñadas específicamente para empresas de turismo activo y experiencias."
      features={tourismFeatures}
    />

    <!-- Comparativa verificada vs Bókun / FareHarbor -->
    <section id="comparativa-turismo" class="section-apple bg-gray-50">
      <div class="container-apple">
        <div class="text-center mb-12">
          <span class="feature-bubble mb-4 inline-block">Comparativa verificada</span>
          <h2 class="text-headline text-gray-900 mb-4">¿Cuánto pagas realmente por gestionar tus actividades?</h2>
          <p class="text-body">Precios contrastados en webs oficiales. Abril 2026.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto mb-12">

          <!-- Bókun -->
          <div class="bg-white rounded-2xl border-2 border-red-200 p-6">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-2xl">🌐</span>
              <div>
                <h3 class="font-bold text-red-600">Bókun</h3>
                <p class="text-xs text-gray-400">De TripAdvisor · Precio en USD</p>
              </div>
            </div>
            <div class="space-y-3 text-sm mb-4 mt-4">
              <div class="flex justify-between">
                <span class="text-gray-500">Plan Start</span>
                <span class="font-semibold text-red-600"><span data-competitor-key="bokun.monthly_usd">49</span> USD/mes</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Comisión por reserva online</span>
                <span class="font-semibold text-red-600">+<span data-competitor-key="bokun.commission_value">1,5</span>%</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500"><span data-competitor-key="bokun.example_bookings">100</span> reservas × <span data-competitor-key="bokun.example_booking_value">50</span>€</span>
                <span class="font-semibold text-red-600">+75 USD extra</span>
              </div>
              <div class="border-t pt-3 flex justify-between">
                <span class="font-bold">Total real/mes</span>
                <span class="font-extrabold text-red-600 text-lg">~<span data-competitor-total="bokun">124</span> USD</span>
              </div>
            </div>
            <ul class="text-xs text-gray-400 space-y-1">
              <li>❌ Precio en USD — fluctuación de cambio</li>
              <li>❌ Sin soporte en español</li>
              <li>❌ Sin WhatsApp</li>
              <li>✔ Channel manager Viator</li>
            </ul>
            <p class="text-xs text-gray-300 mt-3">
              Fuente: <a data-competitor-source-url="bokun" href="https://www.bokun.io/pricing" target="_blank" rel="nofollow noopener noreferrer" class="underline hover:text-white"><span data-competitor-source="bokun">bokun.io · verificado</span></a>
              · <span data-competitor-date="bokun">2026-04</span>
            </p>
          </div>

          <!-- FareHarbor -->
          <div class="bg-white rounded-2xl border-2 border-orange-200 p-6">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-2xl">⚓</span>
              <div>
                <h3 class="font-bold text-orange-600">FareHarbor</h3>
                <p class="text-xs text-gray-400">De Booking Holdings</p>
              </div>
            </div>
            <div class="space-y-3 text-sm mb-4 mt-4">
              <div class="flex justify-between">
                <span class="text-gray-500">Cuota mensual</span>
                <span class="font-semibold text-green-600">0 USD/mes</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Comisión por reserva</span>
                <span class="font-semibold text-red-600"><span data-competitor-key="fareharbor.commission_value">6</span>%</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500"><span data-competitor-key="fareharbor.example_bookings">100</span> reservas × <span data-competitor-key="fareharbor.example_booking_value">50</span>€</span>
                <span class="font-semibold text-red-600"><span data-competitor-total="fareharbor">300</span> USD extra</span>
              </div>
              <div class="border-t pt-3 flex justify-between">
                <span class="font-bold">Total real/mes</span>
                <span class="font-extrabold text-red-600 text-lg">~<span data-competitor-total="fareharbor">300</span> USD</span>
              </div>
            </div>
            <ul class="text-xs text-gray-400 space-y-1">
              <li>❌ Comisión visible al cliente final</li>
              <li>❌ Solo en inglés</li>
              <li>❌ Sin WhatsApp</li>
              <li>❌ No adaptado al mercado español</li>
            </ul>
            <p class="text-xs text-gray-300 mt-3">
              Fuente: <a data-competitor-source-url="fareharbor" href="https://fareharbor.com/pricing/" target="_blank" rel="nofollow noopener noreferrer" class="underline hover:text-white"><span data-competitor-source="fareharbor">fareharbor.com · verificado</span></a>
              · <span data-competitor-date="fareharbor">2026-04</span>
            </p>
          </div>

          <!-- Agenda de Reservas -->
          <div class="bg-white rounded-2xl border-2 border-green-400 p-6 shadow-lg relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-green-500 text-white text-xs font-bold px-3 py-1 rounded-full">
              La opción inteligente ✓
            </div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-2xl">🧭</span>
              <div>
                <h3 class="font-bold text-green-600">Agenda de Reservas</h3>
                <p class="text-xs text-gray-400">Plan Turismo · En euros</p>
              </div>
            </div>
            <div class="space-y-3 text-sm mb-4 mt-4">
              <div class="flex justify-between">
                <span class="text-gray-500">Cuota mensual</span>
                <span class="font-semibold text-green-600"><span data-price-key="tourism_activities.monthly">29</span>€/mes</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Comisión por reserva</span>
                <span class="font-semibold text-green-600">0% — siempre</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">WhatsApp Business</span>
                <span class="font-semibold">+<span data-price-key="addon_communications.monthly">8</span>€/mes</span>
              </div>
              <div class="border-t pt-3 flex justify-between">
                <span class="font-bold">Total completo</span>
                <span class="font-extrabold text-green-600 text-lg"><span data-price-calc="tourism_activities.monthly+addon_communications.monthly">37</span>€/mes</span>
              </div>
            </div>
            <ul class="text-xs text-gray-600 space-y-1">
              <li>✅ En euros, soporte en español</li>
              <li>✅ WhatsApp Business API nativo</li>
              <li>✅ Manifest de participantes incluido</li>
              <li>✅ Precios por adulto/niño/grupo</li>
            </ul>
          </div>
        </div>

        <div class="text-center">
          <p class="text-xl font-bold text-gray-900">
            Ahorro vs Bókun: <span class="text-green-600">hasta <span data-price-saving-annual="tourism_activities.monthly+addon_communications.monthly:115">936</span>€/año</span>
          </p>
          <p class="text-sm text-gray-500 mt-1">
            (115$ equivalentes - <span data-price-calc="tourism_activities.monthly+addon_communications.monthly">37</span>€) × 12 meses
          </p>
        </div>
      </div>
    </section>

    <Testimonials 
      title="Lo que dicen las empresas de turismo"
      subtitle="Más de 80 agencias de viajes y empresas de turismo activo ya usan Agenda de Reservas."
      testimonials={tourismTestimonials}
    />

    <!-- IA Chat Widget: diferenciador exclusivo -->
    <section class="section-apple bg-white" id="chat-ia">
      <div class="container-apple">

        <div class="text-center max-w-3xl mx-auto mb-16">
          <span class="feature-bubble mb-4 inline-block">Exclusivo · Ningún competidor lo tiene</span>
          <h2 class="text-headline text-gray-900 mb-4">
            Reservas por IA en tu web.<br/>
            <span class="text-blue-600">Tus clientes preguntan. El sistema reserva.</span>
          </h2>
          <p class="text-body text-lg">
            Un asistente inteligente que conoce tus actividades, precios y disponibilidad. 
            Tu cliente escribe "quiero una ruta en kayak para 4 personas el sábado" — y queda reservado.
          </p>
        </div>

        <!-- Antes/Después del chat -->
        <div class="grid lg:grid-cols-2 gap-12 max-w-5xl mx-auto mb-20">

          <!-- SIN chat IA -->
          <div class="bg-red-50 rounded-3xl p-8 border-2 border-red-100">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">😩</div>
              <div>
                <h3 class="font-bold text-gray-900">Sin asistente IA</h3>
                <p class="text-sm text-red-600">Cómo reservan los turistas hoy</p>
              </div>
            </div>
            <div class="space-y-4">
              {[
                { icon: "📞", text: "Buscan tu teléfono → Llaman → Nadie responde" },
                { icon: "📧", text: "Envían un email → Esperan 24-48h tu respuesta" },
                { icon: "🌐", text: "Intentan el formulario → Demasiados campos → Abandonan" },
                { icon: "💬", text: "Preguntan por WhatsApp → Tú lo ves cuando puedes" },
                { icon: "😞", text: "Se van a reservar con la competencia" },
              ].map(item => (
                <div class="flex items-start gap-3">
                  <span class="text-xl flex-shrink-0">{item.icon}</span>
                  <p class="text-sm text-red-800">{item.text}</p>
                </div>
              ))}
            </div>
            <div class="mt-6 pt-4 border-t border-red-200">
              <p class="text-sm font-bold text-red-700">Resultado: pierdes el 60% de las consultas fuera de horario</p>
            </div>
          </div>

          <!-- CON chat IA -->
          <div class="bg-blue-50 rounded-3xl p-8 border-2 border-blue-200 relative">
            <div class="absolute -top-3 right-6 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full">
              Disponible en tu web en 5 min
            </div>
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">🤖</div>
              <div>
                <h3 class="font-bold text-gray-900">Con Asistente IA Cita2</h3>
                <p class="text-sm text-blue-600">Cómo reservan tus turistas desde mañana</p>
              </div>
            </div>

            <!-- Conversación demo -->
            <div class="space-y-3 mb-6">
              <div class="flex justify-end">
                <div class="bg-white rounded-2xl rounded-tr-none px-4 py-2.5 text-sm text-gray-800 shadow-sm max-w-xs">
                  Hola, ¿tenéis kayak para 4 personas el próximo sábado?
                </div>
              </div>
              <div class="flex justify-start">
                <div class="bg-blue-600 rounded-2xl rounded-tl-none px-4 py-2.5 text-sm text-white shadow-sm max-w-xs">
                  ¡Hola! Sí tenemos disponibilidad el sábado. Tengo salidas a las 10:00 y 16:00. Para 4 personas son 120€. ¿Cuál horario prefieres?
                </div>
              </div>
              <div class="flex justify-end">
                <div class="bg-white rounded-2xl rounded-tr-none px-4 py-2.5 text-sm text-gray-800 shadow-sm max-w-xs">
                  Las 10:00 perfecto. ¿Cómo pago?
                </div>
              </div>
              <div class="flex justify-start">
                <div class="bg-blue-600 rounded-2xl rounded-tl-none px-4 py-2.5 text-sm text-white shadow-sm max-w-xs">
                  Perfecto ✅ Te reservo las 10:00 del sábado. Necesito tu nombre y teléfono para confirmar.
                </div>
              </div>
            </div>

            <div class="bg-white rounded-xl p-4 border border-blue-100">
              <div class="flex items-center gap-2 text-sm">
                <span class="text-green-600 font-bold">✅ Reserva confirmada</span>
                <span class="text-gray-400">·</span>
                <span class="text-gray-500">en tu agenda automáticamente</span>
              </div>
              <p class="text-xs text-gray-400 mt-1">3:47 am · El cliente reservó mientras dormías</p>
            </div>
          </div>
        </div>

        <!-- 3 beneficios clave en grid -->
        <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto mb-16">
          {[
            {
              icon: "🌙",
              title: "Reservas mientras duermes",
              stat: "60% de reservas fuera de horario",
              desc: "El 60% de las búsquedas de actividades turísticas son fuera del horario de oficina. Tu IA atiende 24/7."
            },
            {
              icon: "🧠",
              title: "Conoce tu negocio",
              stat: "Respuestas en <3 segundos",
              desc: "Precios, disponibilidad, qué incluye, requisitos de edad... Todo respondido al instante con tus datos reales."
            },
            {
              icon: "💶",
              title: "Sin comisiones por reserva",
              stat: "0€ por reserva completada",
              desc: "Bókun y FareHarbor cobran 1,5-6% por reserva. Nuestro chat IA está incluido en tu plan mensual."
            }
          ].map(b => (
            <div class="bg-gray-50 rounded-2xl p-6 text-center hover-lift">
              <div class="text-4xl mb-4">{b.icon}</div>
              <div class="text-xs font-bold text-blue-600 bg-blue-50 px-3 py-1 rounded-full inline-block mb-3">{b.stat}</div>
              <h3 class="font-bold text-gray-900 mb-2">{b.title}</h3>
              <p class="text-sm text-gray-500">{b.desc}</p>
            </div>
          ))}
        </div>

        <!-- Compatibilidad -->
        <div class="bg-gray-900 rounded-3xl p-8 max-w-3xl mx-auto text-center">
          <p class="text-gray-400 text-sm mb-3">Funciona en cualquier web — sin programación</p>
          <div class="flex flex-wrap justify-center gap-4 mb-6">
            {["WordPress", "Wix", "Squarespace", "HTML", "Elementor", "Divi"].map(p => (
              <span class="bg-gray-800 text-gray-200 px-4 py-1.5 rounded-full text-sm">{p}</span>
            ))}
          </div>
          <p class="text-white font-semibold text-lg mb-2">2 líneas de código. Listo.</p>
          <p class="text-gray-400 text-sm mb-6">Pegas el snippet en el footer de tu web y en 5 minutos tus clientes pueden reservar por chat.</p>
          <a
            href="https://app.agendadereservas.com"
            class="inline-block bg-blue-600 text-white font-bold px-8 py-3.5 rounded-2xl hover:bg-blue-700 transition-colors"
          >
            Activar asistente IA gratis →
          </a>
          <p class="text-gray-500 text-xs mt-3">Incluido en todos los planes · Sin coste adicional</p>
        </div>

      </div>
    </section>

    <PricingV2 />

    <FAQ 
      title="Preguntas frecuentes para turismo"
      subtitle="Respuestas a las dudas más comunes del sector turístico."
      faqs={tourismFAQs}
    />

    <section class="section-apple bg-gray-900">
      <div class="container-apple text-center">
        <h2 class="text-headline text-white mb-4">Gestiona tus actividades profesionalmente.<br/><span class="text-green-400">Por <span data-price-key="tourism_activities.monthly">29</span>€/mes.</span></h2>
        <p class="text-gray-400 mb-8">Únete a 80+ empresas de turismo que ya ahorran tiempo y dinero con Agenda de Reservas.</p>
        <a href="https://app.agendadereservas.com" class="inline-block bg-white text-gray-900 font-bold px-10 py-4 rounded-2xl hover:bg-gray-100 transition-colors">
          Prueba gratis 14 días — sin tarjeta
        </a>
      </div>
    </section>
  </main>
  
  <Footer />
  <DynamicPricing />
</Layout>
