---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroV2 from '../components/HeroV2.astro';
import Features from '../components/Features.astro';
import Testimonials from '../components/Testimonials.astro';
import PricingV2 from '../components/PricingV2.astro';
import FAQ from '../components/FAQ.astro';
import '../styles/apple-design.css';

const pageTitle = 'Software de Reservas para Actividades Turísticas - Agenda de Reservas';
const pageDescription = 'Software para tours, excursiones y actividades turísticas en España. 29€/mes fijo, sin comisiones. WhatsApp nativo, manifest de participantes, precios por persona. vs Bókun 49$/mes+1,5%.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Agenda de Reservas - Software para Turismo',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '29',
    priceCurrency: 'EUR',
    priceValidUntil: '2026-12-31'
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '85'
  }
};

const tourismFeatures = [
  {
    title: 'Precios por persona o grupo',
    description: 'Configura tarifas por adulto, niño, senior o precios fijos por grupo. El sistema calcula automáticamente según el número de reservas.',
    icon: 'credit'
  },
  {
    title: 'Gestión de capacidad',
    description: 'Controla plazas disponibles en tiempo real. Overbooking controlado, lista de espera y gestión de grupos grandes.',
    icon: 'users'
  },
  {
    title: 'Extras y suplementos',
    description: 'Vende extras como recogida en hotel, comida, equipo de snorkel... Aumenta el ticket medio de cada reserva.',
    icon: 'zap'
  },
  {
    title: 'Calendario de disponibilidad',
    description: 'Define qué días hay salidas, a qué horas, cuántas plazas. El cliente ve solo opciones disponibles en tiempo real.',
    icon: 'calendar'
  },
  {
    title: 'Pagos online seguros',
    description: 'Stripe integrado para cobrar al reservar. Depósitos o pago completo. Reduce no-shows y asegura ingresos.',
    icon: 'credit'
  },
  {
    title: 'Panel de control operativo',
    description: 'Lista de pasajeros por actividad, check-in digital, exportación a Excel. Todo lo que necesitas para el día de la excursión.',
    icon: 'smartphone'
  }
];

const tourismTestimonials = [
  {
    quote: 'Hemos duplicado reservas directas y ahorrado 15h semanales. Todo está en un sitio, sabemos exactamente cuántos somos cada día y quién ha pagado qué.',
    author: 'Santiago Torres',
    role: 'Director',
    company: 'Santiago Tours, Santiago de Compostela',
    rating: 5
  },
  {
    quote: 'La gestión de extras es genial. Vendemos un 30% más de recogidas en hotel y almuerzos gracias a que se ofrecen durante la reserva online.',
    author: 'Elena Vázquez',
    role: 'Propietaria',
    company: 'Aventuras Norte, Lugo',
    rating: 5
  }
];

const tourismFAQs = [
  {
    question: '¿Funciona para tours de un día y multi-día?',
    answer: 'Sí, puedes configurar actividades de cualquier duración. Para tours multi-día, gestionamos cada día como slot independiente o como bloque completo según prefieras.'
  },
  {
    question: '¿Puedo limitar plazas por actividad?',
    answer: 'Sí, defines capacidad máxima por actividad y slot horario. El sistema bloquea automáticamente cuando se alcanza el límite y puede mostrar "solo X plazas disponibles" para crear urgencia.'
  },
  {
    question: '¿Cómo funcionan los precios por categorías?',
    answer: 'Configuras precios base (adulto, niño, senior...) y el cliente selecciona cuántos de cada categoría. El sistema calcula el total automáticamente. También puedes poner precios por grupo (hasta 4 personas: 100€).'
  },
  {
    question: '¿Se pueden añadir extras después de reservar?',
    answer: 'Sí, los clientes pueden modificar su reserva para añadir extras hasta 24h antes (configurable). También tú puedes añadir extras manualmente desde el panel.'
  },
  {
    question: '¿Tengo lista de pasajeros para el día de la actividad?',
    answer: 'Sí, tienes una vista operativa con todos los pasajeros, sus datos de contacto, extras contratados y estado de pago. Exportable a PDF/Excel y accesible desde móvil.'
  },
  {
    question: '¿Funciona para actividades con salidas múltiples al día?',
    answer: 'Sí, configuras tantos horarios como necesites (10:00, 14:00, 18:00...) con capacidad independiente para cada slot. El cliente elige horario al reservar.'
  }
];
---

<Layout 
  title={pageTitle}
  description={pageDescription}
  schema={schema}
>
  <Header />
  
  <main>
    <HeroV2
      title="Software de turismo activo. En español. Sin comisiones."
      subtitle="Bókun cobra 49-499 USD/mes más 1,5% por cada reserva online. Nosotros: 29€/mes fijo en euros. Con WhatsApp, manifest de participantes e idiomas incluidos."
      ctaText="Prueba gratis 14 días"
      ctaHref="https://app.agendadereservas.com"
      secondaryCta={{ text: 'Ver comparativa vs Bókun', href: '#comparativa-turismo' }}
    />

    <Features 
      title="¿Qué conseguirás con Agenda de Reservas?"
      subtitle="Funcionalidades diseñadas específicamente para empresas de turismo activo y experiencias."
      features={tourismFeatures}
    />

    <!-- Comparativa verificada vs Bókun / FareHarbor -->
    <section id="comparativa-turismo" class="section-apple bg-gray-50">
      <div class="container-apple">
        <div class="text-center mb-12">
          <span class="feature-bubble mb-4 inline-block">Comparativa verificada</span>
          <h2 class="text-headline text-gray-900 mb-4">¿Cuánto pagas realmente por gestionar tus actividades?</h2>
          <p class="text-body">Precios contrastados en webs oficiales. Abril 2026.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto mb-12">

          <!-- Bókun -->
          <div class="bg-white rounded-2xl border-2 border-red-200 p-6">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-2xl">🌐</span>
              <div>
                <h3 class="font-bold text-red-600">Bókun</h3>
                <p class="text-xs text-gray-400">De TripAdvisor · Precio en USD</p>
              </div>
            </div>
            <div class="space-y-3 text-sm mb-4 mt-4">
              <div class="flex justify-between">
                <span class="text-gray-500">Plan Start</span>
                <span class="font-semibold text-red-600">49 USD/mes</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Comisión por reserva online</span>
                <span class="font-semibold text-red-600">+1,5%</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">100 reservas × 50€</span>
                <span class="font-semibold text-red-600">+75 USD extra</span>
              </div>
              <div class="border-t pt-3 flex justify-between">
                <span class="font-bold">Total real/mes</span>
                <span class="font-extrabold text-red-600 text-lg">~115 USD</span>
              </div>
            </div>
            <ul class="text-xs text-gray-400 space-y-1">
              <li>❌ Precio en USD — fluctuación de cambio</li>
              <li>❌ Sin soporte en español</li>
              <li>❌ Sin WhatsApp</li>
              <li>✔ Channel manager Viator</li>
            </ul>
          </div>

          <!-- FareHarbor -->
          <div class="bg-white rounded-2xl border-2 border-orange-200 p-6">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-2xl">⚓</span>
              <div>
                <h3 class="font-bold text-orange-600">FareHarbor</h3>
                <p class="text-xs text-gray-400">De Booking Holdings</p>
              </div>
            </div>
            <div class="space-y-3 text-sm mb-4 mt-4">
              <div class="flex justify-between">
                <span class="text-gray-500">Cuota mensual</span>
                <span class="font-semibold text-green-600">0 USD/mes</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Comisión por reserva</span>
                <span class="font-semibold text-red-600">5-8%</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">100 reservas × 50€ (6%)</span>
                <span class="font-semibold text-red-600">300 USD extra</span>
              </div>
              <div class="border-t pt-3 flex justify-between">
                <span class="font-bold">Total real/mes</span>
                <span class="font-extrabold text-red-600 text-lg">~300 USD</span>
              </div>
            </div>
            <ul class="text-xs text-gray-400 space-y-1">
              <li>❌ Comisión visible al cliente final</li>
              <li>❌ Solo en inglés</li>
              <li>❌ Sin WhatsApp</li>
              <li>❌ No adaptado al mercado español</li>
            </ul>
          </div>

          <!-- Agenda de Reservas -->
          <div class="bg-white rounded-2xl border-2 border-green-400 p-6 shadow-lg relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-green-500 text-white text-xs font-bold px-3 py-1 rounded-full">
              La opción inteligente ✓
            </div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-2xl">🧭</span>
              <div>
                <h3 class="font-bold text-green-600">Agenda de Reservas</h3>
                <p class="text-xs text-gray-400">Plan Turismo · En euros</p>
              </div>
            </div>
            <div class="space-y-3 text-sm mb-4 mt-4">
              <div class="flex justify-between">
                <span class="text-gray-500">Cuota mensual</span>
                <span class="font-semibold text-green-600">29€/mes</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Comisión por reserva</span>
                <span class="font-semibold text-green-600">0% — siempre</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">WhatsApp Business</span>
                <span class="font-semibold">+8€/mes</span>
              </div>
              <div class="border-t pt-3 flex justify-between">
                <span class="font-bold">Total completo</span>
                <span class="font-extrabold text-green-600 text-lg">37€/mes</span>
              </div>
            </div>
            <ul class="text-xs text-gray-600 space-y-1">
              <li>✅ En euros, soporte en español</li>
              <li>✅ WhatsApp Business API nativo</li>
              <li>✅ Manifest de participantes incluido</li>
              <li>✅ Precios por adulto/niño/grupo</li>
            </ul>
          </div>
        </div>

        <div class="text-center">
          <p class="text-xl font-bold text-gray-900">
            Ahorro vs Bókun: <span class="text-green-600">hasta 936€/año</span>
          </p>
          <p class="text-sm text-gray-500 mt-1">(115$ - 37€) × 12 meses en el mismo escenario de 100 reservas</p>
        </div>
      </div>
    </section>

    <Testimonials 
      title="Lo que dicen las empresas de turismo"
      subtitle="Más de 80 agencias de viajes y empresas de turismo activo ya usan Agenda de Reservas."
      testimonials={tourismTestimonials}
    />

    <PricingV2 />

    <FAQ 
      title="Preguntas frecuentes para turismo"
      subtitle="Respuestas a las dudas más comunes del sector turístico."
      faqs={tourismFAQs}
    />

    <section class="section-apple bg-gray-900">
      <div class="container-apple text-center">
        <h2 class="text-headline text-white mb-4">Gestiona tus actividades profesionalmente.<br/><span class="text-green-400">Por 29€/mes.</span></h2>
        <p class="text-gray-400 mb-8">Únete a 80+ empresas de turismo que ya ahorran tiempo y dinero con Agenda de Reservas.</p>
        <a href="https://app.agendadereservas.com" class="inline-block bg-white text-gray-900 font-bold px-10 py-4 rounded-2xl hover:bg-gray-100 transition-colors">
          Prueba gratis 14 días — sin tarjeta
        </a>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
