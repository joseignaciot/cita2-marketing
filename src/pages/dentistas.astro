---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Testimonials from '../components/Testimonials.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';

import content from '../content/sectors/dentistas.json';

const { pageTitle, pageDescription, aiDescription, heroTitle, heroSubtitle, features, testimonials, faqs } = content;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Agenda de Reservas - Software para Dentistas',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '19',
    priceCurrency: 'EUR',
    priceValidUntil: '2026-12-31'
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    reviewCount: '120'
  }
};

---

<Layout title={pageTitle} description={pageDescription} aiDescription={aiDescription} schema={schema}>
  <Header />
  
  <main>
    <Hero 
      title={heroTitle}
      subtitle={heroSubtitle}
      primaryCta="Prueba gratis 14 días"
      primaryCtaHref="https://app.agendadereservas.com"
      secondaryCta="Ver funcionalidades"
      secondaryCtaHref="#producto"
    />

    <Features 
      title="¿Qué conseguirás con Agenda de Reservas?"
      subtitle="Funcionalidades específicas para clínicas dentales."
      features={features}
    />

    <Testimonials 
      title="Lo que dicen los dentistas"
      subtitle="Más de 120 clínicas dentales ya usan Agenda de Reservas."
      testimonials={testimonials}
    />

    <Pricing />

    <FAQ 
      title="Preguntas frecuentes para dentistas"
      subtitle="Respuestas a las dudas más comunes del sector dental."
      faqs={faqs}
    />

    <CTA 
      title="Digitaliza tu clínica dental hoy"
      subtitle="Únete a 120+ clínicas que ya ahorran tiempo y ofrecen mejor servicio con Agenda de Reservas."
    />
  </main>
  
  <Footer />
</Layout>
