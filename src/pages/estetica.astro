---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Testimonials from '../components/Testimonials.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';

import content from '../content/sectors/estetica.json';
import DynamicPricing from '../components/DynamicPricing.astro';
import DashboardMockup from '../components/DashboardMockup.astro';

const { pageTitle, pageDescription, aiDescription, heroTitle, heroSubtitle, features, testimonials, faqs } = content;

const canonicalUrl = 'https://agendadereservas.com/estetica/';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: 'Agenda de Reservas - Software para Centros de Estética',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      offers: {
        '@type': 'Offer',
        price: '19',
        priceCurrency: 'EUR',
        priceValidUntil: '2026-12-31'
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.8',
        reviewCount: '180'
      }
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((faq: { question: string; answer: string }) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer }
      }))
    }
  ]
};

---

<Layout title={pageTitle} description={pageDescription} aiDescription={aiDescription} canonicalUrl={canonicalUrl} schema={schema}>
  <Header />
  
  <main>
    <Hero 
      title={heroTitle}
      subtitle={heroSubtitle}
      primaryCta="Prueba gratis 14 días"
      primaryCtaHref="https://app.agendadereservas.com"
      secondaryCta="Ver funcionalidades"
      secondaryCtaHref="#producto"
    />

    <!-- Vista previa del panel real (datos de ejemplo) -->
    <section class="section-padding bg-white border-b border-gray-100">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto mb-10">
          <h2 class="text-3xl font-bold text-gray-900 mb-3">Así gestionas tu centro de estética</h2>
          <p class="text-gray-600">Cabinas, bonos y recordatorios de tratamientos en un solo panel. Datos de ejemplo.</p>
        </div>
        <div class="max-w-3xl mx-auto">
          <DashboardMockup sector="estetica" />
        </div>
      </div>
    </section>

    <Features
      title="¿Qué conseguirás con Agenda de Reservas?"
      subtitle="Funcionalidades diseñadas específicamente para centros de estética, spas y bienestar."
      features={features}
    />

    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-center mb-12">Comparativa honesta</h2>
        <div class="overflow-x-auto">
          <table class="w-full max-w-4xl mx-auto bg-white rounded-xl shadow-sm">
            <thead>
              <tr class="bg-gray-100">
                <th class="p-4 text-left font-semibold">Característica</th>
                <th class="p-4 text-center font-semibold text-blue-600">Agenda de Reservas</th>
                <th class="p-4 text-center font-semibold">AgendaPro</th>
                <th class="p-4 text-center font-semibold">Reservio</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-t">
                <td class="p-4">Precio mensual</td>
                <td class="p-4 text-center font-medium text-blue-600"><span data-price-key="service_business.monthly">19</span>€ plan único</td>
                <td class="p-4 text-center">Desde 49€</td>
                <td class="p-4 text-center">Desde 31€</td>
              </tr>
              <tr class="border-t bg-gray-50">
                <td class="p-4">Comisiones</td>
                <td class="p-4 text-center text-green-600">✅ Ninguna</td>
                <td class="p-4 text-center text-green-600">✅ Ninguna</td>
                <td class="p-4 text-center text-green-600">✅ Ninguna</td>
              </tr>
              <tr class="border-t">
                <td class="p-4">Bonos y paquetes</td>
                <td class="p-4 text-center text-green-600">✅ Incluido</td>
                <td class="p-4 text-center text-red-500">❌ No</td>
                <td class="p-4 text-center text-yellow-500">⚠️ Básico</td>
              </tr>
              <tr class="border-t bg-gray-50">
                <td class="p-4">Ficha de tratamientos</td>
                <td class="p-4 text-center text-green-600">✅ Completa</td>
                <td class="p-4 text-center text-yellow-500">⚠️ Básica</td>
                <td class="p-4 text-center text-red-500">❌ No</td>
              </tr>
              <tr class="border-t">
                <td class="p-4">WhatsApp Business</td>
                <td class="p-4 text-center text-green-600">✅ Incluido</td>
                <td class="p-4 text-center text-red-500">❌ No</td>
                <td class="p-4 text-center text-red-500">❌ No</td>
              </tr>
              <tr class="border-t bg-gray-50">
                <td class="p-4">Setup tiempo</td>
                <td class="p-4 text-center text-blue-600">2 minutos</td>
                <td class="p-4 text-center">Varios días</td>
                <td class="p-4 text-center">30 minutos</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-center text-sm text-gray-700 mt-4">
          *Precios actualizados marzo 2026.
        </p>
      </div>
    </section>

    <Testimonials 
      title="Lo que dicen los centros de estética"
      subtitle="Más de 150 centros de estética y spas ya gestionan sus citas con Agenda de Reservas."
      testimonials={testimonials}
    />

    <Pricing />

    <FAQ 
      title="Preguntas frecuentes para centros de estética"
      subtitle="Respuestas a las dudas más comunes de spas y centros de bienestar."
      faqs={faqs}
    />

    <!-- Recursos para estética — hub-and-spoke -->
    <section class="section-padding bg-gray-50 border-t border-gray-100">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-2 text-center">Recursos para centros de estética y spas</h2>
        <p class="text-center text-gray-500 mb-10">Guías y comparativas para gestionar mejor tu centro.</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
          {[
            { href: '/guias/software-cabinas-estetica', tipo: 'Guía', titulo: 'Software para gestionar cabinas de estética', desc: 'Calendario de cabinas, bonos de sesiones y recordatorios para tratamientos.' },
            { href: '/guias/cobrar-anticipo-peluqueria', tipo: 'Guía', titulo: 'Cobrar anticipo para tratamientos', desc: 'Cómo pedir anticipo en sesiones largas para eliminar no-shows.' },
            { href: '/guias/reducir-ausencias', tipo: 'Guía', titulo: 'Cómo reducir ausencias hasta un 70%', desc: '7 estrategias probadas para negocios de belleza y bienestar.' },
            { href: '/vs/treatwell', tipo: 'Comparativa', titulo: 'Treatwell vs Agenda de Reservas', desc: 'Sin comisión del 20-35%: tus clientes y tus datos, siempre tuyos.' },
            { href: '/vs/fresha', tipo: 'Comparativa', titulo: 'Fresha vs Agenda de Reservas', desc: '"Gratis" con comisión vs cuota fija: qué sale mejor para tu centro.' },
            { href: '/vs/booksy', tipo: 'Comparativa', titulo: 'Booksy vs Agenda de Reservas', desc: 'Sin pago por profesional: precio fijo sin sorpresas al mes.' },
          ].map(({ href, tipo, titulo, desc }) => (
            <a href={href} class="group block bg-white border border-gray-200 rounded-xl p-5 hover:border-blue-300 hover:shadow-md transition-all">
              <p class="text-xs text-blue-600 font-medium mb-1 uppercase tracking-wide">{tipo}</p>
              <p class="font-semibold text-gray-900 group-hover:text-blue-700 transition-colors mb-1">{titulo}</p>
              <p class="text-sm text-gray-500">{desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CTA
      title="Empieza a gestionar tu centro de estética como un profesional"
      subtitle="Únete a 150+ centros de estética que ya ahorran tiempo y ganan más con Agenda de Reservas."
    />
  </main>
  
  <Footer />
  <DynamicPricing />
</Layout>
