---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import content from '../content/sectors/peluquerias.json';

const { pageTitle, pageDescription, aiDescription, heroTitle, heroSubtitle, features, testimonials, faqs } = content;
const canonicalUrl = 'https://agendadereservas.com/peluquerias/';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Agenda de Reservas para Peluquerías',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '19',
    priceCurrency: 'EUR',
    priceValidUntil: '2026-12-31',
    description: '19€/mes, todo incluido. Sin comisiones ni límites.',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    ratingCount: '200',
  },
  description: pageDescription,
  featureList: features.map((f: any) => f.title),
};
---

<Layout title={pageTitle} description={pageDescription} aiDescription={aiDescription} canonicalUrl={canonicalUrl} schema={schema}>
  <Header />
  
  <main>
    <Hero
      title={heroTitle}
      subtitle={heroSubtitle}
      ctaText="Prueba gratis 14 días"
      ctaHref="https://app.agendadereservas.com"
    />
    
    <Features
      title="¿Qué conseguirás con Agenda de Reservas?"
      subtitle="Funcionalidades diseñadas específicamente para las necesidades de las peluquerías."
      features={features}
      columns={3}
    />
    
    <!-- Comparison Section -->
    <section class="section-padding bg-white">
      <div class="max-w-5xl mx-auto container-padding">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-12">
          Comparativa honesta
        </h2>
        
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="border-b-2 border-gray-200">
                <th class="py-4 px-4 font-semibold text-gray-900">Característica</th>
                <th class="py-4 px-4 font-semibold text-primary-600">Agenda de Reservas</th>
                <th class="py-4 px-4 font-semibold text-gray-700">AgendaPro</th>
                <th class="py-4 px-4 font-semibold text-gray-700">Reservio</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <tr>
                <td class="py-4 px-4 font-medium">Precio mensual</td>
                <td class="py-4 px-4 text-primary-600 font-semibold">19€ plan único</td>
                <td class="py-4 px-4 text-gray-700">Desde 49€</td>
                <td class="py-4 px-4 text-gray-700">Desde 31€</td>
              </tr>
              <tr>
                <td class="py-4 px-4 font-medium">Comisiones</td>
                <td class="py-4 px-4"><span class="text-success font-semibold">❌ Ninguna</span></td>
                <td class="py-4 px-4 text-gray-700">❌ Ninguna</td>
                <td class="py-4 px-4 text-gray-700">❌ Ninguna</td>
              </tr>
              <tr>
                <td class="py-4 px-4 font-medium">WhatsApp Business</td>
                <td class="py-4 px-4"><span class="text-success font-semibold">✅ Incluido</span></td>
                <td class="py-4 px-4 text-gray-700">❌ No</td>
                <td class="py-4 px-4 text-gray-700">❌ No</td>
              </tr>
              <tr>
                <td class="py-4 px-4 font-medium">Setup tiempo</td>
                <td class="py-4 px-4 text-primary-600 font-semibold">2 minutos</td>
                <td class="py-4 px-4 text-gray-700">Varios días</td>
                <td class="py-4 px-4 text-gray-700">30 minutos</td>
              </tr>
              <tr>
                <td class="py-4 px-4 font-medium">Preset peluquería</td>
                <td class="py-4 px-4"><span class="text-success font-semibold">✅ Sí</span></td>
                <td class="py-4 px-4 text-gray-700">✅ Sí</td>
                <td class="py-4 px-4 text-gray-700">⚠️ Parcial</td>
              </tr>
              <tr>
                <td class="py-4 px-4 font-medium">Soporte español</td>
                <td class="py-4 px-4"><span class="text-success font-semibold">✅ Sí</span></td>
                <td class="py-4 px-4 text-gray-700">✅ Sí</td>
                <td class="py-4 px-4 text-gray-700">⚠️ Limitado</td>
              </tr>
            </tbody>
          </table>
        </div>
        
        <p class="mt-4 text-sm text-gray-700 text-center">
          *Precios actualizados marzo 2026. 
          <a href="/vs/agendapro" class="text-primary-600 hover:underline">Ver comparativa completa →</a>
        </p>
      </div>
    </section>
    
    <Testimonials
      title="Lo que dicen las peluquerías"
      subtitle="Más de 200 peluquerías ya gestionan sus citas con Agenda de Reservas."
      testimonials={testimonials}
    />
    
    <FAQ
      title="Preguntas frecuentes"
      subtitle="Respuestas a las dudas más comunes de las peluquerías."
      items={faqs}
    />
    
    <CTA
      title="Empieza a gestionar tu peluquería como un profesional"
      subtitle="Únete a 200+ peluquerías que ya ahorran tiempo y ganan más con Agenda de Reservas."
    />
  </main>
  
  <Footer />
</Layout>
