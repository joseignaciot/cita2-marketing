---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroV2 from '../components/HeroV2.astro';
import Features from '../components/Features.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import '../styles/apple-design.css';

// Contenido editable desde el CMS → public/admin → Páginas de Sector → Psicología
import content from '../content/sectors/clinicas-psicologia.json';
import DynamicPricing from '../components/DynamicPricing.astro';
const { pageTitle, pageDescription, features, testimonials, faqs, heroTitle, heroSubtitle } = content;

const canonicalUrl = 'https://agendadereservas.com/clinicas-psicologia/';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: 'Agenda de Reservas para Psicólogos',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      offers: {
        '@type': 'Offer',
        price: '19',
        priceCurrency: 'EUR',
        priceValidUntil: '2026-12-31',
        description: 'Precio plano mensual, citas ilimitadas, sin comisiones'
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.9',
        ratingCount: '87',
        bestRating: '5'
      },
      description: pageDescription,
      featureList: [
        'Citas online 24/7 para pacientes',
        'Recordatorios automáticos por WhatsApp y email',
        'Historial de pacientes confidencial',
        'Política de cancelación configurable',
        'Pagos online con Stripe',
        'Compatible con normativa RGPD'
      ]
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: '¿Es seguro para los datos de mis pacientes?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Sí. Agenda de Reservas cumple con el RGPD europeo. Los datos de tus pacientes se almacenan en servidores europeos, con cifrado en tránsito y reposo. Puedes firmar un acuerdo de encargado del tratamiento (DPA) con nosotros.'
          }
        },
        {
          '@type': 'Question',
          name: '¿Puedo gestionar terapia online y presencial?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Sí. Puedes configurar servicios diferenciados para sesiones presenciales, online (videollamada) o mixtas. Cada tipo puede tener precio y duración distintos.'
          }
        },
        {
          '@type': 'Question',
          name: '¿Los recordatorios de WhatsApp respetan la confidencialidad?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Sí. Los recordatorios nunca incluyen el motivo de la consulta ni información clínica. Solo confirman fecha, hora y nombre del profesional. El contenido es personalizable.'
          }
        },
        {
          '@type': 'Question',
          name: '¿Puedo cobrar la sesión al reservar?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Sí. Puedes activar el pago anticipado completo o un depósito para reducir cancelaciones de último minuto. El paciente paga con tarjeta al reservar a través de Stripe.'
          }
        },
        {
          '@type': 'Question',
          name: '¿Funciona para un solo psicólogo o para una clínica con varios terapeutas?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Para ambos. Un psicólogo autónomo con una cuota plana mensual gestiona su agenda completa. Una clínica puede añadir todos los terapeutas sin coste adicional por usuario.'
          }
        }
      ]
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription} canonicalUrl={canonicalUrl} schema={schema}>
  <Header />

  <main>
    <HeroV2
      title={heroTitle}
      subtitle={heroSubtitle}
      ctaText="Prueba gratis 14 días"
      ctaHref="https://app.agendadereservas.com"
      secondaryCta={{ text: 'Ver funcionalidades', href: '#funcionalidades' }}
    />

    <!-- El problema específico del psicólogo -->
    <section class="section-apple bg-gray-50">
      <div class="container-apple">
        <div class="text-center max-w-3xl mx-auto mb-12">
          <span class="feature-bubble mb-4 inline-block">El problema que conoces bien</span>
          <h2 class="text-headline text-gray-900 mb-4">
            Cada sesión perdida son <span class="text-red-600">60-120€ que no vuelven</span>
          </h2>
          <p class="text-body">
            El 18% de las citas psicológicas tienen ausencia o cancelación tardía. Con una agenda de 30 sesiones mensuales, eso son 5-6 sesiones perdidas. Hasta 720€ al mes en ingresos no realizados.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
          {[
            { stat: '−70%', label: 'ausencias con recordatorio automático 48h+2h antes' },
            { stat: '0€', label: 'comisión por reserva, para siempre' },
            { stat: '2 min', label: 'setup inicial con preset "Psicología" preconfigurado' }
          ].map(({ stat, label }) => (
            <div class="text-center">
              <p class="text-5xl font-black text-gray-900 mb-2">{stat}</p>
              <p class="text-gray-600 text-sm">{label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <Features
      id="funcionalidades"
      title="Todo lo que necesita una consulta de psicología"
      subtitle="Diseñado para profesionales de la salud mental. Privacidad, automatización y profesionalidad."
      features={features}
    />

    <!-- Comparativa vs no tener sistema -->
    <section class="section-apple bg-white">
      <div class="container-apple">
        <div class="text-center mb-12">
          <h2 class="text-headline text-gray-900 mb-4">Con y sin Agenda de Reservas</h2>
          <p class="text-body">El mismo tiempo de consulta. La diferencia: cuántos pacientes llegan.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
          <div class="bg-red-50 rounded-2xl p-8 border-2 border-red-100">
            <h3 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
              <span class="text-2xl">😓</span> Gestión manual
            </h3>
            <ul class="space-y-3 text-sm text-red-800">
              {[
                'Llamas o escribes a cada paciente para recordar cita',
                'Los pacientes te escriben al WhatsApp personal para reservar',
                'Pierdes 30-60 min/día en gestión administrativa',
                'Sin cancelación con antelación, pierdes el ingreso',
                'Tu número personal en Google = sin límites de horario'
              ].map(item => (
                <li class="flex items-start gap-2">
                  <span class="text-red-400 mt-0.5">✗</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-green-50 rounded-2xl p-8 border-2 border-green-200">
            <h3 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
              <span class="text-2xl">😌</span> Con Agenda de Reservas
            </h3>
            <ul class="space-y-3 text-sm text-green-800">
              {[
                'Recordatorio automático 48h y 2h antes por WA y email',
                'Página de reservas propia con tu marca, 24/7',
                'Cero tiempo en gestión: todo automatizado',
                'Política de cancelación con depósito configurable',
                'Número personal protegido, horarios respetados'
              ].map(item => (
                <li class="flex items-start gap-2">
                  <span class="text-green-600 mt-0.5">✓</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <Testimonials
      title="Lo que dicen los psicólogos"
      subtitle="Más de 80 profesionales de la salud mental usan Agenda de Reservas en España."
      testimonials={testimonials}
    />

    <FAQ
      title="Preguntas frecuentes para psicólogos"
      subtitle="Respondemos las dudas más habituales de los profesionales de la salud mental."
      faqs={faqs}
    />

    <section class="section-apple bg-gray-900">
      <div class="container-apple text-center">
        <h2 class="text-headline text-white mb-4">
          Céntrate en tus pacientes.<br/>
          <span class="text-green-400">Nosotros gestionamos tu agenda.</span>
        </h2>
        <p class="text-gray-400 mb-8"><span data-price-key="service_business.monthly">19</span>€/mes · Sin comisiones · Sin permanencia · Soporte en español</p>
        <a href="https://app.agendadereservas.com" class="inline-block bg-white text-gray-900 font-bold px-10 py-4 rounded-2xl hover:bg-gray-100 transition-colors">
          Prueba gratis 14 días — sin tarjeta
        </a>
      </div>
    </section>
  </main>

  <Footer />
  <DynamicPricing />
</Layout>
