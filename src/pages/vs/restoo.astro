---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import DynamicPricing from '../../components/DynamicPricing.astro';

const pageTitle = 'Agenda de Reservas vs Restoo 2026 — Comparativa para restaurantes en España';
const pageDescription = 'Comparativa Restoo vs Agenda de Reservas. Ambos sin comisiones, pero Agenda incluye WhatsApp, turismo y multivertical desde el mismo precio. ¿Cuál elegir?';

const features = [
  { category: 'Precios', rows: [
    { name: 'Plan básico mensual',          ours: '24€/mes',                    theirs: '39€/mes (Mini)',       winner: 'ours'   },
    { name: 'Plan completo',                ours: '24€ (todo incluido)',         theirs: '79€/mes (Pro)',        winner: 'ours'   },
    { name: 'Comisión por reserva',         ours: '0%',                         theirs: '0%',                  winner: 'tie'    },
    { name: 'Modelo de precios',            ours: 'Plan único todo-en-uno',     theirs: 'Múltiples planes',    winner: 'ours'   },
  ]},
  { category: 'Reservas y mesas', rows: [
    { name: 'Motor de reservas online',     ours: '✅ Incluido',                 theirs: '✅ Incluido',          winner: 'tie'    },
    { name: 'Gestión de mesas / plano sala',ours: '✅ Incluido',                 theirs: '✅ Avanzado',          winner: 'tie'    },
    { name: 'Turnos de comida y cena',      ours: '✅ Configurable',             theirs: '✅ Configurable',      winner: 'tie'    },
    { name: 'Lista de espera',              ours: '✅ Automática',               theirs: '✅ Disponible',        winner: 'tie'    },
    { name: 'Depósito al reservar',         ours: '✅ Stripe integrado',         theirs: '⚠️ Plan Pro',         winner: 'ours'   },
  ]},
  { category: 'Comunicación', rows: [
    { name: 'Email de confirmación',        ours: '✅ Personalizable',           theirs: '✅ Estándar',          winner: 'tie'    },
    { name: 'Recordatorio automático',      ours: '✅ Email + WhatsApp',         theirs: '✅ Email solo',        winner: 'ours'   },
    { name: 'WhatsApp Business',            ours: '✅ Nativo (+8€/mes)',         theirs: '❌ No disponible',    winner: 'ours'   },
    { name: 'SMS',                          ours: '✅ Disponible',               theirs: '❌ No',               winner: 'ours'   },
  ]},
  { category: 'CRM y datos', rows: [
    { name: 'Ficha de cliente',             ours: '✅ Completa',                 theirs: '✅ Básica',            winner: 'ours'   },
    { name: 'Historial de visitas',         ours: '✅ Detallado',                theirs: '⚠️ Básico',           winner: 'ours'   },
    { name: 'Exportar base de clientes',    ours: '✅ CSV / Excel',              theirs: '⚠️ Limitado',         winner: 'ours'   },
  ]},
  { category: 'Multivertical', rows: [
    { name: 'Restaurantes',                 ours: '✅',                          theirs: '✅ Core',              winner: 'tie'    },
    { name: 'Turismo y actividades',        ours: '✅ Plan Turismo',             theirs: '❌ No',               winner: 'ours'   },
    { name: 'Peluquerías / servicios',      ours: '✅ Plan Servicios',           theirs: '❌ No',               winner: 'ours'   },
    { name: 'Un panel para todo tu negocio',ours: '✅ Sí',                       theirs: '❌ Solo restaurantes', winner: 'ours'  },
  ]},
];

const wins = { ours: 0, theirs: 0, tie: 0 };
features.forEach(c => c.rows.forEach(r => wins[r.winner as keyof typeof wins]++));
---

<Layout title={pageTitle} description={pageDescription}>
  <Header />
  <main class="pt-24 bg-white">

    <section class="py-20 bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <span class="inline-block px-4 py-1.5 bg-orange-500/20 text-orange-300 text-sm font-semibold rounded-full mb-6 border border-orange-500/30">
          Comparativa verificada · Abril 2026
        </span>
        <h1 class="text-4xl md:text-6xl font-extrabold mb-6 leading-tight">
          Restoo<br/><span class="text-gray-400">vs</span><br/>
          <span class="text-green-400">Agenda de Reservas</span>
        </h1>
        <p class="text-xl text-gray-300 max-w-2xl mx-auto mb-10">
          Dos opciones sin comisiones para restaurantes. Pero solo una incluye WhatsApp, turismo y precio más bajo.
        </p>
        <div class="flex flex-wrap justify-center gap-4 mb-12">
          <span class="px-4 py-2 bg-green-500/20 border border-green-500/30 text-green-300 rounded-full text-sm">🏆 {wins.ours} ventajas Agenda</span>
          <span class="px-4 py-2 bg-orange-500/20 border border-orange-500/30 text-orange-300 rounded-full text-sm">✅ {wins.theirs} ventajas Restoo</span>
          <span class="px-4 py-2 bg-gray-500/20 border border-gray-500/30 text-gray-400 rounded-full text-sm">🤝 {wins.tie} empates</span>
        </div>
        <div class="grid md:grid-cols-2 gap-6 max-w-2xl mx-auto">
          <div class="bg-orange-900/30 border border-orange-500/30 rounded-2xl p-6">
            <p class="text-orange-300 text-xs font-semibold uppercase mb-2">Restoo desde</p>
            <p class="text-4xl font-black text-orange-400"><span data-competitor-key="restoo.monthly_fee">39</span>€<span class="text-lg font-normal text-orange-300">/mes</span></p>
            <p class="text-xs text-orange-400 mt-1">Plan Mini. WhatsApp no incluido.</p>
          </div>
          <div class="bg-green-900/30 border border-green-500/30 rounded-2xl p-6">
            <p class="text-green-300 text-xs font-semibold uppercase mb-2">Agenda de Reservas</p>
            <p class="text-4xl font-black text-green-400"><span data-price-key="restaurant.monthly">24</span>€<span class="text-lg font-normal text-green-300">/mes</span></p>
            <p class="text-xs text-green-400 mt-1">Todo incluido. WhatsApp +8€.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-center mb-12">Comparativa completa</h2>
        {features.map((cat, i) => (
          <div class={`mb-12 ${i > 0 ? 'pt-12 border-t border-gray-100' : ''}`}>
            <h3 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
              <span class="w-1.5 h-6 bg-green-500 rounded-full inline-block"></span>{cat.category}
            </h3>
            <div class="overflow-x-auto rounded-xl border border-gray-200">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-gray-50 border-b border-gray-200">
                    <th class="text-left py-3 px-4 font-semibold text-gray-600 w-1/3">Característica</th>
                    <th class="text-center py-3 px-4 font-semibold text-green-700 w-1/3">Agenda de Reservas</th>
                    <th class="text-center py-3 px-4 font-semibold text-orange-700 w-1/3">Restoo</th>
                  </tr>
                </thead>
                <tbody>
                  {cat.rows.map((row, ri) => (
                    <tr class={`border-b border-gray-100 ${ri % 2 === 0 ? '' : 'bg-gray-50/50'}`}>
                      <td class="py-3 px-4 font-medium text-gray-700">{row.name}</td>
                      <td class={`py-3 px-4 text-center ${row.winner === 'ours' ? 'text-green-700 font-semibold bg-green-50' : 'text-gray-600'}`}>
                        {row.ours}{row.winner === 'ours' && <span class="ml-1">🏆</span>}
                      </td>
                      <td class={`py-3 px-4 text-center ${row.winner === 'theirs' ? 'text-green-700 font-semibold bg-green-50' : 'text-gray-600'}`}>
                        {row.theirs}{row.winner === 'theirs' && <span class="ml-1">🏆</span>}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="py-20 bg-gray-900 text-white">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold mb-4">Ahorro anual vs Restoo</h2>
        <p class="text-4xl font-black text-green-400 mb-2">
          <span data-price-saving-annual="restaurant.monthly:39">180</span>€/año
        </p>
        <p class="text-gray-400 mb-10">Solo en cuota. Más lo que ahorras sin pagar WhatsApp aparte.</p>
        <a href="https://app.agendadereservas.com"
          class="inline-block px-10 py-5 bg-green-500 hover:bg-green-400 text-white font-bold text-lg rounded-2xl transition-colors">
          Prueba gratis 14 días →
        </a>
        <p class="text-gray-500 text-sm mt-4">Sin contrato · Cancela cuando quieras</p>
      </div>
    </section>
  </main>
  <Footer />
  <DynamicPricing />
</Layout>
