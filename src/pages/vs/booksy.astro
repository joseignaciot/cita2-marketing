
---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import DynamicPricing from '../../components/DynamicPricing.astro';
import '../../styles/apple-design.css';
import pricingData from '../../content/pricing.json';

// Precio de build-time: leer de pricing.json para coherencia con el resto del sitio
const svcPlan = pricingData.businessTypes.find(bt => bt.id === 'servicios');
const svcPrice = svcPlan?.monthly ?? 19; // fallback si la estructura cambia
const commsAddon = pricingData.addons.find(a => a.id === 'comunicaciones');
const commsPrice = commsAddon?.price ?? 8;

const pageTitle = 'Booksy vs Agenda de Reservas (2026) — Comparativa Honesta con Precios Reales';
const pageDescription = 'Comparativa detallada Booksy vs Agenda de Reservas. Precios reales: Booksy cobra 20-35€/mes POR EMPLEADO. Agenda de Reservas: precio fijo para todo tu equipo. Sin comisiones. ¿Cuál es mejor para tu negocio en España?';
const canonicalUrl = 'https://agendadereservas.com/vs/booksy/';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: '¿Booksy cobra por empleado?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Sí. Booksy cobra entre 20€ y 35€ por empleado al mes. Una peluquería con 3 empleados paga entre 60€ y 105€/mes. Agenda de Reservas cobra un precio fijo único sin límite de empleados.'
          }
        },
        {
          '@type': 'Question',
          name: '¿Booksy tiene WhatsApp Business integrado?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No. Booksy no integra WhatsApp Business API. Solo envía recordatorios por email y notificaciones push de su app. Agenda de Reservas integra WhatsApp Business API oficial con mensajes que llegan con un 90% de tasa de apertura.'
          }
        },
        {
          '@type': 'Question',
          name: '¿Cuál es más barato para una peluquería con 3 empleados?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Agenda de Reservas: 19€/mes fijo. Booksy: 60-105€/mes (3 empleados × 20-35€). El ahorro anual con Agenda de Reservas es de entre 492€ y 1.032€.'
          }
        },
        {
          '@type': 'Question',
          name: '¿Booksy funciona en España en español?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Booksy está disponible en España pero el soporte en español es limitado. Agenda de Reservas está creada en España, con soporte humano en español, RGPD europeo y precios en euros.'
          }
        }
      ]
    },
    {
      '@type': 'Article',
      headline: pageTitle,
      description: pageDescription,
      datePublished: '2026-04-01',
      dateModified: '2026-04-26',
      author: {
        '@type': 'Organization',
        name: 'Agenda de Reservas'
      }
    }
  ]
};

const pagosAddon = pricingData.addons.find(a => a.id === 'pagos');
const pagosPrice = pagosAddon?.price ?? 8;

const comparativa = [
  { feature: 'Precio base', booksy: '20-35€/empleado/mes', agenda: `${svcPrice}€/mes fijo total`, winner: 'agenda' },
  { feature: '3 empleados', booksy: '60-105€/mes', agenda: `${svcPrice}€/mes`, winner: 'agenda' },
  { feature: '5 empleados', booksy: '100-175€/mes', agenda: `${svcPrice}€/mes`, winner: 'agenda' },
  { feature: 'WhatsApp Business API', booksy: '❌ No', agenda: `✅ Incluido (+${commsPrice}€)`, winner: 'agenda' },
  { feature: 'Soporte en español', booksy: '⚠️ Limitado', agenda: '✅ Humano, <2h', winner: 'agenda' },
  { feature: 'RGPD / datos en Europa', booksy: '⚠️ USA (Booksy Inc.)', agenda: '✅ Servidores EU', winner: 'agenda' },
  { feature: 'Pagos online con Stripe', booksy: '✅ Sí', agenda: `✅ Sí (+${pagosPrice}€/mes)`, winner: 'empate' },
  { feature: 'App para clientes', booksy: '✅ App propia (Booksy)', agenda: '✅ Página web responsive', winner: 'empate' },
  { feature: 'Marketplace de clientes', booksy: '✅ Sí (Booksy App)', agenda: '❌ No', winner: 'booksy' },
  { feature: 'Multi-sector', booksy: '⚠️ Solo belleza', agenda: '✅ Servicios, restaurantes, turismo', winner: 'agenda' },
  { feature: 'API / Integraciones', booksy: '⚠️ Limitado', agenda: '✅ Webhook + Zapier', winner: 'agenda' },
  { feature: 'Precio en euros', booksy: '⚠️ Variable (USD base)', agenda: '✅ Euros fijos', winner: 'agenda' },
];

// Cálculos pre-computados (evitar expresiones aritméticas en template literals del frontmatter)
const booksyMin1 = 20, booksyMax1 = 35;
const s1min = booksyMin1, s1max = booksyMax1;
const s2min = booksyMin1 * 2, s2max = booksyMax1 * 2, sv2min = s2min - svcPrice, sv2max = s2max - svcPrice;
const s3min = booksyMin1 * 3, s3max = booksyMax1 * 3, sv3min = s3min - svcPrice, sv3max = s3max - svcPrice;
const s5min = booksyMin1 * 5, s5max = booksyMax1 * 5, sv5min = s5min - svcPrice, sv5max = s5max - svcPrice;
const savings = [
  { size: '1 empleado',  booksyRange: `${s1min}-${s1max}€/mes`, saving: 'Empate o ahorro' },
  { size: '2 empleados', booksyRange: `${s2min}-${s2max}€/mes`, saving: `Ahorras ${sv2min}-${sv2max}€` },
  { size: '3 empleados', booksyRange: `${s3min}-${s3max}€/mes`, saving: `Ahorras ${sv3min}-${sv3max}€` },
  { size: '5 empleados', booksyRange: `${s5min}-${s5max}€/mes`, saving: `Ahorras ${sv5min}-${sv5max}€` },
];
---

<Layout title={pageTitle} description={pageDescription} canonicalUrl={canonicalUrl} schema={schema}>
  <Header />

  <main>
    <!-- Hero comparativa -->
    <section class="section-apple bg-white border-b border-gray-100">
      <div class="container-apple">
        <div class="text-center max-w-3xl mx-auto">
          <span class="feature-bubble mb-4 inline-block">Comparativa verificada · Abril 2026</span>
          <h1 class="text-headline text-gray-900 mb-6">
            Booksy vs Agenda de Reservas:<br/>
            <span class="text-blue-600">La comparativa que Booksy no quiere que veas</span>
          </h1>
          <p class="text-body text-lg mb-8">
            Booksy cobra por empleado. Con 3 peluqueros en plantilla, pagas <strong class="text-red-600">hasta 105€/mes</strong>. Agenda de Reservas: <strong class="text-green-600"><span data-price-key="service_business.monthly">{svcPrice}</span>€/mes para todo tu equipo</strong>, sin límites.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="https://app.agendadereservas.com" class="btn-apple-primary px-8 py-4">
              Empezar gratis — sin tarjeta
            </a>
            <a href="#comparativa" class="btn-apple-secondary px-8 py-4">
              Ver comparativa completa ↓
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- El número que más importa -->
    <section class="section-apple bg-red-50 border-b border-red-100">
      <div class="container-apple">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">
            El coste real de Booksy por tamaño de negocio
          </h2>
          <div class="grid md:grid-cols-4 gap-4">
            {savings.map(({ size, booksyRange, saving }) => (
              <div class="bg-white rounded-2xl p-5 border border-red-100 text-center">
                <p class="font-bold text-gray-900 mb-3">{size}</p>
                <p class="text-sm text-gray-500 mb-1">Booksy:</p>
                <p class="text-red-600 font-bold mb-2">{booksyRange}</p>
                <p class="text-sm text-gray-500 mb-1">Agenda de Reservas:</p>
                <p class="text-green-600 font-bold mb-3"><span data-price-key="service_business.monthly">{svcPrice}</span>€/mes</p>
                <span class="text-xs bg-green-100 text-green-800 px-2 py-1 rounded-full font-semibold">{saving}</span>
              </div>
            ))}
          </div>
          <p class="text-center text-xs text-gray-400 mt-4">Precios Booksy verificados en booksy.com/es-es. Actualizado abril 2026.</p>
        </div>
      </div>
    </section>

    <!-- Tabla comparativa completa -->
    <section id="comparativa" class="section-apple bg-white">
      <div class="container-apple">
        <h2 class="text-headline text-gray-900 text-center mb-12">Comparativa feature a feature</h2>

        <div class="max-w-4xl mx-auto overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b-2 border-gray-200">
                <th class="text-left py-4 px-4 text-gray-700 font-semibold">Característica</th>
                <th class="text-center py-4 px-4 text-gray-600 font-semibold">Booksy</th>
                <th class="text-center py-4 px-4 text-blue-700 font-semibold bg-blue-50 rounded-t-lg">Agenda de Reservas</th>
              </tr>
            </thead>
            <tbody>
              {comparativa.map(({ feature, booksy, agenda, winner }) => (
                <tr class="border-b border-gray-100 hover:bg-gray-50">
                  <td class="py-3 px-4 font-medium text-gray-800">{feature}</td>
                  <td class={`py-3 px-4 text-center ${winner === 'booksy' ? 'text-green-700 font-semibold' : winner === 'agenda' ? 'text-red-600' : 'text-gray-600'}`}>
                    {booksy}
                  </td>
                  <td class={`py-3 px-4 text-center bg-blue-50 ${winner === 'agenda' ? 'text-green-700 font-bold' : winner === 'booksy' ? 'text-red-600' : 'text-gray-600'}`}>
                    {agenda}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          <p class="text-xs text-gray-400 mt-4 text-right">Precios verificados en webs oficiales. Abril 2026.</p>
        </div>
      </div>
    </section>

    <!-- Cuándo elegir Booksy -->
    <section class="section-apple bg-gray-50">
      <div class="container-apple">
        <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-8">
          <div class="bg-white rounded-2xl p-8 border border-gray-200">
            <h3 class="font-bold text-gray-900 text-lg mb-4">Elige Booksy si...</h3>
            <ul class="space-y-3 text-sm text-gray-700">
              {[
                'Quieres aparecer en el marketplace de Booksy para captar clientes nuevos',
                'Trabajas solo (1 empleado) y el precio por usuario no te afecta',
                'La mayoría de tus clientes ya usan la app de Booksy',
                'No necesitas WhatsApp Business integrado'
              ].map(item => (
                <li class="flex items-start gap-2">
                  <span class="text-blue-500 mt-0.5 flex-shrink-0">→</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-blue-50 rounded-2xl p-8 border-2 border-blue-200">
            <h3 class="font-bold text-gray-900 text-lg mb-4">Elige Agenda de Reservas si...</h3>
            <ul class="space-y-3 text-sm text-gray-800">
              {[
                'Tienes 2 o más empleados y no quieres pagar por usuario',
                'Quieres WhatsApp Business API con 90% de apertura de mensajes',
                'Gestionas también restaurante o actividades turísticas',
                'Necesitas soporte humano en español con respuesta rápida',
                'Quieres tus datos en servidores europeos (RGPD)'
              ].map(item => (
                <li class="flex items-start gap-2">
                  <span class="text-green-600 mt-0.5 flex-shrink-0 font-bold">✓</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-apple bg-white">
      <div class="container-apple max-w-3xl mx-auto">
        <h2 class="text-headline text-gray-900 text-center mb-12">Preguntas frecuentes</h2>
        <div class="space-y-4">
          {[
            {
              q: '¿Booksy cobra por empleado?',
              a: 'Sí. Booksy cobra entre 20€ y 35€ por empleado al mes según el plan. Una peluquería con 3 empleados paga entre 60€ y 105€/mes. Agenda de Reservas cobra 19€/mes para todo tu equipo sin importar cuántos sois.'
            },
            {
              q: '¿Booksy tiene WhatsApp Business integrado?',
              a: 'No. Booksy solo envía notificaciones push de su app y emails. No integra WhatsApp Business API. Agenda de Reservas tiene WhatsApp Business API oficial incluida por +8€/mes, con mensajes de 90% de tasa de apertura.'
            },
            {
              q: '¿Cuál es más barato para una peluquería con 3 empleados?',
              a: 'Agenda de Reservas: 19€/mes fijo. Booksy: 60-105€/mes (3 empleados × 20-35€). El ahorro anual es de 492€ a 1.032€.'
            },
            {
              q: '¿Puedo migrar de Booksy a Agenda de Reservas sin perder datos?',
              a: 'Sí. Exporta tu lista de clientes desde Booksy en CSV e impórtala en Agenda de Reservas. Te ayudamos con la migración de forma gratuita. El proceso lleva menos de 1 hora.'
            },
            {
              q: '¿Agenda de Reservas tiene marketplace como Booksy?',
              a: 'No. A diferencia de Booksy, no tenemos un marketplace de captación de nuevos clientes. Agenda de Reservas es un software de gestión para tu negocio: tus clientes reservan directamente en tu página, sin intermediarios.'
            }
          ].map(({ q, a }) => (
            <div class="border border-gray-200 rounded-xl overflow-hidden">
              <details class="group">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-semibold text-gray-900 hover:bg-gray-50">
                  {q}
                  <span class="text-gray-400 group-open:rotate-180 transition-transform">▾</span>
                </summary>
                <div class="px-6 pb-4 text-gray-600 text-sm leading-relaxed">{a}</div>
              </details>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="section-apple bg-gray-900">
      <div class="container-apple text-center">
        <h2 class="text-headline text-white mb-4">
          ¿Cansado de pagar por cada empleado?<br/>
          <span class="text-blue-400"><span data-price-key="service_business.monthly">{svcPrice}</span>€/mes para todo tu equipo.</span>
        </h2>
        <p class="text-gray-400 mb-2">Sin comisiones · Sin permanencia · Soporte humano en español</p>
        <p class="text-gray-500 text-sm mb-8">Migración gratuita desde Booksy</p>
        <a href="https://app.agendadereservas.com" class="inline-block bg-white text-gray-900 font-bold px-10 py-4 rounded-2xl hover:bg-gray-100 transition-colors">
          Prueba gratis 14 días — sin tarjeta
        </a>
      </div>
    </section>
  </main>

  <Footer />
  <DynamicPricing />
</Layout>
