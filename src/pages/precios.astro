---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';

const pageTitle = 'Precios - Agenda de Reservas | Software de Gestión de Citas';
const pageDescription = 'Un plan, todo incluido. 19€/mes, sin comisiones por reserva ni límites ocultos. Prueba gratis 14 días, sin tarjeta de crédito.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Agenda de Reservas - Plan Profesional',
  description: 'Software de gestión de citas todo incluido',
  offers: {
    '@type': 'Offer',
    price: '19',
    priceCurrency: 'EUR',
    priceValidUntil: '2026-12-31',
    availability: 'https://schema.org/InStock'
  }
};

const pricingFAQs = [
  {
    question: '¿Hay algún coste oculto?',
    answer: 'No. 19€/mes es todo lo que pagas. Sin comisiones por reserva, sin límites de citas, sin cargos extra por usuarios o funcionalidades. Lo que ves es lo que pagas.'
  },
  {
    question: '¿Puedo cancelar cuando quiera?',
    answer: 'Sí, sin compromiso de permanencia. Cancelas cuando quieras desde tu panel, sin llamar a nadie ni justificar nada. Tu suscripción se detiene al final del período pagado.'
  },
  {
    question: '¿Hay descuento por pago anual?',
    answer: 'Sí, al pagar anualmente te regalamos 2 meses. Pagas 190€/año en lugar de 228€ (ahorro de 38€).'
  },
  {
    question: '¿Necesito tarjeta para la prueba?',
    answer: 'No. Los 14 días de prueba son completamente gratis, sin requerir tarjeta de crédito. Solo te pedimos datos de pago si decides continuar tras la prueba.'
  },
  {
    question: '¿Hay planes para franquicias o múltiples locales?',
    answer: 'Sí, ofrecemos planes especiales para cadenas y franquicias. Contacta con nosotros para un presupuesto personalizado con descuentos por volumen.'
  }
];

const includedFeatures = [
  'Reservas online ilimitadas',
  'Recordatorios automáticos (email + SMS)',
  'WhatsApp Business integrado',
  'Calendario visual multivista',
  'CRM de clientes completo',
  'Página de reservas personalizada',
  'Pagos online con Stripe',
  'Gestión de servicios y precios',
  'Estadísticas y dashboard',
  'Soporte por email y chat',
  'Usuarios ilimitados',
  'Clientes ilimitados',
  'Exportación de datos',
  'Integración Google Calendar',
  'API disponible',
  'SSL y seguridad incluida'
];
---

<Layout title={pageTitle} description={pageDescription} schema={schema}>
  <Header />
  
  <main class="pt-24">
    <!-- Hero -->
    <section class="py-16 bg-gradient-to-br from-blue-50 to-white">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Precio simple, sin sorpresas
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-8">
          Un plan, todo incluido. Sin comisiones por reserva ni límites ocultos.
        </p>
        <div class="flex flex-wrap justify-center gap-4 text-sm text-gray-600">
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Sin tarjeta para probar
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Cancela cuando quieras
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            30 días garantía
          </span>
        </div>
      </div>
    </section>

    <!-- Pricing Card -->
    <section class="py-12">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="bg-white rounded-2xl shadow-xl border-2 border-blue-500 overflow-hidden">
          <div class="bg-blue-500 text-white text-center py-2 text-sm font-medium">
            🌟 Más popular
          </div>
          <div class="p-8 md:p-12">
            <div class="text-center mb-8">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">Plan Profesional</h2>
              <p class="text-gray-600 mb-6">Todo lo que necesitas para gestionar tu negocio</p>
              <div class="flex items-baseline justify-center gap-2">
                <span class="text-5xl font-bold text-gray-900">19€</span>
                <span class="text-gray-600">/mes</span>
              </div>
              <p class="text-sm text-gray-500 mt-2">o 190€/año (ahorra 38€)</p>
            </div>

            <div class="grid md:grid-cols-2 gap-4 mb-8">
              {includedFeatures.map(feature => (
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-gray-700 text-sm">{feature}</span>
                </div>
              ))}
            </div>

            <div class="text-center">
              <a 
                href="https://agendadereservas.com/register"
                class="inline-block w-full md:w-auto px-8 py-4 bg-blue-600 text-white rounded-lg font-semibold text-lg hover:bg-blue-700 transition-colors"
              >
                Empezar prueba gratis 14 días
              </a>
              <p class="text-sm text-gray-500 mt-4">
                No requiere tarjeta de crédito · Setup en 2 minutos
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Comparison -->
    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4 max-w-4xl">
        <h2 class="text-2xl font-bold text-center mb-8">¿Cuánto ahorras vs la competencia?</h2>
        <div class="overflow-x-auto">
          <table class="w-full bg-white rounded-xl shadow-sm">
            <thead>
              <tr class="bg-gray-100">
                <th class="p-4 text-left">Software</th>
                <th class="p-4 text-center">Coste/mes (3 empleados)</th>
                <th class="p-4 text-center">Ahorro anual con Agenda de Reservas</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-t bg-blue-50">
                <td class="p-4 font-bold text-blue-600">Agenda de Reservas</td>
                <td class="p-4 text-center font-bold">19€</td>
                <td class="p-4 text-center">—</td>
              </tr>
              <tr class="border-t">
                <td class="p-4">AgendaPro</td>
                <td class="p-4 text-center">147€</td>
                <td class="p-4 text-center text-green-600 font-semibold">1.536€</td>
              </tr>
              <tr class="border-t">
                <td class="p-4">Reservio Pro</td>
                <td class="p-4 text-center">63€</td>
                <td class="p-4 text-center text-green-600 font-semibold">528€</td>
              </tr>
              <tr class="border-t">
                <td class="p-4">ElTenedor (comisiones)</td>
                <td class="p-4 text-center">~500€*</td>
                <td class="p-4 text-center text-green-600 font-semibold">~5.772€</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-sm text-gray-500 mt-4 text-center">
          *Estimado para restaurante con 100 reservas/mes y ticket medio 35€ (comisión 12-15%)
        </p>
      </div>
    </section>

    <!-- Guarantee -->
    <section class="py-16">
      <div class="container mx-auto px-4 max-w-3xl text-center">
        <div class="bg-green-50 border border-green-200 rounded-xl p-8">
          <h2 class="text-2xl font-bold text-green-800 mb-4">🛡️ Garantía de satisfacción</h2>
          <p class="text-green-700 mb-4">
            Si en los primeros 30 días decides que Agenda de Reservas no es para ti, te devolvemos el 100% de tu dinero. Sin preguntas, sin complicaciones.
          </p>
          <p class="text-sm text-green-600">
            También puedes probar 14 días gratis sin tarjeta antes de pagar nada.
          </p>
        </div>
      </div>
    </section>

    <FAQ title="Preguntas sobre precios" subtitle="Todo lo que necesitas saber antes de suscribirte." faqs={pricingFAQs} />

    <!-- Final CTA -->
    <section class="py-16 bg-blue-600 text-white text-center">
      <div class="container mx-auto px-4">
        <h2 class="text-2xl md:text-3xl font-bold mb-4">
          ¿Listo para empezar?
        </h2>
        <p class="text-blue-100 mb-8 max-w-xl mx-auto">
          Prueba Agenda de Reservas gratis 14 días. Sin tarjeta, sin compromiso.
        </p>
        <a 
          href="https://agendadereservas.com/register"
          class="inline-block px-8 py-4 bg-white text-blue-600 rounded-lg font-semibold hover:bg-gray-100 transition-colors"
        >
          Empezar prueba gratuita →
        </a>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
