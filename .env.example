# Analytics Configuration
# Copy this file to .env and fill in your actual values

# Google Analytics 4 - Get from https://analytics.google.com/
PUBLIC_GA_ID=G-XXXXXXXXXX

# Plausible Analytics - Privacy-friendly alternative (optional)
# Get from https://plausible.io/
PUBLIC_PLAUSIBLE_DOMAIN=cita2.tecelia.com

# Optional: Disable analytics in development
PUBLIC_DISABLE_ANALYTICS=false
