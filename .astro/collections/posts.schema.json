{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "author": {
      "default": "Cita2 Team",
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "productividad",
        "marketing",
        "tecnologia",
        "sectores",
        "tutoriales",
        "noticias"
      ]
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "image": {
      "type": "string"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "readingTime": {
      "type": "number"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "pubDate",
    "category"
  ]
}