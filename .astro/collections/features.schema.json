{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "icon": {
      "default": "calendar",
      "type": "string",
      "enum": [
        "calendar",
        "bell",
        "users",
        "credit",
        "message",
        "chart",
        "smartphone",
        "zap"
      ]
    },
    "order": {
      "default": 0,
      "type": "number"
    },
    "sectors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description"
  ]
}