{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "quote": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "rating": {
      "default": 5,
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "sector": {
      "type": "string"
    },
    "order": {
      "default": 0,
      "type": "number"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "quote",
    "author",
    "role",
    "company"
  ]
}